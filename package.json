{
  "name": "whoniverse-arabic",
  "version": "1.5.0",
  "description": "Doctor Who for Stremio with separate English and Arabic subtitle tracks.",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "audit:subtitles": "node tools/subtitleAudit.js",
    "build:arabic": "node tools/buildArabicProduction.js",
    "normalize:arabic": "node tools/normalizeArabicProduction.js",
    "build:stream-metadata": "node tools/buildStreamMetadata.js",
    "build:subtitle-status": "node tools/buildSubtitleStatus.js",
    "build:arabic-alternatives": "python3 tools/buildArabicAlternatives.py",
    "check": "node tools/checkProduction.js",
    "validate:torrents": "node tools/validateTorrentSources.js"
  },
  "dependencies": {
    "stremio-addon-sdk": "^1.6.10"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "stremio",
    "stremio-addon",
    "doctor-who",
    "metadata",
    "catalog",
    "nucabe"
  ],
  "author": "MohammadHaddad11"
}
