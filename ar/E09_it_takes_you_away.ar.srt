1
00:00:13,859 --> 00:00:26,859
Translated by .. MadNess
تـرجمـة .. إبتـهـال

2
00:00:44,996 --> 00:00:47,699
فيورد جميل

3
00:00:48,600 --> 00:00:50,180
هذا فيورد، أليس كذلك؟

4
00:00:51,500 --> 00:00:53,180
هل عرفتِ مكاننا بعد يا دكتور؟

5
00:00:54,859 --> 00:00:57,378
النرويج، لا شك بأنها النرويج

6
00:00:57,379 --> 00:00:59,419
واحدة من تلك الأجزاء الشمالية

7
00:00:59,420 --> 00:01:01,100
تراجعوا

8
00:01:06,060 --> 00:01:09,328
لا بأس، نحن في 2018

9
00:01:09,329 --> 00:01:11,539
ظننتنا إنتقلنا لإحدى الثورات الصوفية

10
00:01:11,540 --> 00:01:14,304
المعذرة، ماذا؟ -
الثورات الصوفية -

11
00:01:14,305 --> 00:01:16,139
بعد 193 سنة

12
00:01:16,140 --> 00:01:19,367
تتم إعادة المفاوضات حول
 علاقة البشر بالخراف

13
00:01:19,368 --> 00:01:21,060
مجزرة رهيبة

14
00:01:21,061 --> 00:01:23,159
لطالما أحببت فكرة النرويج

15
00:01:23,820 --> 00:01:26,360
أي جزء منها هذا؟ -
لا أدري -

16
00:01:28,540 --> 00:01:30,939
لكن على بعد 25 ميل
... توجد مزرعة ألباكا

17
00:01:30,940 --> 00:01:32,459
...ومتجر هدايا

18
00:01:32,460 --> 00:01:34,539
تقييمه سيء في
TripAdvisor

19
00:01:34,540 --> 00:01:37,363
تراب؟ -
لا، شكراً -

20
00:01:37,364 --> 00:01:39,163
يوجد منزل صغير هناك على القمة

21
00:01:39,164 --> 00:01:40,645
صحيح

22
00:01:43,180 --> 00:01:45,739
كوخ في النرويج وفي الشتاء

23
00:01:45,740 --> 00:01:47,903
بمدخنة، لكن دون دخان

24
00:01:47,904 --> 00:01:49,360
قد يكون من أكواخ العطلات

25
00:01:50,060 --> 00:01:52,080
ربما، هل نذهب في نزهة؟

26
00:01:52,859 --> 00:01:55,939
تحدثنا أنا وجدتك
عن زيارة النرويج

27
00:01:55,940 --> 00:01:57,279
وما الذي منعكما؟

28
00:01:57,280 --> 00:01:59,380
لم نفعلها فحسب

29
00:02:04,460 --> 00:02:05,609
أنظروا لهذا

30
00:02:05,610 --> 00:02:08,204
"تحمس أحدهم بتطبيق "إصنعها بنفسك

31
00:02:08,205 --> 00:02:11,346
تبدو هذه الألواح أقرب
للتحصين منها إصلاحات

32
00:02:12,399 --> 00:02:14,519
يبدو وكأنه مهجور

33
00:02:16,020 --> 00:02:18,620
هل رأيتم هذا؟
يوجد أحد بالداخل

34
00:02:30,640 --> 00:02:32,446
هل من أحد هنا؟

35
00:02:36,020 --> 00:02:37,700
نظرة سريعة؟ كي نطمئن؟

36
00:02:56,477 --> 00:02:59,580
ثلاثة أقفال في منزل مهجور
وفي مكان معزول

37
00:03:02,540 --> 00:03:04,100
قد يكون من الأفضل أن لا ندخله

38
00:03:04,820 --> 00:03:06,500
يوجد طفل في هذا المنزل

39
00:03:07,940 --> 00:03:10,500
أو مهووس بجمع أحذية الأطفال

40
00:03:15,520 --> 00:03:17,719
أنتما الإثنان، تفقدا الأعلى

41
00:03:17,720 --> 00:03:19,001
هيّا

42
00:03:40,320 --> 00:03:42,939
ريان"، إنها أغلفة حلوى"

43
00:03:55,400 --> 00:03:58,320
لا بأس، لا عليكِ، أنا آسف
لم نقصد إخافتكِ

44
00:04:01,460 --> 00:04:03,499
مرحباً، نريد مساعدتكِ

45
00:04:03,500 --> 00:04:04,899
ما اسمكِ؟

46
00:04:04,900 --> 00:04:06,219
هل أنتِ جائعة؟

47
00:04:06,220 --> 00:04:09,348
لأنني أصبحت أحمل معي
شطيرة جبن ومخلل

48
00:04:09,349 --> 00:04:11,060
لحالات الطوارئ

49
00:04:12,475 --> 00:04:15,259
أتأخذ معك شطيرة في
كل مرة تغادر فيها التاردس؟

50
00:04:15,260 --> 00:04:17,059
نعم، لأن التجارب علمتني، صحيح؟

51
00:04:17,060 --> 00:04:19,379
يمكن أن يمر وقت طويل
قبل أن يتاح لنا أن نأكل

52
00:04:19,380 --> 00:04:21,859
ويتعكر مزاجي إذا إنخفضت
مستويات السكر في دمي

53
00:04:21,860 --> 00:04:24,579
والآن .. أخرج مستعداً

54
00:04:25,060 --> 00:04:28,220
من أنتم، وكيف دخلتم إلى منزلنا؟

55
00:04:29,675 --> 00:04:33,154
"أنا الدكتور، وهؤلاء "ياز
"و "ريان" و "غراهام

56
00:04:33,155 --> 00:04:34,167
كنا نتنزه

57
00:04:34,168 --> 00:04:36,259
لكن قلقنا بشأن إحتمال
وجود مشكلة هنا

58
00:04:36,666 --> 00:04:39,666
حين قلتِ "منزلنا"، من يعيش معكِ؟

59
00:04:41,973 --> 00:04:45,220
إذا لم تمانعي السؤال
ما الذي أخافكِ هكذا؟

60
00:04:47,820 --> 00:04:49,300
الشيء

61
00:04:53,620 --> 00:04:55,340
أي شيء يا حبيبتي؟

62
00:04:56,686 --> 00:04:59,218
ذلك الشيء الذي كان
أبي يحمي المنزل منه

63
00:04:59,219 --> 00:05:01,139
دخل إلى هنا وأخذه

64
00:05:01,140 --> 00:05:02,980
ما شكل ذلك الشيء؟

65
00:05:17,767 --> 00:05:19,200
ما اسمكِ؟

66
00:05:20,180 --> 00:05:21,340
"هانا"

67
00:05:22,106 --> 00:05:23,666
هل أنتِ كفيفة يا "هانا"؟

68
00:05:31,040 --> 00:05:33,560
أرجوكم ... ساعدوني لأجد أبي

69
00:05:35,593 --> 00:05:37,832
سمعت الشيء هنا
قبل أن أخلد للنوم

70
00:05:37,833 --> 00:05:40,113
وفي الصباح، إختفى أبي

71
00:05:40,114 --> 00:05:42,060
لا تعلمين ما إذا كان قد دخل المنزل؟

72
00:05:42,860 --> 00:05:45,362
كيف تعلمين بأن أبيكِ
لم يرحل ويترككِ؟

73
00:05:45,363 --> 00:05:47,659
ما كان أبي ليتركني أبداً، حسناً؟

74
00:05:47,660 --> 00:05:49,499
"ريان" -
ماذا؟ -

75
00:05:49,500 --> 00:05:52,100
منذ متى إختفى؟ -
أربعة أيام -

76
00:05:52,900 --> 00:05:54,140
حسناً

77
00:05:56,180 --> 00:05:57,280
أحببت قميصكِ

78
00:05:57,980 --> 00:06:00,899
أنا من شيفيلد، مثل فرقة
"أركتك مونكيز"

79
00:06:00,900 --> 00:06:02,760
حضرت ابنة عمي أول عرض لفرقتهم

80
00:06:03,399 --> 00:06:05,738
وحضرت أمي أول عرض لهم في النرويج

81
00:06:05,739 --> 00:06:07,539
كان هذا القميص لها

82
00:06:07,540 --> 00:06:09,220
أين أمكِ يا "هانا"؟

83
00:06:10,287 --> 00:06:11,326
لقد ماتت

84
00:06:11,955 --> 00:06:14,346
يؤسفني سماع ذلك
لا بد بأنكِ تفتقدينها

85
00:06:14,347 --> 00:06:15,793
طوال الوقت

86
00:06:15,794 --> 00:06:17,379
وكذلك أبي

87
00:06:17,380 --> 00:06:18,499
بالطبع

88
00:06:18,500 --> 00:06:21,499
وأظن بأن ما كان يقصده "ريان" قوله

89
00:06:21,500 --> 00:06:24,259
أن من الواضح أن أبيكِ
لم يرغب بأن يترككِ

90
00:06:24,260 --> 00:06:29,539
لكن ماذا لو ذهب للعمل
أو ماشابه... ثم تاه أو أصيب؟

91
00:06:29,540 --> 00:06:33,434
ترك العمل حين غادرنا أوسلو
ولا يزال المركب هنا

92
00:06:33,435 --> 00:06:35,099
ذهبت إليه لأتحقق

93
00:06:39,060 --> 00:06:40,699
يجب أن ندخل

94
00:06:40,700 --> 00:06:42,374
دائماً ما يأتي في هذا الوقت

95
00:06:42,375 --> 00:06:43,979
نفس الوقت من كل يوم؟

96
00:06:44,419 --> 00:06:45,900
هذا وقت الصيد بالنسبة له

97
00:06:49,901 --> 00:06:51,975
طفلة مسكينة -
لا تصدقون هذا -

98
00:06:51,976 --> 00:06:54,740
تركها أبيها وهرب
وهي تختلق هذا الوحش

99
00:06:54,741 --> 00:06:56,875
لا داعي للإفتراضات

100
00:06:57,333 --> 00:06:59,095
أنتما، ألقيا نظرة على السقيفة

101
00:07:00,113 --> 00:07:01,592
غراهام"، لنتحقق من المنزل" -
حسناً -

102
00:07:01,593 --> 00:07:02,874
لا تطيلا البقاء في الخارج

103
00:07:08,660 --> 00:07:10,340
هل تفتقدين المدينة؟

104
00:07:11,420 --> 00:07:13,099
أحياناً

105
00:07:13,100 --> 00:07:16,047
لكن أراد أبي التغيير
بعد أن ماتت أمي

106
00:07:16,834 --> 00:07:19,052
هل أتى هنا ليهرب من ذكرياته إذن؟

107
00:07:19,053 --> 00:07:22,779
نعم، وكان مهجوراً لسنوات
لذا وجدناه رخيصاً

108
00:07:22,780 --> 00:07:24,948
هل كان أبيكِ من وضع
هذه الألواح والأقفال في كل مكان؟

109
00:07:24,949 --> 00:07:26,619
قبل إختفائه بيوم

110
00:07:26,620 --> 00:07:28,459
قلت له بأنه مجنون

111
00:07:28,460 --> 00:07:30,160
لا يوجد أحد على بعد أميال

112
00:07:30,980 --> 00:07:35,420
لكنه قال "يوجد أشياء
"أسوأ من البشر

113
00:07:47,660 --> 00:07:50,099
ما هذه الرائحة؟

114
00:07:50,100 --> 00:07:51,580
لا أظنني أريد أن أعرف

115
00:07:59,340 --> 00:08:02,059
هل صرخت؟ -
لا تعتبر الطيور الميتة شيئاً طبيعياً -

116
00:08:02,060 --> 00:08:04,380
قد تكون طبيعية في النرويج

117
00:08:06,180 --> 00:08:07,859
تعاملتِ معها بشكل جيّد قبل قليل

118
00:08:07,860 --> 00:08:09,456
أنا سيء بالتعامل مع الأطفال

119
00:08:09,457 --> 00:08:11,305
صحيح، لأنني تلقيت تدريباً

120
00:08:11,306 --> 00:08:14,987
يجب أن تعزز الشيء
الذي يشعرهم بالأمان

121
00:08:19,700 --> 00:08:20,777
"ريان"

122
00:08:21,497 --> 00:08:23,859
ما هذه؟ فخاخ للحيوانات؟

123
00:08:25,940 --> 00:08:27,420
إنه قادم

124
00:08:28,420 --> 00:08:29,979
دكتور

125
00:08:29,980 --> 00:08:31,179
دكتور

126
00:08:31,180 --> 00:08:32,965
هل رأيتماه؟ -
لا -

127
00:08:32,966 --> 00:08:34,299
لكن أبو "هانا" رآه

128
00:08:34,300 --> 00:08:37,459
لديه سقيفة مليئة
بهذه الأشياء في.. السقيفة

129
00:08:37,460 --> 00:08:39,739
وهذا ليس طبيعياً
حتى بالنسبة للنرويج

130
00:08:41,220 --> 00:08:42,459
ما ذلك الشيء؟

131
00:08:42,460 --> 00:08:44,940
لا أدري، لكن بدا صوته
وكأنه قادم من الغابة

132
00:08:47,173 --> 00:08:48,174
للداخل

133
00:08:53,180 --> 00:08:54,779
يجب أن نؤمن المنزل

134
00:08:54,780 --> 00:08:56,890
ياز"، و "ريان" سدّا الباب الخلفي"

135
00:08:57,340 --> 00:08:59,819
غراهام"، ألقِ نظرة "
من نافذة الطابق الثاني

136
00:08:59,820 --> 00:09:01,100
حسناً

137
00:09:05,580 --> 00:09:08,019
يأخذك بعيداً، يأخذك بعيداً

138
00:09:08,020 --> 00:09:09,539
يأخذك بعيداً

139
00:09:09,540 --> 00:09:10,858
هانا"، اسمعيني"

140
00:09:10,859 --> 00:09:13,399
أيّاً كان ما في الخارج
فسنبقيكِ بأمان

141
00:09:13,400 --> 00:09:14,959
لكنه يأخذكِ بعيداً

142
00:09:16,119 --> 00:09:17,839
أرأيت شيئاً؟

143
00:09:17,840 --> 00:09:19,625
لا شيء بعد

144
00:09:53,375 --> 00:09:56,430
لا تفعل هذا

145
00:09:56,431 --> 00:09:57,951
لمَ لسنا في المرآة؟

146
00:09:57,952 --> 00:09:59,513
لا أدري

147
00:10:03,142 --> 00:10:05,678
كنا سنعرف لو كنا مصاصي دماء، صحيح؟

148
00:10:05,679 --> 00:10:06,800
صحيح

149
00:10:11,120 --> 00:10:12,639
ما هذا الصوت؟

150
00:10:12,640 --> 00:10:14,840
!إبتعدا عن المرآة! كلاكما

151
00:10:15,920 --> 00:10:16,999
تراجعا

152
00:10:17,000 --> 00:10:18,719
نحن هناك

153
00:10:18,720 --> 00:10:19,896
ما الذي حدث؟

154
00:10:21,017 --> 00:10:23,994
لست متأكدة تماماً
لكنه لا يعجبني

155
00:10:23,995 --> 00:10:26,519
هل رأيت تغييراً؟
ما الذي حدث هنا؟

156
00:10:26,520 --> 00:10:28,439
سمعت صوتاً، وأتيت للمرآة

157
00:10:28,440 --> 00:10:30,919
ولم تكن صورتي منعكسة

158
00:10:32,640 --> 00:10:34,159
ها هي ثانية

159
00:10:34,160 --> 00:10:36,905
وذلك الصوت -
لا أحد يتحرك -

160
00:10:38,542 --> 00:10:41,679
حجزته، وهو يفعل ما يفعله

161
00:10:41,680 --> 00:10:44,399
أيمكنني أن أقول بأنني أحب مفكي

162
00:10:44,400 --> 00:10:46,090
... والآن

163
00:10:46,091 --> 00:10:49,180
متى لا تكون المرآة مرآة؟

164
00:11:07,771 --> 00:11:09,679
أنا بخير

165
00:11:09,680 --> 00:11:12,005
غالباً، أشعر برأسي متزعزع قليلاً

166
00:11:12,006 --> 00:11:13,647
وغير ذلك أنا بخير تماماً

167
00:11:14,800 --> 00:11:16,125
أقدره بـ 7 من 10

168
00:11:16,126 --> 00:11:17,359
أو 6.5 على الأسوأ

169
00:11:17,360 --> 00:11:19,599
ما كان ذلك الصوت؟
إهتز المنزل بأكمله

170
00:11:19,600 --> 00:11:21,999
"مرحباً يا "ياز"، وأهلاً يا "هانا
يحدث الكثير هنا

171
00:11:22,000 --> 00:11:24,199
هل كان ما في الخارج؟ -
لا -

172
00:11:24,200 --> 00:11:27,279
يبدو بأن هذه المرآة التي في
غرفة أبيكِ عبارة عن بوابة

173
00:11:27,280 --> 00:11:29,359
... حين تقولين بوابة

174
00:11:29,360 --> 00:11:33,479
بوابة لعالم آخر، أو بعد آخر
أو من يعلم ماذا؟

175
00:11:33,480 --> 00:11:35,239
لكن دعوني أخبركم
إنه يعبث بعقلك

176
00:11:35,240 --> 00:11:37,742
ما الذي تتحدثين عنه؟ -
أعلم، إنه إكتشاف مهم -

177
00:11:37,743 --> 00:11:39,839
كان يفترض أن أخبركِ
بطريقة ألطف

178
00:11:39,840 --> 00:11:41,363
لكن كما قلت، رأسي متزعزع

179
00:11:41,364 --> 00:11:43,759
أيّا ما كان في الغابة، هل
يمكن أن يكون مصدره البوابة؟

180
00:11:43,760 --> 00:11:45,479
ممكن، لا أدري
لم أرَ الكثير

181
00:11:45,480 --> 00:11:46,919
يجب أن ألقي نظرة أفضل

182
00:11:46,920 --> 00:11:48,599
دكتور، أتظنينه آمن؟

183
00:11:48,600 --> 00:11:49,719
أشك بذلك

184
00:11:49,720 --> 00:11:51,378
إنها بوابة لبعد بإهتزازات قوية

185
00:11:51,379 --> 00:11:53,662
في غرفة نوم في النرويج

186
00:11:53,663 --> 00:11:55,134
سآتي معكِ

187
00:11:55,135 --> 00:11:56,599
وأنا أيضاً -
وكذلك أنا -

188
00:11:56,600 --> 00:12:00,240
وأنا، أيّا كان ما يحدث
سأبقى معكم

189
00:12:02,280 --> 00:12:03,946
"لا يمكنني أن أسمح لكِ بهذا يا "هانا

190
00:12:03,947 --> 00:12:05,399
لا أعرف ما يوجد عبر البوابة

191
00:12:05,400 --> 00:12:07,759
وأنتِ آمنة هنا
أمّن لكِ أبيكِ هذا المكان

192
00:12:07,760 --> 00:12:09,919
وأيضاً، أحتاجكِ لحماية المنزل

193
00:12:09,920 --> 00:12:11,439
مما يوجد في الخارج

194
00:12:11,440 --> 00:12:13,279
وسيبقى "ريان" هنا معكِ -
ماذا؟ -

195
00:12:13,280 --> 00:12:15,759
إلا هو -
لمَ قلتِ هذا؟ -

196
00:12:16,263 --> 00:12:18,719
وكلاكما، إبتعدا عن المرآة

197
00:12:18,720 --> 00:12:20,463
فقد حاولت إستدراج "غراهام" إليها

198
00:12:20,464 --> 00:12:22,837
صحيح -
لم تقم بإستدراجي -

199
00:12:22,838 --> 00:12:25,159
ليس وكأنني أعطيتها
 معلومات بطاقتي

200
00:12:32,395 --> 00:12:35,559
هذه خريطة للمنزل توضح
الأماكن المعرضة للهجوم

201
00:12:35,560 --> 00:12:37,439
إحرص على أن تهتم بها

202
00:12:37,440 --> 00:12:38,560
حسناً

203
00:12:38,640 --> 00:12:42,260
قد يكون أبيها ميّت .. أبقها بأمان
وإسأل عن من غيره يمكنه العناية بها

204
00:12:46,287 --> 00:12:48,159
ما اسم أبيكِ يا "هانا"؟

205
00:12:48,160 --> 00:12:49,719
"إيريك"

206
00:12:49,720 --> 00:12:51,279
سوف تجدونه، صحيح؟

207
00:12:51,960 --> 00:12:53,520
سأفعل ما بوسعي

208
00:12:58,633 --> 00:13:02,080
لا أظنها فكرة جيّدة

209
00:13:03,073 --> 00:13:04,993
لنذهب

210
00:13:09,440 --> 00:13:11,039
بالكاد أرى شيئاً

211
00:13:11,040 --> 00:13:13,830
أشبه ببوابة للمكان والزمن
وثبتت نفسها بتلك المرآة

212
00:13:13,831 --> 00:13:15,516
لكن لا يفترض أن تبدو هكذا

213
00:13:15,517 --> 00:13:17,359
كل أجزاء الضوء الغريبة هذه

214
00:13:17,360 --> 00:13:20,159
وكأن البوابة عالقة بين نصفين

215
00:13:20,160 --> 00:13:22,759
كان يفترض أن ندخل لعالم آخر

216
00:13:22,760 --> 00:13:25,959
هذا عالم آخر -
ليس تبعاً لقراءاتي -

217
00:13:25,960 --> 00:13:29,679
أما زلنا في النرويج أم لا؟ -
أيبدو لك هذا نرويجياً؟ -

218
00:13:29,680 --> 00:13:33,239
ليس تماماً -
لنلقي نظرة، بحذر -

219
00:13:33,240 --> 00:13:36,439
دكتور، يوجد ضوء من تلك الصخرة

220
00:13:36,440 --> 00:13:40,080
"ملاحظة جيّدة يا "غراهام
إبقيا بقربي

221
00:13:41,046 --> 00:13:43,246
لنحرص على أن نجد طريق عودتنا

222
00:13:45,367 --> 00:13:48,040
أهذا خيط؟ يا لها من تقنية متطورة

223
00:13:53,440 --> 00:13:54,813
...أكسرك

224
00:14:00,882 --> 00:14:04,039
أكسرك، وألمس لحمك

225
00:14:04,040 --> 00:14:07,519
...وأقتلعك، وكل قطعة منك

226
00:14:07,520 --> 00:14:09,952
مرحباً، آسفون لإزعاجك

227
00:14:12,000 --> 00:14:14,759
هل رأيت مخلوق مزعج
أتى من هذا الإتجاه؟

228
00:14:14,760 --> 00:14:18,359
أو بشريّ نرويجي، يحتمل
أنه إتجه للإتجاه الآخر؟

229
00:14:18,360 --> 00:14:21,576
بإسم "إيريك"، أعني البشريّ

230
00:14:21,577 --> 00:14:23,035
إبنته تبحث عنه

231
00:14:23,720 --> 00:14:25,200
يالها من مأساة

232
00:14:25,840 --> 00:14:28,360
تشعرني بالجوع

233
00:14:30,271 --> 00:14:31,919
لا

234
00:14:31,920 --> 00:14:34,119
حسناً، إذا لم تستطع مساعدتنا
فهل يمكننا أن نأخذ مصباحك؟

235
00:14:34,120 --> 00:14:36,331
لأنه يبدو بأنك إحتكرت الضوء هنا

236
00:14:36,332 --> 00:14:39,559
لا صدقة، مبادلة فقط

237
00:14:39,560 --> 00:14:41,342
إبتعد

238
00:14:41,343 --> 00:14:43,394
المصباح ليس لك

239
00:14:43,395 --> 00:14:45,108
حسناً، كنت أنظر إليه فحسب

240
00:14:45,109 --> 00:14:46,789
إهدأ

241
00:14:46,790 --> 00:14:48,719
الطير غداء

242
00:14:48,720 --> 00:14:51,159
ربما عجوز للشاي

243
00:14:51,160 --> 00:14:52,799
من تقصد بالعجوز؟

244
00:14:52,800 --> 00:14:54,479
أنت ورائحتك النتنة كالبول

245
00:14:54,480 --> 00:14:56,879
هذا ليس بولي

246
00:14:56,880 --> 00:15:00,579
دعه يذهب، لأنك لا تريد
أن تكون هذه كلماتك الأخيرة

247
00:15:00,580 --> 00:15:04,119
سيّدتي

248
00:15:04,120 --> 00:15:08,239
اسمي "ريبونز" من المعدات السبعة

249
00:15:09,403 --> 00:15:12,399
أريد أنبوبكِ

250
00:15:12,400 --> 00:15:15,416
أنبوب لامع

251
00:15:15,417 --> 00:15:19,187
لأن "ريبونز" رأى الرجل
... الذي تبحثين عنه

252
00:15:19,188 --> 00:15:21,546
المبادلة الآن ممكنة

253
00:15:21,547 --> 00:15:26,959
بهذا الأنبوب، يمكن أن
تشتري معلومات لذيذة

254
00:15:26,960 --> 00:15:28,960
ومصباح

255
00:15:30,280 --> 00:15:32,964
كيف كان يبدو؟ هذا الرجل؟

256
00:15:32,965 --> 00:15:38,077
بلا قرون، وفم واحد، وقبيح جداً

257
00:15:38,078 --> 00:15:43,079
مثلكم، لكن بحذاء أجمل

258
00:15:43,080 --> 00:15:44,840
إنه حيّ إذن

259
00:15:45,800 --> 00:15:48,725
هل كان معه أحد؟ أو شيء؟

260
00:15:48,726 --> 00:15:51,456
ستعرفين حين آخذكِ

261
00:15:51,457 --> 00:15:53,660
لكن بعد الدفع

262
00:15:54,656 --> 00:15:57,560
الأنبوب من فضلكِ، الآن

263
00:15:58,806 --> 00:16:02,082
الدفع عند الإستلام
وأترك السكين هنا

264
00:16:14,800 --> 00:16:17,599
دكتور، لن تعطيه المفك، صحيح؟

265
00:16:17,600 --> 00:16:21,719
أنظري.. لديه حزام مليء
بجرذان ميتة ذات ستة أرجل

266
00:16:21,720 --> 00:16:23,279
غراهام" محق"

267
00:16:23,280 --> 00:16:25,319
"قد يكون من أخذ "إيريك

268
00:16:25,320 --> 00:16:27,999
وتريديننا أن نتبع هذا
المجنون نحو الظلام

269
00:16:28,000 --> 00:16:30,239
لا، بل أريدكم أن تتبعا
هذه المجنونة نحو الظلام

270
00:16:30,240 --> 00:16:32,199
يوجد ثلاثة منا، ولا يوجد سواه

271
00:16:32,200 --> 00:16:33,639
بالإضافة للجرذان

272
00:16:33,640 --> 00:16:36,600
مهم أن تبقوا هادئين يا أصدقاء

273
00:16:37,560 --> 00:16:40,039
تفضلوا، ضوء
لإثبات حسن النية

274
00:16:40,040 --> 00:16:43,360
إتبعوا "ريبونز" للأب المفقود

275
00:16:47,080 --> 00:16:48,559
هل كنتِ طوال عمركِ كفيفة؟

276
00:16:48,560 --> 00:16:49,833
تقريباً

277
00:16:49,834 --> 00:16:52,080
يمكنني أن أرى الضوء
إذا كان قريباً جداً مني

278
00:16:53,080 --> 00:16:54,199
لا بد بأنه صعب

279
00:16:54,200 --> 00:16:56,019
لا أريد شفقتك

280
00:16:56,918 --> 00:16:58,479
لمَ لا تحبينني؟

281
00:16:58,480 --> 00:17:00,231
ظننت بأن أبي سيتركني

282
00:17:00,232 --> 00:17:02,800
حسناً، أنا آسف، كنت مخطئاً

283
00:17:04,440 --> 00:17:06,936
أي جزء من المنزل
يعتبر عرضة للهجوم؟

284
00:17:11,320 --> 00:17:12,720
المستنبت الزجاجي

285
00:17:15,849 --> 00:17:17,869
أعني.. أعني الشرفة

286
00:17:18,642 --> 00:17:20,349
ليست خريطة، صحيح؟

287
00:17:20,350 --> 00:17:21,828
بدا صوتها وكأنها تكتب شيئاً

288
00:17:21,829 --> 00:17:24,615
بل هي خريطة حقاً -
ما الذي تخفيه عني؟ -

289
00:17:24,616 --> 00:17:25,740
أريد أن أذهب معهم

290
00:17:25,741 --> 00:17:28,398
قالت الدكتور بأن نبقى هنا -
أريد أبي -

291
00:17:28,399 --> 00:17:29,960
أتركني

292
00:17:33,520 --> 00:17:35,519
أعطني هذا المفتاح

293
00:17:35,520 --> 00:17:37,959
لا يمكنك أن تمسك بي
وتسحبني حيث شئت

294
00:17:37,960 --> 00:17:39,519
يمكن أن أتصل بالشرطة -
ثم ماذا؟ -

295
00:17:39,520 --> 00:17:40,839
وتخبرينهم بشأن الوحش؟

296
00:17:40,840 --> 00:17:43,010
أو البوابة التي في المرآة؟
كيف سيساعدكِ ذلك؟

297
00:17:43,011 --> 00:17:44,879
لا يعجبني كذبك عليّ

298
00:17:44,880 --> 00:17:46,439
بشأن ما كتبته على الجدار

299
00:17:46,440 --> 00:17:48,399
كان هذا أقرب

300
00:17:48,400 --> 00:17:50,840
ماذا لو نكف عن الجدال
ونتحقق من دفاعاتنا؟

301
00:17:53,720 --> 00:17:55,759
إلى أين ستأخذنا بالضبط يا "ريبونز"؟

302
00:17:55,760 --> 00:17:58,778
"إهدأوا! واستمتعوا مع "ريبونز

303
00:17:58,779 --> 00:18:00,220
نحن كذلك

304
00:18:00,920 --> 00:18:03,287
أخبرنا عن هذه المصابيح
التي تفخر بها

305
00:18:03,874 --> 00:18:05,254
تصميمي

306
00:18:05,760 --> 00:18:07,198
الضوء الوحيد هنا

307
00:18:07,199 --> 00:18:08,359
هنا أين؟

308
00:18:08,360 --> 00:18:12,079
المعلومات باهضة جداً للأسف

309
00:18:12,080 --> 00:18:14,843
لا تملكين الرصيد الكافي

310
00:18:14,844 --> 00:18:16,599
لكنك تعيش هنا، كما أفترض

311
00:18:16,600 --> 00:18:19,079
بما أنه يوجد بوابة قرب
 المكان الذي وجدناك فيه

312
00:18:19,080 --> 00:18:20,640
وإخترت أن لا تستخدمها

313
00:18:23,690 --> 00:18:25,959
تسألين الأسئلة الذكية

314
00:18:25,960 --> 00:18:29,400
أراهن على أن مذاق دماغكِ لذيذ

315
00:18:32,440 --> 00:18:34,680
ما هذا؟ -
عث اللحم -

316
00:18:35,987 --> 00:18:37,580
غلطتكم

317
00:18:37,581 --> 00:18:39,341
لا تتحركوا

318
00:18:48,022 --> 00:18:49,762
هذا عث خطير

319
00:18:50,282 --> 00:18:55,719
لن يؤذي الملابس، لكن
 يفسخ اللحم عن العظام

320
00:18:55,720 --> 00:19:00,360
لحسن الحظ، أي شيء
يمكن تشتيته بالطعام

321
00:19:02,160 --> 00:19:04,943
للأمام يا أصدقاء

322
00:19:06,113 --> 00:19:08,273
سيخلي "ريبونز" المكان ويتبعكم

323
00:19:30,400 --> 00:19:32,320
لا بد بأنك تمزح

324
00:19:44,160 --> 00:19:45,640
لمَ تفعل هذا؟

325
00:19:47,640 --> 00:19:48,960
هانا"؟"

326
00:19:50,240 --> 00:19:51,519
"هانا"

327
00:19:51,520 --> 00:19:53,920
لا داعي للخوف، لا يوجد
 مخلوق في الخارج

328
00:20:04,920 --> 00:20:06,750
لم أعد أعرف أين أنا

329
00:20:06,751 --> 00:20:08,799
هذا المكان أشبه بمتاهة

330
00:20:08,800 --> 00:20:10,199
هل رأيت "إيريك" هنا؟

331
00:20:10,200 --> 00:20:12,164
لا، لا، لا، لا

332
00:20:12,165 --> 00:20:15,399
يضعكم "ريبونز" في
 أضعف حالاتكم للمفاوضة

333
00:20:15,400 --> 00:20:17,081
ما الذي تتحدث عنه؟

334
00:20:17,082 --> 00:20:20,000
مؤسف، ليس لديكِ حبل

335
00:20:26,220 --> 00:20:29,620
لا "إيريك"، لا مفك

336
00:20:32,479 --> 00:20:35,039
سكينتان، بالطبع ستحمل سكينتين

337
00:20:35,040 --> 00:20:38,313
كل ما علينا أن نعيد التفاوض

338
00:20:38,314 --> 00:20:40,079
لا يوجد طريق للعودة

339
00:20:40,080 --> 00:20:45,839
يمكنني أن أريكم
لكن هذا الإرشاد اللذيذ يكلف أكثر

340
00:20:45,840 --> 00:20:49,559
يا إلهي، كيف تكون رائحتك أسوأ من السابق؟

341
00:20:51,403 --> 00:20:53,320
عث اللحم يتبعنا

342
00:20:55,599 --> 00:20:59,118
يجب أن نتخلص منه
وإلا سيأتي الكثير

343
00:21:02,160 --> 00:21:03,680
الجرذ الأخير

344
00:21:06,573 --> 00:21:07,999
لا يريده

345
00:21:08,000 --> 00:21:11,279
ألا يمكننا التخلص من المصباح؟ -
لا! الظلام أسوأ -

346
00:21:11,280 --> 00:21:12,799
ما هذا المكان يا "ريبونز"؟

347
00:21:12,800 --> 00:21:14,159
منطقة مضادة

348
00:21:14,160 --> 00:21:16,079
أوه، لا

349
00:21:16,080 --> 00:21:18,239
أهذا شيء جيّد أم سيء؟

350
00:21:18,240 --> 00:21:20,559
المنطقة المضادة هي شيء
يصنعه الكون

351
00:21:20,560 --> 00:21:24,079
كلما أصبح نسيج المكان
...والزمن مهدداً، مثل

352
00:21:24,080 --> 00:21:26,559
منطقة مصد حماية...
لتبقي التهديد بعيداً

353
00:21:26,560 --> 00:21:28,599
ونحن في الوسط

354
00:21:28,600 --> 00:21:30,439
كيف وصلت إلى هنا يا "ريبونز"؟

355
00:21:30,440 --> 00:21:32,040
لطالما كنت هنا

356
00:21:35,240 --> 00:21:37,239
ما الذي يحدث؟

357
00:21:38,880 --> 00:21:42,479
يستدعي عث اللحم جماعته
الإشارة تقتل مصباحي

358
00:21:42,480 --> 00:21:44,300
سيأتي الكثير منهم الآن

359
00:21:44,880 --> 00:21:46,399
يجب أن تركضوا

360
00:21:46,400 --> 00:21:49,479
أعطيني أنبوبي الآن -
لا، لن تأخذه يا عزيزي -

361
00:21:52,980 --> 00:21:55,079
ما رأيك بهذا بالنسبة لعجوز
يا ذو السكينتين؟

362
00:21:55,080 --> 00:21:56,261
الصمت

363
00:21:56,920 --> 00:21:58,239
إنهم هنا

364
00:21:58,240 --> 00:22:00,330
"ياز" و "غراهام"

365
00:22:01,040 --> 00:22:03,880
لا تحركا عضلة...

366
00:22:04,840 --> 00:22:08,639
يريدنا أن نركض
لذا سنبقى ثابتين تماماً

367
00:22:16,971 --> 00:22:19,118
لا يا "ريبونز"، لا تفعل

368
00:22:19,119 --> 00:22:21,679
لا! ليس أنا

369
00:22:21,680 --> 00:22:25,200
هاجموا الآخرين، ليس أنا

370
00:22:29,683 --> 00:22:31,880
بلطف وهدوء، والآن أركضا

371
00:22:36,080 --> 00:22:38,575
إستمرا! يوجد ضوء أمامنا

372
00:22:38,576 --> 00:22:40,360
ها هي البوابة

373
00:22:49,680 --> 00:22:51,376
ما كان ذلك؟

374
00:22:51,377 --> 00:22:53,355
لا أدري، لكن أظننا آمنون الآن

375
00:22:53,356 --> 00:22:56,119
هل غيروا أماكن الأثاث هنا؟

376
00:22:56,120 --> 00:22:58,360
كل شيء يبدو مختلفاً

377
00:22:59,680 --> 00:23:02,080
لا أظنها نفس البوابة
التي دخلنا عبرها

378
00:23:03,183 --> 00:23:06,800
لكن إذا لم تكن نفس البوابة
فكيف عدنا لغرفة النوم؟

379
00:23:09,093 --> 00:23:12,093
يبدو لي بأننا وصلنا
للجانب الآخر من المرآة

380
00:23:33,760 --> 00:23:35,239
"هانا"

381
00:24:18,760 --> 00:24:20,119
لم نقاطعك، صحيح؟

382
00:24:21,480 --> 00:24:24,061
ما الذي تفعلونه في منزلي؟ -
ما الذي تفعله في منزلك؟ -

383
00:24:24,062 --> 00:24:27,076
وكيف يكون هذا منزلك يا "إيريك"؟
هذا مستحيل، صحيح؟

384
00:24:27,077 --> 00:24:29,039
من أنتِ وكيف تعرفين إسمي؟

385
00:24:29,040 --> 00:24:30,367
أترك هذا من يدك

386
00:24:30,368 --> 00:24:33,399
أتينا عبر المنطقة المضادة
بعد أن أرسلتنا إبنتك التي هجرتها

387
00:24:33,400 --> 00:24:35,239
ولم يكن الأمر ممتعاً

388
00:24:35,240 --> 00:24:37,719
"لم أهجر "هانا -
بلى فعلت يا صاح -

389
00:24:37,720 --> 00:24:40,319
إنها خائفة وجائعة
وتظن بأنك أُختطفت

390
00:24:40,320 --> 00:24:43,519
إنها مراهقة، ويوجد طعام في الثلاجة
وهي بخير دون وجودي

391
00:24:43,520 --> 00:24:46,119
يوجد وحش طليق في
 الغابة خارج منزلك

392
00:24:46,120 --> 00:24:48,719
لا، لا يوجد شيء -
تبدو متأكداً من ذلك -

393
00:24:48,720 --> 00:24:51,726
لأنه مجرد تسجيل
كي لا تذهب إلى التلال

394
00:24:52,426 --> 00:24:56,544
حولت بيتك لحصن
لتخيف إبنتك؟

395
00:24:56,545 --> 00:24:58,763
لأبقيها بأمان، حين أغيب

396
00:24:58,764 --> 00:25:00,719
أسلوب تربية مريع

397
00:25:00,720 --> 00:25:02,279
كنت تعلم بمجيئك إلى هنا

398
00:25:02,280 --> 00:25:04,080
فلمَ صنعت فخاخ الدببة؟

399
00:25:04,081 --> 00:25:05,740
لأنه يوجد دببة

400
00:25:05,741 --> 00:25:08,305
وليس وحشاً، لكن الدب الطبيعي

401
00:25:08,306 --> 00:25:11,999
اسمعوا، شكراً لقدومكم
 سأعود قريباً، لكن إذهبوا الآن

402
00:25:12,000 --> 00:25:13,359
سوف أضربه

403
00:25:13,360 --> 00:25:15,079
لا، لن تفعل، بل أنا سأضربه

404
00:25:15,080 --> 00:25:16,717
لا أحد سيضرب أحد

405
00:25:17,820 --> 00:25:21,163
يوم طويل، وعث لحم ومنطقة مضادة

406
00:25:21,164 --> 00:25:22,719
والآن، من غيرك هنا يا "إيريك"؟

407
00:25:22,720 --> 00:25:24,199
من الذي لا تريدنا أن نراه؟

408
00:25:24,200 --> 00:25:26,119
لا أعرف ما تقصدينه

409
00:25:26,120 --> 00:25:27,364
بلى، تعرف

410
00:25:27,800 --> 00:25:28,960
طبقين

411
00:25:32,640 --> 00:25:33,879
مرحباً

412
00:25:33,880 --> 00:25:35,799
"أنا "ترينا

413
00:25:35,800 --> 00:25:37,199
"زوجة "إيريك

414
00:25:37,961 --> 00:25:39,280
"إيريك"

415
00:25:39,281 --> 00:25:40,940
هل تزوجت بمن بالمرآة؟

416
00:25:40,941 --> 00:25:43,760
"لا، "ترينا" والدة "هانا

417
00:25:45,320 --> 00:25:46,919
والدة "هانا" ميتة

418
00:25:46,920 --> 00:25:49,291
في عالمكم، لكن ليس هنا

419
00:25:49,292 --> 00:25:50,413
ما الذي تفعلينه؟

420
00:25:51,136 --> 00:25:54,239
هل هذا عالم بديل حيث
لا تموت "ترينا"؟

421
00:25:54,240 --> 00:25:57,359
لا أعرف ما يكون -
... ولا أنا، أقصد -

422
00:25:57,360 --> 00:26:00,541
... لقد مت، وأتذكر ذلك

423
00:26:00,976 --> 00:26:02,622
لكن... ها أنا الآن

424
00:26:03,520 --> 00:26:04,761
لا يمكنها المغادرة

425
00:26:04,762 --> 00:26:07,015
حاولنا لكن لا يمكنها
أن تعبر المرآة

426
00:26:07,016 --> 00:26:09,999
"أعلم بأنني تركت "هانا
لوقت طويل لكنني ظللت أفكر

427
00:26:10,000 --> 00:26:12,160
"ماذا لو ذهبت ولم أستطع العودة؟"

428
00:26:14,280 --> 00:26:16,052
لا يمكنني أن أخسر "تينا" ثانية

429
00:26:16,053 --> 00:26:18,155
يجب أن تعيد ترتيب أولويتاتك يا صاح

430
00:26:18,848 --> 00:26:20,639
إبنتك تحتاجك، هيّا

431
00:26:20,640 --> 00:26:22,480
ألا تريدون أن تروا صديقتكم؟

432
00:26:23,440 --> 00:26:24,740
ما الذي تتحدثين عنه؟

433
00:26:25,840 --> 00:26:27,720
وصلت إلى هنا حين أتيتم

434
00:26:44,960 --> 00:26:46,239
هل أنت بخير؟

435
00:26:46,240 --> 00:26:48,400
نعم ... أعرف ذلك الصوت

436
00:26:59,800 --> 00:27:01,640
"غراهام أوبراين"

437
00:27:03,148 --> 00:27:05,286
يستحسن أن تخبرني
الآن بما يحدث هنا

438
00:27:08,360 --> 00:27:09,960
لا تفعلي هذا بي

439
00:27:24,160 --> 00:27:27,056
لا تتحركي، قفي مكانكِ

440
00:27:27,400 --> 00:27:28,960
"إنه أنا، "ريان

441
00:27:31,282 --> 00:27:33,159
حسناً

442
00:27:33,160 --> 00:27:34,661
سوف أصلح شيئاً

443
00:27:35,293 --> 00:27:37,173
ثم سنتحرك معاً

444
00:27:38,760 --> 00:27:40,360
يوجد ضوء مخبأ هنا

445
00:27:51,002 --> 00:27:53,719
حسناً، أمسكي بكمي

446
00:27:53,720 --> 00:27:56,200
أين نحن؟ -
لا فكرة لديّ، إبقي قربي -

447
00:27:57,440 --> 00:27:58,840
حسناً

448
00:28:02,200 --> 00:28:04,040
أخبرني بما تراه

449
00:28:04,973 --> 00:28:08,360
إنه نوع من الكهوف
لكنه كهف جميل

450
00:28:09,040 --> 00:28:12,102
هل زرتِ كهوف البيك دستركت؟
يشبهها قليلاً

451
00:28:12,575 --> 00:28:14,840
ريان" أنت تكذب علي"

452
00:28:15,840 --> 00:28:17,666
أعتذر لإغلاقي الباب عليك

453
00:28:18,340 --> 00:28:20,340
كان عليّ أن آتي إلى هنا لأجد أبي

454
00:28:21,200 --> 00:28:23,382
حسناً، أتريدين الحقيقة؟

455
00:28:23,955 --> 00:28:25,914
كانت الوحوش التي
 في الغابة مجرد تسجيل

456
00:28:25,915 --> 00:28:28,200
أظن والدكِ فعل ذلك
ليبقيكِ داخل المنزل

457
00:28:29,105 --> 00:28:30,493
كان الإنترنت سيكفيه

458
00:28:31,646 --> 00:28:33,246
هل كذب علي؟

459
00:28:35,000 --> 00:28:36,199
نعم

460
00:28:36,200 --> 00:28:39,120
وأنت تكذب الآن عن
مدى سوء المكان هنا

461
00:28:41,120 --> 00:28:42,567
أحاول أن أعتني بكِ

462
00:28:42,568 --> 00:28:44,122
...أعلم بأنها حماقة، لكن

463
00:28:45,022 --> 00:28:46,236
هل أنا حقيقية؟...

464
00:28:46,949 --> 00:28:49,755
قتلني ذلك المخلوق
 الذي على الرافعة

465
00:28:50,754 --> 00:28:53,560
لكن الآن... أنا هنا معك

466
00:28:55,320 --> 00:28:57,280
لا أفهم

467
00:28:58,638 --> 00:29:00,238
لا، ولا أنا

468
00:29:00,938 --> 00:29:02,480
لمَ تتصرف بغرابة معي؟

469
00:29:03,532 --> 00:29:05,039
لأن هذا مستحيل

470
00:29:05,580 --> 00:29:06,719
أعلم

471
00:29:07,260 --> 00:29:08,599
لكنني هنا يا حبيبي

472
00:29:08,600 --> 00:29:09,780
وأنا حقيقية

473
00:29:11,380 --> 00:29:12,820
..."إذا كنتِ "غريس

474
00:29:13,319 --> 00:29:15,439
أخبريني بكل شيء...
عن هذه القلادة

475
00:29:16,560 --> 00:29:18,000
إنها لي

476
00:29:19,040 --> 00:29:21,879
أعطيتني إياها قبل عيدين

477
00:29:22,631 --> 00:29:25,160
وفي نفس السنة، أهداني
ريان" قلادة ضفدع أخرى"

478
00:29:26,440 --> 00:29:28,240
لأنني أحب الضفادع

479
00:29:29,040 --> 00:29:31,800
ولم تتحققا من بعضكما
قبل أن تذهبا للتسوق

480
00:29:33,043 --> 00:29:37,479
وأنت ترتديها... كي تبقيني قربك

481
00:29:37,913 --> 00:29:39,483
هذا ليس عدلاً

482
00:29:42,585 --> 00:29:44,192
لا بد بأنها خدعة

483
00:29:44,193 --> 00:29:47,073
لا يمكن أن تكوني هي

484
00:29:48,078 --> 00:29:49,573
أشعر بأنني أنا

485
00:29:52,440 --> 00:29:54,639
يستحيل أن تكون "غريس"، أهذا ممكن؟

486
00:29:54,640 --> 00:29:55,842
لا

487
00:29:56,469 --> 00:29:58,199
"ولا يمكن أن تكوني زوجة "إيريك

488
00:29:58,200 --> 00:29:59,403
أعلم

489
00:30:00,117 --> 00:30:02,520
لكننا كذلك، صحيح؟

490
00:30:06,160 --> 00:30:07,959
حسناً، لا داعي للهلع

491
00:30:08,525 --> 00:30:11,293
لم أهلع -
أعلم، كنت أحدث نفسي -

492
00:30:11,294 --> 00:30:14,240
لأن كل هذا... خاطئ تماماً

493
00:30:14,740 --> 00:30:16,579
صحيح، ما الذي نعرفه؟

494
00:30:16,580 --> 00:30:21,039
هذه المرآة بوابة بين عالمين

495
00:30:21,040 --> 00:30:25,879
دخلنا إليها من العالم الحقيقي
وخرجنا منها إلى هذا العالم

496
00:30:25,880 --> 00:30:27,860
لكن تلك المنطقة المضادة
موجودة في الوسط

497
00:30:27,861 --> 00:30:29,519
تقسم البوابة لقسمين

498
00:30:29,520 --> 00:30:31,439
منطقة للفصل بين عالمين

499
00:30:31,440 --> 00:30:32,559
بالضبط

500
00:30:32,560 --> 00:30:35,799
لأن المنطقة المضادة لا توجد
إلا حين يتعرض نسيج الكون

501
00:30:35,800 --> 00:30:38,839
لتهديد هائل وعظيم

502
00:30:40,400 --> 00:30:42,359
... وهذا يعني

503
00:30:42,360 --> 00:30:46,073
بأنها موجودة لتمنع هذا العالم...

504
00:30:46,074 --> 00:30:48,650
وعالمكِ، من أن يتلامسا

505
00:30:49,618 --> 00:30:52,439
لحظة، لكن هذا يعني
بأن هذا العالم خطير

506
00:30:52,440 --> 00:30:54,159
لكن كيف يكون خطيراً؟

507
00:30:54,160 --> 00:30:57,559
أيضاً، ما الذي يملك القوة
لأن يصنع نسخة كهذه؟

508
00:30:57,560 --> 00:30:59,085
... إلا لو

509
00:30:59,086 --> 00:31:02,273
هذا مستحيل

510
00:31:02,274 --> 00:31:03,959
ما المستحيل؟

511
00:31:03,960 --> 00:31:05,769
أخبرتكِ عن السوليتراكت، صحيح؟

512
00:31:05,770 --> 00:31:07,359
حرفيّاً لم أسمع بهذه الكلمة من قبل

513
00:31:07,360 --> 00:31:08,559
السوليتراكت؟

514
00:31:08,560 --> 00:31:11,559
السوليتراكت، عبارة عن نظرية
أو أسطورة

515
00:31:11,560 --> 00:31:14,218
قصة قبل النوم، كانت تحكيها لي جدتي

516
00:31:14,219 --> 00:31:15,319
أكانت لديكِ جدة؟

517
00:31:15,320 --> 00:31:17,159
كان لدي سبعة، لكن الجدة الخامسة
 هي المفضلة لدي

518
00:31:17,160 --> 00:31:19,040
كانت تخبرني عن السوليتراكت

519
00:31:21,080 --> 00:31:24,679
لأنه في البداية، قبل الزمن وقبل كل شيء

520
00:31:24,680 --> 00:31:26,799
كانت كل القوانين والمواد

521
00:31:26,800 --> 00:31:29,999
والعناصر الأساسية للكون، موجودة

522
00:31:30,000 --> 00:31:33,799
الضوء والمادة والرياضيات وغيرها

523
00:31:33,800 --> 00:31:36,039
لكن لم تتناسق معاً بالشكل المطلوب

524
00:31:36,040 --> 00:31:37,999
بسبب وجود السوليتراكت

525
00:31:38,685 --> 00:31:40,039
ما هو السوليتراكت إذن؟

526
00:31:40,040 --> 00:31:42,399
وعي، طاقة

527
00:31:42,400 --> 00:31:45,639
لا يمكن لواقعنا أن يعمل
بوجود طاقة السوليتراكت

528
00:31:45,640 --> 00:31:49,640
ستفسَد أبسط الأفكار في الكون

529
00:31:50,680 --> 00:31:54,559
فكري بها كما لو كانت طفلة
مصابة بالحصبة، حصبة نووية

530
00:31:54,560 --> 00:31:58,279
تريد أن تنضم للآخرين
لكنها تصيب البقية بالمرض

531
00:31:58,280 --> 00:32:02,429
لا يمكن لكوننا العمل
بوجود السوليتراكت داخله

532
00:32:02,430 --> 00:32:04,759
حكت لكِ جدتكِ هذا قبل النوم؟

533
00:32:04,760 --> 00:32:06,298
فقط حين يجافيني النوم

534
00:32:06,299 --> 00:32:08,560
ما الذي فعله كوننا إذن؟

535
00:32:09,480 --> 00:32:13,720
إستطاع أن ينفي السوليتراكت

536
00:32:13,721 --> 00:32:16,360
لوجود منفصل لا يمكن وصوله

537
00:32:17,183 --> 00:32:18,959
مستوى السوليتراكت

538
00:32:18,960 --> 00:32:22,719
وفجأة، أصبح كل شيء مفهوم

539
00:32:22,720 --> 00:32:24,999
تمكن الكون من النجاح

540
00:32:25,000 --> 00:32:27,439
لأنه تمت إزالة السوليتراكت

541
00:32:27,440 --> 00:32:31,159
لحظة، أتقولين بأننا الآن
داخل مستوى السوليتراكت؟

542
00:32:31,160 --> 00:32:32,679
أتمنى لو لم يكن كذلك
 لكن هذا ما أظنه

543
00:32:32,680 --> 00:32:35,089
أنا خائفة، فهل أنتِ خائفة؟

544
00:32:35,090 --> 00:32:36,955
أنا مرعوبة بحق

545
00:32:36,956 --> 00:32:40,279
هذا كون منبوذ منفصل
ووعيّ في الوقت ذاته؟

546
00:32:40,280 --> 00:32:41,919
هذا ما كانت تقوله جدتي الخامسة

547
00:32:41,920 --> 00:32:44,159
كون واعي

548
00:32:44,160 --> 00:32:46,919
لكنها قالت أيضاً بأن جدتي الثانية
كانت عميلة سرية للزايغون

549
00:32:46,920 --> 00:32:49,119
لكن بدت متأكدة من هذه المعلومة

550
00:32:49,120 --> 00:32:50,679
لكن لماذا؟

551
00:32:50,680 --> 00:32:53,394
لمَ نسخت السوليتراكت عالمكِ؟

552
00:32:53,395 --> 00:32:55,768
"متضمناً "غريس" و "ترينا

553
00:32:55,769 --> 00:32:57,840
... وبنت بوابة

554
00:32:58,986 --> 00:33:00,506
لعالمنا؟...

555
00:33:01,238 --> 00:33:05,040
حين تقولينه بهذا الشكل
يبدو وكأنه... فخ

556
00:33:08,371 --> 00:33:10,439
ما الذي تفعله في النرويج؟

557
00:33:10,440 --> 00:33:11,622
إنها سفينة الدكتور

558
00:33:11,623 --> 00:33:13,096
"كنتِ ستحبينها يا "غريس

559
00:33:13,097 --> 00:33:15,119
إنها كبينة شرطة قديمة

560
00:33:15,120 --> 00:33:17,599
لكنها من الداخل
مركبة فضاء ضخمة

561
00:33:17,600 --> 00:33:19,531
تذهب إلى أي مكان وزمن

562
00:33:19,532 --> 00:33:21,079
كانت تخبرنا بالحقيقة
تلك الليلة إذن؟

563
00:33:21,080 --> 00:33:23,719
تذكرين كل شيء، صحيح؟ -
بالطبع أذكر كل شيء -

564
00:33:23,720 --> 00:33:24,779
صحيح

565
00:33:25,400 --> 00:33:28,820
ذهبت لكوكب فضائي يا "غريس"، أنا

566
00:33:29,800 --> 00:33:31,879
"وقابلت "روزا باركس

567
00:33:32,317 --> 00:33:33,884
روزا باركس"؟" -
أعلم -

568
00:33:36,112 --> 00:33:38,232
يبدو بأنك بأفضل حال بدوني

569
00:33:39,511 --> 00:33:40,879
"أنا تائه يا "غريس

570
00:33:41,397 --> 00:33:42,680
أفتقدكِ

571
00:33:43,160 --> 00:33:46,039
كنت أبحث عنكِ طوال حياتي
وحين وجدتكِ

572
00:33:46,040 --> 00:33:48,780
كنت... سعيداً جداً

573
00:33:49,400 --> 00:33:51,120
وأنا كذلك

574
00:33:53,726 --> 00:33:55,060
ثم فقدتكِ

575
00:33:55,600 --> 00:33:56,879
أنا هنا

576
00:33:56,880 --> 00:33:58,600
أفتقدكِ كثيراً

577
00:33:59,999 --> 00:34:01,751
"أفتقدكِ كثيراً يا "غريس

578
00:34:01,752 --> 00:34:04,119
غراهام"، سنغادر الآن"

579
00:34:04,120 --> 00:34:06,418
حسناً، نعم
"هيّا يا "غريس

580
00:34:06,419 --> 00:34:08,479
صحيح، آسفة لصراحتي
"مرحباً يا "غريس

581
00:34:08,480 --> 00:34:10,479
"هذه ليست "غريس
"لا أقصد الإساءة يا "غريس

582
00:34:10,480 --> 00:34:11,757
لا عليكِ يا حبيبتي

583
00:34:11,758 --> 00:34:13,719
"لا يمكنها مرافقتنا يا "غراهام
ليست حقيقية

584
00:34:13,720 --> 00:34:15,719
أظنكِ مخطئة -
لست مخطئة -

585
00:34:15,720 --> 00:34:18,118
إنها تذكر كل شيء -
أعلم بأن هذا صعباً -

586
00:34:18,119 --> 00:34:20,359
أعني، بعد كل الأشياء المجنونة
 التي رأيتيها يا دكتور

587
00:34:20,360 --> 00:34:22,384
لا يمكنكِ إخباري بأنكِ
تعرفين بأنها ليست هي

588
00:34:22,385 --> 00:34:25,341
هذا كله مجرد حيلة
ولا أظن "غريس" تعلم ذلك

589
00:34:25,342 --> 00:34:29,109
أظن هذا العالم بأكمله فخ
وهي جزء منه

590
00:34:29,110 --> 00:34:33,631
إسمعني، إما هي أو العالم الحقيقي
لا يمكن أن تحصل على الإثنين

591
00:34:33,632 --> 00:34:36,000
أدخل أرجوك، سنذهب

592
00:34:40,164 --> 00:34:43,460
أحتاج لأن أفتح هذه وأخرج
غراهام" و"إيريك" من هنا"

593
00:34:44,240 --> 00:34:48,879
لن تتزحزح، لا بد بأن
السوليتراكت تتحكم بها

594
00:34:48,880 --> 00:34:50,901
ولا يمكنني إجبارها بالمفك
كما فعلت سابقاً

595
00:34:50,902 --> 00:34:53,239
لأنها ذكيّة وتكيّفت معه

596
00:34:53,240 --> 00:34:55,751
ماذا لو فعلتِ شيئاً
لم تره من قبل

597
00:34:55,752 --> 00:34:58,633
كأن تعكسي القطبية أو ما شابه؟

598
00:34:59,402 --> 00:35:02,119
"ياسمين خان"
أنتِ تتحدثين لغتي

599
00:35:02,120 --> 00:35:04,159
"إستمري بالركض يا "هانا

600
00:35:04,160 --> 00:35:06,399
!إلى هنا! إلى هنا

601
00:35:06,400 --> 00:35:07,920
إنخفضي، إنخفضي

602
00:35:13,816 --> 00:35:16,342
أظننا مستعدون الآن -
عمل جيّد يا دكتور -

603
00:35:16,343 --> 00:35:17,839
شكراً لكِ، أبذل جهدي

604
00:35:17,840 --> 00:35:20,239
غراهام" و "إيريك"، حان الوقت"

605
00:35:20,240 --> 00:35:22,278
هيّا -
"غراهام" -

606
00:35:22,279 --> 00:35:24,031
سمعت ما قالته الدكتور

607
00:35:24,032 --> 00:35:26,079
"هيّا يا "غريس -
لست متأكدة -

608
00:35:26,080 --> 00:35:28,039
لا يمكنني أن أبقيها مفتوحة مدة أطول

609
00:35:28,040 --> 00:35:31,080
غراهام" و"ياز" و"إيريك"، الآن أرجوكم"

610
00:35:33,760 --> 00:35:35,160
أركضي

611
00:35:39,240 --> 00:35:42,040
يوجد بوابة أمامنا مباشرة
سوف أشتت إنتباههم

612
00:35:43,320 --> 00:35:45,640
ما الذي تفعلينه هنا؟ -
هانا"، هذا أنا" -

613
00:35:50,480 --> 00:35:53,799
سمعت أبي -
لا بأس، لا بأس، أنا هنا -

614
00:35:53,800 --> 00:35:56,759
أين نحن؟ وما الذي يحدث؟

615
00:35:56,760 --> 00:35:59,559
تكيّفت البوابة ثانية
لا يمكنني فتحها

616
00:36:00,129 --> 00:36:01,799
لديّ مفاجأة لكِ

617
00:36:01,800 --> 00:36:03,286
"إنها أمكِ يا "هانا

618
00:36:04,046 --> 00:36:06,279
إنها حيّة -
ماذا؟ -

619
00:36:06,280 --> 00:36:07,751
"هانا"

620
00:36:09,200 --> 00:36:11,805
إبنتي الجميلة

621
00:36:13,720 --> 00:36:17,399
لا أعرف من تكونين
لكنكِ لست أمي

622
00:36:17,400 --> 00:36:19,348
ريان"؟"

623
00:36:19,349 --> 00:36:22,166
ريان"؟" -
ريان" ليس هنا" -

624
00:36:22,167 --> 00:36:25,333
لحظة -
هل كان معكِ في المنطقة المضادة؟ -

625
00:36:25,334 --> 00:36:27,399
لا يزال هناك مع تلك الأشياء

626
00:36:27,400 --> 00:36:29,839
أُغلقت البوابة ولا يزال "ريان" هناك

627
00:36:29,840 --> 00:36:31,999
إفتحيها إذن، يجب أن نساعده

628
00:36:32,000 --> 00:36:33,839
لا -
ما الذي تعنينه بـ لا؟ -

629
00:36:35,760 --> 00:36:38,639
هذا العالم يتداعى
لوجودنا داخله حتى الآن

630
00:36:38,640 --> 00:36:41,679
لا نزال نحن وأنتِ غير متوافقين

631
00:36:41,680 --> 00:36:45,070
وجود "إيريك" هنا كان ممكناً
لكن خمسة منا؟

632
00:36:45,071 --> 00:36:47,361
هذه مواد كثيرة غير متوافقة

633
00:36:47,362 --> 00:36:49,079
تتجاوز تحملكِ

634
00:36:49,080 --> 00:36:51,297
يجب أن تدعينا نذهب الآن

635
00:36:51,298 --> 00:36:54,199
هل أنا فقط من ترى أن
 هذه المرأة مجنونة تماماً؟

636
00:36:54,200 --> 00:36:56,397
ليست "غريس" و "ترينا" من تفعلان هذا

637
00:36:56,398 --> 00:36:58,157
بالطبع هما

638
00:36:58,158 --> 00:37:00,559
إنهما مصنوعتان من طاقة السوليتراكت

639
00:37:00,560 --> 00:37:03,119
وتستطيع "هانا" الإحساس بها
فلمَ تعجزان أنتما؟

640
00:37:03,120 --> 00:37:04,839
لماذا؟

641
00:37:04,840 --> 00:37:06,600
لمَ صنعتِ كل هذا؟

642
00:37:12,880 --> 00:37:15,880
يالغبائي، بالطبع

643
00:37:16,866 --> 00:37:21,919
أردتِ ما أردتِه دائماً
أن تكوني معنا

644
00:37:23,000 --> 00:37:25,159
لذا بنيتِ عالماً ظننته سيعجبنا

645
00:37:25,160 --> 00:37:28,663
وأخذتِ أشكالاً لن نصدها

646
00:37:28,664 --> 00:37:30,709
لا تستمع إليها يا حبيبي

647
00:37:30,710 --> 00:37:33,506
لا تستغلي عاطفته
"لستِ "غريس

648
00:37:33,507 --> 00:37:37,039
كانت "غريس" الحقيقية
جميلة ومبتسمة دائماً

649
00:37:37,040 --> 00:37:40,078
وهل تعرفين كيف كانت فوق كل هذا؟
كانت شجاعة

650
00:37:40,079 --> 00:37:42,080
وكانت ستتقدمنا عبر تلك المرآة

651
00:37:43,400 --> 00:37:44,679
"ياز"

652
00:37:48,320 --> 00:37:50,943
"ريان"

653
00:37:53,800 --> 00:37:55,933
هل فعلت أنا هذا؟

654
00:37:55,934 --> 00:37:57,847
أظنكِ تعرفين

655
00:37:58,560 --> 00:38:00,637
أريد العودة للمنزل

656
00:38:00,638 --> 00:38:02,911
هانا"، لا تخافي"

657
00:38:02,912 --> 00:38:04,919
إيريك"، طمئنها"

658
00:38:04,920 --> 00:38:09,328
هانا"، نحن في مكان قريب من المنزل"

659
00:38:09,329 --> 00:38:12,959
يمكننا البقاء هنا
لم أكن لأطلب منكِ البقاء لو لم يكن آمناً

660
00:38:13,672 --> 00:38:15,272
بلى ستفعل يا أبي

661
00:38:15,872 --> 00:38:17,220
لست بخير

662
00:38:17,720 --> 00:38:19,920
لم تكن بخير منذ ماتت أمي

663
00:38:21,120 --> 00:38:23,084
وأنتِ لستِ أمي

664
00:38:23,085 --> 00:38:25,239
أيّاً كنتِ، أنا أكرهكِ

665
00:38:25,240 --> 00:38:26,680
والآن، أخرجيني

666
00:38:30,320 --> 00:38:32,439
"غراهام"

667
00:38:32,440 --> 00:38:35,181
أرتنا "ياز" و "هانا" الطريق

668
00:38:35,182 --> 00:38:39,285
ريان" هناك في خطر"
وسينهار هذا المكان

669
00:38:39,801 --> 00:38:42,039
...دكتور، أعرف ما تطلبينه مني، لكن

670
00:38:42,040 --> 00:38:43,199
لا يمكنني أن أفعلها

671
00:38:45,440 --> 00:38:49,239
ليست زوجتك، إنها أثاث بنبض

672
00:38:49,240 --> 00:38:51,919
لا تعرف ولا يمكنها أن تعرف

673
00:38:51,920 --> 00:38:53,999
غراهام" أرجوك"

674
00:38:54,000 --> 00:38:55,799
أعرف مدى صعوبة هذا بالنسبة لك

675
00:38:55,800 --> 00:38:59,150
لكن دعها وإلا سنموت جميعاً

676
00:39:00,772 --> 00:39:03,881
أعلم بأنك لا تزال تلوم نفسك
"على ما حدث لـ "غريس

677
00:39:03,882 --> 00:39:05,999
لم تكن غلطتك

678
00:39:06,000 --> 00:39:09,378
صدها أرجوك، لأنك تعرف
"بأنها ليست "غريس

679
00:39:10,080 --> 00:39:11,857
لا تتركني يا حبيبي

680
00:39:11,858 --> 00:39:12,919
ليس ثانية

681
00:39:13,728 --> 00:39:15,199
ماذا عن "ريان"؟

682
00:39:15,625 --> 00:39:17,364
إنه في مشكلة يا حبيبتي

683
00:39:17,365 --> 00:39:20,366
سيكون بخير، إنه فتى ذكي

684
00:39:23,000 --> 00:39:25,159
"هذا الواقع ينهار يا "غراهام

685
00:39:25,160 --> 00:39:26,680
إقتربتِ

686
00:39:28,100 --> 00:39:29,540
كنتِ قريبةً جداً

687
00:39:31,480 --> 00:39:32,719
...كما ترين

688
00:39:32,720 --> 00:39:34,919
ما كانت "غريس" لتسمح...
لي بأن أعرّض "ريان" للخطر

689
00:39:39,280 --> 00:39:40,600
أنتِ مزيفة

690
00:39:42,600 --> 00:39:44,000
أتمنى لو كنتِ هي، لكنكِ مزيفة

691
00:39:51,400 --> 00:39:52,594
"غريس"

692
00:39:52,595 --> 00:39:54,159
ما الذي حدث لها؟

693
00:39:54,160 --> 00:39:56,840
زائدة عن الحاجة
هل تصدقني الآن؟

694
00:39:58,001 --> 00:39:59,319
"إيريك"

695
00:39:59,320 --> 00:40:02,719
واضح أن هذه المرأة طاقة
 فضائية ستدمر العالمين

696
00:40:02,720 --> 00:40:04,848
وتنتحل هوية زوجتك المتوفية

697
00:40:04,849 --> 00:40:07,039
حان الوقت لتركها يا صاح -
لكن لا أستطيع -

698
00:40:08,400 --> 00:40:10,906
لا، بالطبع لن تستطيع

699
00:40:11,620 --> 00:40:13,140
حسناً

700
00:40:14,231 --> 00:40:16,350
تهانينا

701
00:40:16,351 --> 00:40:17,912
"يريدكِ "إيريك

702
00:40:19,160 --> 00:40:21,799
لكن أمر أخير
هذا العالم يتداعى

703
00:40:22,311 --> 00:40:23,838
ولا أظنكِ تستطيعي الإبقاء
على أكثر من شخص

704
00:40:23,839 --> 00:40:25,720
فهل متأكدة بأنه خياركِ الأفضل؟

705
00:40:29,000 --> 00:40:30,700
لأن السوليتراكت لا تحتاج زوجاً

706
00:40:31,239 --> 00:40:33,540
بل تريدين كوناً بأكمله

707
00:40:34,309 --> 00:40:37,359
شخص رأى كل شيء
وأنا ذلك الشخص

708
00:40:37,360 --> 00:40:41,679
عشت مدة أطول، ورأيت أكثر
وأحببت أكثر، وفقدت أكثر

709
00:40:42,040 --> 00:40:44,112
يمكنني أن أشارككِ كل هذا

710
00:40:44,113 --> 00:40:46,687
وأي شيء تريدين معرفته
عن أي شيء لم تملكيه

711
00:40:47,960 --> 00:40:51,479
لأنه أحمق لديه إبنة تحتاجه
... لذا دعيه يذهب

712
00:40:51,480 --> 00:40:53,360
وسأعطيكِ كل شيء...

713
00:40:57,760 --> 00:40:59,039
"لستِ "ترينا

714
00:40:59,040 --> 00:41:00,500
"أخيراً يا "إيريك

715
00:41:04,757 --> 00:41:08,228
يمكنكِ أن تكفّي عن تجسيد "ترينا" الآن
لأن هذا الكون في حالة حرجة

716
00:41:08,229 --> 00:41:12,600
وإذا إنفجر فسيأخذ المنطقة
 المضادة وكوني معه أيضاً

717
00:41:46,200 --> 00:41:49,520
لمَ يوجد ضفدع هنا؟

718
00:41:51,400 --> 00:41:53,880
"قلتِ بأن أكف عن تجسيد "ترينا

719
00:41:55,000 --> 00:41:57,080
... السوليتراكت ضفدع

720
00:41:58,000 --> 00:42:00,053
يتحدث بصوت "غريس"؟...

721
00:42:00,054 --> 00:42:02,406
شكلي الحقيقيّ لا نهائي

722
00:42:02,407 --> 00:42:05,247
لكن شكل هذا الضفدع يعجبني

723
00:42:05,248 --> 00:42:07,662
كما أعجب "غريس" سابقاً

724
00:42:07,663 --> 00:42:11,279
وكنت أفكر بأنه لم يبق
مفاجآت في هذا اليوم

725
00:42:11,280 --> 00:42:14,858
والآن، أخبريني أرجوكِ عن كونكِ

726
00:42:14,859 --> 00:42:16,879
أتظنين الكلمات ستوفيه حقه؟

727
00:42:16,880 --> 00:42:18,320
... إنه هائل جداً

728
00:42:20,356 --> 00:42:22,484
وجميل جداً...

729
00:42:23,213 --> 00:42:26,576
ويبدو بأنني لتوي ودعته

730
00:42:27,440 --> 00:42:30,288
لكن الناس ما سوف أفتقده حقاً

731
00:42:30,880 --> 00:42:34,119
أصدقائي -
سأكون هنا، وسنكون هنا معاً -

732
00:42:34,120 --> 00:42:35,881
أصدقاء -
صحيح -

733
00:42:35,882 --> 00:42:39,399
أنا والكون الواعي المتنكر كضفدع
أعز أصدقاء للأبد

734
00:42:39,778 --> 00:42:42,599
هل رأيتِ هذا؟

735
00:42:43,346 --> 00:42:44,839
لأنني لن أكون صديقة حقيقية لكِ

736
00:42:44,840 --> 00:42:46,836
لو لم أنبهكِ إلى عجزكِ
عن السيطرة على هذا

737
00:42:46,837 --> 00:42:50,479
أنتِ مخطئة، هذا مستواي
وأنا أتحكم بكل شيء هنا

738
00:42:50,480 --> 00:42:53,334
يمكنكِ أن تري إذن
بأنه لا زال يتذبذب

739
00:42:53,821 --> 00:42:56,319
وجودي هنا سيقتلنا معاً

740
00:42:56,320 --> 00:42:59,599
قد ترغبين بتواجدنا معاً
لكن لن ينفع هذا

741
00:42:59,600 --> 00:43:01,439
لن ينفع أبداً

742
00:43:01,440 --> 00:43:03,959
أنتِ تكذبين عليّ
لأنكِ تريدين المغادرة

743
00:43:04,503 --> 00:43:06,796
لا، أنا صديقتكِ

744
00:43:07,440 --> 00:43:09,479
لكن الأصدقاء يساعدون بعضهم
ليواجهوا مشاكلهم

745
00:43:09,480 --> 00:43:10,672
لا أن يتجاهلوها

746
00:43:11,466 --> 00:43:13,319
...وهذا

747
00:43:13,320 --> 00:43:16,719
وأنتِ... أشد

748
00:43:17,272 --> 00:43:22,319
الأشياء التي إختبرتها جمالاً

749
00:43:22,320 --> 00:43:25,049
ولم أرَ منكِ شيئاً بعد

750
00:43:26,546 --> 00:43:28,266
أتمنى لو كان بإستطاعتي البقاء

751
00:43:30,033 --> 00:43:32,382
لكن إذا كنا سننجو

752
00:43:32,383 --> 00:43:33,659
فينبغي أن تتركيني أذهب

753
00:43:33,660 --> 00:43:36,586
وتستمري بالعيش وحدكِ، مذهلة كما أنتِ

754
00:43:39,640 --> 00:43:41,440
أفتقدكم

755
00:43:43,200 --> 00:43:46,084
أفتقد كل شيء، كثيراً

756
00:43:46,085 --> 00:43:47,526
أعلم

757
00:43:48,819 --> 00:43:52,328
لكن لو فعلتِ هذا، فأعدكِ

758
00:43:52,329 --> 00:43:56,160
سنبقى صديقتين للأبد

759
00:43:57,226 --> 00:43:58,880
يجب أن تدعيني أذهب

760
00:44:03,120 --> 00:44:04,879
سأحلم بكِ

761
00:44:04,880 --> 00:44:07,200
هناك، دوني

762
00:44:13,600 --> 00:44:14,920
وداعاً

763
00:44:29,760 --> 00:44:34,079
رماني ضفدع، مذهل

764
00:44:40,520 --> 00:44:44,439
صخور مشتعلة، لن أعود إلى هنا ثانية

765
00:44:44,440 --> 00:44:46,659
"غراهام"

766
00:44:46,660 --> 00:44:48,747
أنت بأمان، أمسكت بك

767
00:44:49,240 --> 00:44:50,513
"غراهام"

768
00:44:54,080 --> 00:44:56,320
المكان بأكمله يتفكك

769
00:44:56,321 --> 00:44:58,342
إستمروا بالتقدم، هناك البوابة

770
00:44:58,343 --> 00:45:01,600
ماذا عن الدكتور؟
أين الدكتور؟

771
00:45:02,800 --> 00:45:04,640
قادمة

772
00:45:25,551 --> 00:45:26,919
هل نحن بأمان؟

773
00:45:27,559 --> 00:45:30,216
من السوليتراكت، نعم

774
00:45:31,073 --> 00:45:32,593
...لا أعلم ما إذا نجت

775
00:45:33,760 --> 00:45:35,524
لكنها لن تعود إلى هنا...

776
00:45:36,480 --> 00:45:37,743
مؤسف

777
00:45:38,360 --> 00:45:39,840
كونت صداقة جديدة

778
00:45:40,506 --> 00:45:42,346
كون واعي بأكمله

779
00:45:43,533 --> 00:45:45,137
وكان عليّ توديعه

780
00:46:16,782 --> 00:46:19,999
ما الذي تنويانه؟ -
حان الوقت لنعود -

781
00:46:20,000 --> 00:46:22,320
ليس في صالحنا البقاء هنا

782
00:46:24,289 --> 00:46:25,592
إلى أوسلو؟

783
00:46:26,186 --> 00:46:27,406
أوسلو، نعم

784
00:46:28,024 --> 00:46:31,919
إلى شقتنا والإنترنت والأصدقاء

785
00:46:32,659 --> 00:46:33,659
شكراً لكم

786
00:46:34,450 --> 00:46:35,450
في أي وقت

787
00:46:36,093 --> 00:46:37,093
وداعاً

788
00:46:37,706 --> 00:46:38,706
"وداعاً يا "هانا

789
00:46:47,847 --> 00:46:49,447
"هيّا يا "غراهام

790
00:46:54,213 --> 00:46:56,413
إنه فيورد جميل جداً

791
00:47:05,303 --> 00:47:07,012
أرى أن الخراف قد ذهبت

792
00:47:07,013 --> 00:47:09,244
الأرجح أنها تخطط
هيّا بنا

793
00:47:24,966 --> 00:47:26,366
هل أنت بخير؟

794
00:47:27,753 --> 00:47:29,275
بخير

795
00:47:29,276 --> 00:47:31,260
قالت "ياز" بأنك رأيت جدتي هناك

796
00:47:33,067 --> 00:47:36,187
...صحيح، ظننتها... ربما

797
00:47:38,080 --> 00:47:40,192
لكن لم تكن هي، ليس حقاً

798
00:47:41,119 --> 00:47:42,415
كانت هي

799
00:47:44,713 --> 00:47:45,953
صحيح

800
00:47:48,266 --> 00:47:50,986
أفتقدها أيضاً، طوال الوقت

801
00:47:55,500 --> 00:47:57,540
لكن لدينا بعضنا على الأقل، صحيح؟

802
00:47:58,760 --> 00:48:00,160
يا جدّي

803
00:48:03,280 --> 00:48:04,919
بمَ ناديتني؟

804
00:48:04,920 --> 00:48:07,239
لماذا؟ هل أصابك الصمم بعد أن شبت؟

805
00:48:07,743 --> 00:48:09,160
هيّا، إلى التاردس

806
00:49:04,142 --> 00:49:07,220
تسع إشارات إستغاثة
أتت من نفس الكوكب

807
00:49:07,221 --> 00:49:09,358
كان ينبغي أن أغادر -
ولمَ لم تفعل؟ -

808
00:49:09,359 --> 00:49:10,620
المعركة

809
00:49:10,621 --> 00:49:13,720
أعطيتني قدري

