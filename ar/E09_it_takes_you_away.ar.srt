1
00:00:08,859 --> 00:00:21,859
Translated by .. MadNess
تـرجمـة .. إبتـهـال

2
00:00:39,996 --> 00:00:42,699
فيورد جميل

3
00:00:43,600 --> 00:00:45,180
هذا فيورد، أليس كذلك؟

4
00:00:46,500 --> 00:00:48,180
هل عرفتِ مكاننا بعد يا دكتور؟

5
00:00:49,859 --> 00:00:52,378
النرويج، لا شك بأنها النرويج

6
00:00:52,379 --> 00:00:54,419
واحدة من تلك الأجزاء الشمالية

7
00:00:54,420 --> 00:00:56,100
تراجعوا

8
00:01:01,060 --> 00:01:04,328
لا بأس، نحن في 2018

9
00:01:04,329 --> 00:01:06,539
ظننتنا إنتقلنا لإحدى الثورات الصوفية

10
00:01:06,540 --> 00:01:09,304
المعذرة، ماذا؟ -
الثورات الصوفية -

11
00:01:09,305 --> 00:01:11,139
بعد 193 سنة

12
00:01:11,140 --> 00:01:14,367
تتم إعادة المفاوضات حول
 علاقة البشر بالخراف

13
00:01:14,368 --> 00:01:16,060
مجزرة رهيبة

14
00:01:16,061 --> 00:01:18,159
لطالما أحببت فكرة النرويج

15
00:01:18,820 --> 00:01:21,360
أي جزء منها هذا؟ -
لا أدري -

16
00:01:23,540 --> 00:01:25,939
لكن على بعد 25 ميل
... توجد مزرعة ألباكا

17
00:01:25,940 --> 00:01:27,459
...ومتجر هدايا

18
00:01:27,460 --> 00:01:29,539
تقييمه سيء في
TripAdvisor

19
00:01:29,540 --> 00:01:32,363
تراب؟ -
لا، شكراً -

20
00:01:32,364 --> 00:01:34,163
يوجد منزل صغير هناك على القمة

21
00:01:34,164 --> 00:01:35,645
صحيح

22
00:01:38,180 --> 00:01:40,739
كوخ في النرويج وفي الشتاء

23
00:01:40,740 --> 00:01:42,903
بمدخنة، لكن دون دخان

24
00:01:42,904 --> 00:01:44,360
قد يكون من أكواخ العطلات

25
00:01:45,060 --> 00:01:47,080
ربما، هل نذهب في نزهة؟

26
00:01:47,859 --> 00:01:50,939
تحدثنا أنا وجدتك
عن زيارة النرويج

27
00:01:50,940 --> 00:01:52,279
وما الذي منعكما؟

28
00:01:52,280 --> 00:01:54,380
لم نفعلها فحسب

29
00:01:59,460 --> 00:02:00,609
أنظروا لهذا

30
00:02:00,610 --> 00:02:03,204
"تحمس أحدهم بتطبيق "إصنعها بنفسك

31
00:02:03,205 --> 00:02:06,346
تبدو هذه الألواح أقرب
للتحصين منها إصلاحات

32
00:02:07,399 --> 00:02:09,519
يبدو وكأنه مهجور

33
00:02:11,020 --> 00:02:13,620
هل رأيتم هذا؟
يوجد أحد بالداخل

34
00:02:25,640 --> 00:02:27,446
هل من أحد هنا؟

35
00:02:31,020 --> 00:02:32,700
نظرة سريعة؟ كي نطمئن؟

36
00:02:51,477 --> 00:02:54,580
ثلاثة أقفال في منزل مهجور
وفي مكان معزول

37
00:02:57,540 --> 00:02:59,100
قد يكون من الأفضل أن لا ندخله

38
00:02:59,820 --> 00:03:01,500
يوجد طفل في هذا المنزل

39
00:03:02,940 --> 00:03:05,500
أو مهووس بجمع أحذية الأطفال

40
00:03:10,520 --> 00:03:12,719
أنتما الإثنان، تفقدا الأعلى

41
00:03:12,720 --> 00:03:14,001
هيّا

42
00:03:35,320 --> 00:03:37,939
ريان"، إنها أغلفة حلوى"

43
00:03:50,400 --> 00:03:53,320
لا بأس، لا عليكِ، أنا آسف
لم نقصد إخافتكِ

44
00:03:56,460 --> 00:03:58,499
مرحباً، نريد مساعدتكِ

45
00:03:58,500 --> 00:03:59,899
ما اسمكِ؟

46
00:03:59,900 --> 00:04:01,219
هل أنتِ جائعة؟

47
00:04:01,220 --> 00:04:04,348
لأنني أصبحت أحمل معي
شطيرة جبن ومخلل

48
00:04:04,349 --> 00:04:06,060
لحالات الطوارئ

49
00:04:07,475 --> 00:04:10,259
أتأخذ معك شطيرة في
كل مرة تغادر فيها التاردس؟

50
00:04:10,260 --> 00:04:12,059
نعم، لأن التجارب علمتني، صحيح؟

51
00:04:12,060 --> 00:04:14,379
يمكن أن يمر وقت طويل
قبل أن يتاح لنا أن نأكل

52
00:04:14,380 --> 00:04:16,859
ويتعكر مزاجي إذا إنخفضت
مستويات السكر في دمي

53
00:04:16,860 --> 00:04:19,579
والآن .. أخرج مستعداً

54
00:04:20,060 --> 00:04:23,220
من أنتم، وكيف دخلتم إلى منزلنا؟

55
00:04:24,675 --> 00:04:28,154
"أنا الدكتور، وهؤلاء "ياز
"و "ريان" و "غراهام

56
00:04:28,155 --> 00:04:29,167
كنا نتنزه

57
00:04:29,168 --> 00:04:31,259
لكن قلقنا بشأن إحتمال
وجود مشكلة هنا

58
00:04:31,666 --> 00:04:34,666
حين قلتِ "منزلنا"، من يعيش معكِ؟

59
00:04:36,973 --> 00:04:40,220
إذا لم تمانعي السؤال
ما الذي أخافكِ هكذا؟

60
00:04:42,820 --> 00:04:44,300
الشيء

61
00:04:48,620 --> 00:04:50,340
أي شيء يا حبيبتي؟

62
00:04:51,686 --> 00:04:54,218
ذلك الشيء الذي كان
أبي يحمي المنزل منه

63
00:04:54,219 --> 00:04:56,139
دخل إلى هنا وأخذه

64
00:04:56,140 --> 00:04:57,980
ما شكل ذلك الشيء؟

65
00:05:12,767 --> 00:05:14,200
ما اسمكِ؟

66
00:05:15,180 --> 00:05:16,340
"هانا"

67
00:05:17,106 --> 00:05:18,666
هل أنتِ كفيفة يا "هانا"؟

68
00:05:26,040 --> 00:05:28,560
أرجوكم ... ساعدوني لأجد أبي

69
00:05:30,593 --> 00:05:32,832
سمعت الشيء هنا
قبل أن أخلد للنوم

70
00:05:32,833 --> 00:05:35,113
وفي الصباح، إختفى أبي

71
00:05:35,114 --> 00:05:37,060
لا تعلمين ما إذا كان قد دخل المنزل؟

72
00:05:37,860 --> 00:05:40,362
كيف تعلمين بأن أبيكِ
لم يرحل ويترككِ؟

73
00:05:40,363 --> 00:05:42,659
ما كان أبي ليتركني أبداً، حسناً؟

74
00:05:42,660 --> 00:05:44,499
"ريان" -
ماذا؟ -

75
00:05:44,500 --> 00:05:47,100
منذ متى إختفى؟ -
أربعة أيام -

76
00:05:47,900 --> 00:05:49,140
حسناً

77
00:05:51,180 --> 00:05:52,280
أحببت قميصكِ

78
00:05:52,980 --> 00:05:55,899
أنا من شيفيلد، مثل فرقة
"أركتك مونكيز"

79
00:05:55,900 --> 00:05:57,760
حضرت ابنة عمي أول عرض لفرقتهم

80
00:05:58,399 --> 00:06:00,738
وحضرت أمي أول عرض لهم في النرويج

81
00:06:00,739 --> 00:06:02,539
كان هذا القميص لها

82
00:06:02,540 --> 00:06:04,220
أين أمكِ يا "هانا"؟

83
00:06:05,287 --> 00:06:06,326
لقد ماتت

84
00:06:06,955 --> 00:06:09,346
يؤسفني سماع ذلك
لا بد بأنكِ تفتقدينها

85
00:06:09,347 --> 00:06:10,793
طوال الوقت

86
00:06:10,794 --> 00:06:12,379
وكذلك أبي

87
00:06:12,380 --> 00:06:13,499
بالطبع

88
00:06:13,500 --> 00:06:16,499
وأظن بأن ما كان يقصده "ريان" قوله

89
00:06:16,500 --> 00:06:19,259
أن من الواضح أن أبيكِ
لم يرغب بأن يترككِ

90
00:06:19,260 --> 00:06:24,539
لكن ماذا لو ذهب للعمل
أو ماشابه... ثم تاه أو أصيب؟

91
00:06:24,540 --> 00:06:28,434
ترك العمل حين غادرنا أوسلو
ولا يزال المركب هنا

92
00:06:28,435 --> 00:06:30,099
ذهبت إليه لأتحقق

93
00:06:34,060 --> 00:06:35,699
يجب أن ندخل

94
00:06:35,700 --> 00:06:37,374
دائماً ما يأتي في هذا الوقت

95
00:06:37,375 --> 00:06:38,979
نفس الوقت من كل يوم؟

96
00:06:39,419 --> 00:06:40,900
هذا وقت الصيد بالنسبة له

97
00:06:44,901 --> 00:06:46,975
طفلة مسكينة -
لا تصدقون هذا -

98
00:06:46,976 --> 00:06:49,740
تركها أبيها وهرب
وهي تختلق هذا الوحش

99
00:06:49,741 --> 00:06:51,875
لا داعي للإفتراضات

100
00:06:52,333 --> 00:06:54,095
أنتما، ألقيا نظرة على السقيفة

101
00:06:55,113 --> 00:06:56,592
غراهام"، لنتحقق من المنزل" -
حسناً -

102
00:06:56,593 --> 00:06:57,874
لا تطيلا البقاء في الخارج

103
00:07:03,660 --> 00:07:05,340
هل تفتقدين المدينة؟

104
00:07:06,420 --> 00:07:08,099
أحياناً

105
00:07:08,100 --> 00:07:11,047
لكن أراد أبي التغيير
بعد أن ماتت أمي

106
00:07:11,834 --> 00:07:14,052
هل أتى هنا ليهرب من ذكرياته إذن؟

107
00:07:14,053 --> 00:07:17,779
نعم، وكان مهجوراً لسنوات
لذا وجدناه رخيصاً

108
00:07:17,780 --> 00:07:19,948
هل كان أبيكِ من وضع
هذه الألواح والأقفال في كل مكان؟

109
00:07:19,949 --> 00:07:21,619
قبل إختفائه بيوم

110
00:07:21,620 --> 00:07:23,459
قلت له بأنه مجنون

111
00:07:23,460 --> 00:07:25,160
لا يوجد أحد على بعد أميال

112
00:07:25,980 --> 00:07:30,420
لكنه قال "يوجد أشياء
"أسوأ من البشر

113
00:07:42,660 --> 00:07:45,099
ما هذه الرائحة؟

114
00:07:45,100 --> 00:07:46,580
لا أظنني أريد أن أعرف

115
00:07:54,340 --> 00:07:57,059
هل صرخت؟ -
لا تعتبر الطيور الميتة شيئاً طبيعياً -

116
00:07:57,060 --> 00:07:59,380
قد تكون طبيعية في النرويج

117
00:08:01,180 --> 00:08:02,859
تعاملتِ معها بشكل جيّد قبل قليل

118
00:08:02,860 --> 00:08:04,456
أنا سيء بالتعامل مع الأطفال

119
00:08:04,457 --> 00:08:06,305
صحيح، لأنني تلقيت تدريباً

120
00:08:06,306 --> 00:08:09,987
يجب أن تعزز الشيء
الذي يشعرهم بالأمان

121
00:08:14,700 --> 00:08:15,777
"ريان"

122
00:08:16,497 --> 00:08:18,859
ما هذه؟ فخاخ للحيوانات؟

123
00:08:20,940 --> 00:08:22,420
إنه قادم

124
00:08:23,420 --> 00:08:24,979
دكتور

125
00:08:24,980 --> 00:08:26,179
دكتور

126
00:08:26,180 --> 00:08:27,965
هل رأيتماه؟ -
لا -

127
00:08:27,966 --> 00:08:29,299
لكن أبو "هانا" رآه

128
00:08:29,300 --> 00:08:32,459
لديه سقيفة مليئة
بهذه الأشياء في.. السقيفة

129
00:08:32,460 --> 00:08:34,739
وهذا ليس طبيعياً
حتى بالنسبة للنرويج

130
00:08:36,220 --> 00:08:37,459
ما ذلك الشيء؟

131
00:08:37,460 --> 00:08:39,940
لا أدري، لكن بدا صوته
وكأنه قادم من الغابة

132
00:08:42,173 --> 00:08:43,174
للداخل

133
00:08:48,180 --> 00:08:49,779
يجب أن نؤمن المنزل

134
00:08:49,780 --> 00:08:51,890
ياز"، و "ريان" سدّا الباب الخلفي"

135
00:08:52,340 --> 00:08:54,819
غراهام"، ألقِ نظرة "
من نافذة الطابق الثاني

136
00:08:54,820 --> 00:08:56,100
حسناً

137
00:09:00,580 --> 00:09:03,019
يأخذك بعيداً، يأخذك بعيداً

138
00:09:03,020 --> 00:09:04,539
يأخذك بعيداً

139
00:09:04,540 --> 00:09:05,858
هانا"، اسمعيني"

140
00:09:05,859 --> 00:09:08,399
أيّاً كان ما في الخارج
فسنبقيكِ بأمان

141
00:09:08,400 --> 00:09:09,959
لكنه يأخذكِ بعيداً

142
00:09:11,119 --> 00:09:12,839
أرأيت شيئاً؟

143
00:09:12,840 --> 00:09:14,625
لا شيء بعد

144
00:09:48,375 --> 00:09:51,430
لا تفعل هذا

145
00:09:51,431 --> 00:09:52,951
لمَ لسنا في المرآة؟

146
00:09:52,952 --> 00:09:54,513
لا أدري

147
00:09:58,142 --> 00:10:00,678
كنا سنعرف لو كنا مصاصي دماء، صحيح؟

148
00:10:00,679 --> 00:10:01,800
صحيح

149
00:10:06,120 --> 00:10:07,639
ما هذا الصوت؟

150
00:10:07,640 --> 00:10:09,840
!إبتعدا عن المرآة! كلاكما

151
00:10:10,920 --> 00:10:11,999
تراجعا

152
00:10:12,000 --> 00:10:13,719
نحن هناك

153
00:10:13,720 --> 00:10:14,896
ما الذي حدث؟

154
00:10:16,017 --> 00:10:18,994
لست متأكدة تماماً
لكنه لا يعجبني

155
00:10:18,995 --> 00:10:21,519
هل رأيت تغييراً؟
ما الذي حدث هنا؟

156
00:10:21,520 --> 00:10:23,439
سمعت صوتاً، وأتيت للمرآة

157
00:10:23,440 --> 00:10:25,919
ولم تكن صورتي منعكسة

158
00:10:27,640 --> 00:10:29,159
ها هي ثانية

159
00:10:29,160 --> 00:10:31,905
وذلك الصوت -
لا أحد يتحرك -

160
00:10:33,542 --> 00:10:36,679
حجزته، وهو يفعل ما يفعله

161
00:10:36,680 --> 00:10:39,399
أيمكنني أن أقول بأنني أحب مفكي

162
00:10:39,400 --> 00:10:41,090
... والآن

163
00:10:41,091 --> 00:10:44,180
متى لا تكون المرآة مرآة؟

164
00:11:02,771 --> 00:11:04,679
أنا بخير

165
00:11:04,680 --> 00:11:07,005
غالباً، أشعر برأسي متزعزع قليلاً

166
00:11:07,006 --> 00:11:08,647
وغير ذلك أنا بخير تماماً

167
00:11:09,800 --> 00:11:11,125
أقدره بـ 7 من 10

168
00:11:11,126 --> 00:11:12,359
أو 6.5 على الأسوأ

169
00:11:12,360 --> 00:11:14,599
ما كان ذلك الصوت؟
إهتز المنزل بأكمله

170
00:11:14,600 --> 00:11:16,999
"مرحباً يا "ياز"، وأهلاً يا "هانا
يحدث الكثير هنا

171
00:11:17,000 --> 00:11:19,199
هل كان ما في الخارج؟ -
لا -

172
00:11:19,200 --> 00:11:22,279
يبدو بأن هذه المرآة التي في
غرفة أبيكِ عبارة عن بوابة

173
00:11:22,280 --> 00:11:24,359
... حين تقولين بوابة

174
00:11:24,360 --> 00:11:28,479
بوابة لعالم آخر، أو بعد آخر
أو من يعلم ماذا؟

175
00:11:28,480 --> 00:11:30,239
لكن دعوني أخبركم
إنه يعبث بعقلك

176
00:11:30,240 --> 00:11:32,742
ما الذي تتحدثين عنه؟ -
أعلم، إنه إكتشاف مهم -

177
00:11:32,743 --> 00:11:34,839
كان يفترض أن أخبركِ
بطريقة ألطف

178
00:11:34,840 --> 00:11:36,363
لكن كما قلت، رأسي متزعزع

179
00:11:36,364 --> 00:11:38,759
أيّا ما كان في الغابة، هل
يمكن أن يكون مصدره البوابة؟

180
00:11:38,760 --> 00:11:40,479
ممكن، لا أدري
لم أرَ الكثير

181
00:11:40,480 --> 00:11:41,919
يجب أن ألقي نظرة أفضل

182
00:11:41,920 --> 00:11:43,599
دكتور، أتظنينه آمن؟

183
00:11:43,600 --> 00:11:44,719
أشك بذلك

184
00:11:44,720 --> 00:11:46,378
إنها بوابة لبعد بإهتزازات قوية

185
00:11:46,379 --> 00:11:48,662
في غرفة نوم في النرويج

186
00:11:48,663 --> 00:11:50,134
سآتي معكِ

187
00:11:50,135 --> 00:11:51,599
وأنا أيضاً -
وكذلك أنا -

188
00:11:51,600 --> 00:11:55,240
وأنا، أيّا كان ما يحدث
سأبقى معكم

189
00:11:57,280 --> 00:11:58,946
"لا يمكنني أن أسمح لكِ بهذا يا "هانا

190
00:11:58,947 --> 00:12:00,399
لا أعرف ما يوجد عبر البوابة

191
00:12:00,400 --> 00:12:02,759
وأنتِ آمنة هنا
أمّن لكِ أبيكِ هذا المكان

192
00:12:02,760 --> 00:12:04,919
وأيضاً، أحتاجكِ لحماية المنزل

193
00:12:04,920 --> 00:12:06,439
مما يوجد في الخارج

194
00:12:06,440 --> 00:12:08,279
وسيبقى "ريان" هنا معكِ -
ماذا؟ -

195
00:12:08,280 --> 00:12:10,759
إلا هو -
لمَ قلتِ هذا؟ -

196
00:12:11,263 --> 00:12:13,719
وكلاكما، إبتعدا عن المرآة

197
00:12:13,720 --> 00:12:15,463
فقد حاولت إستدراج "غراهام" إليها

198
00:12:15,464 --> 00:12:17,837
صحيح -
لم تقم بإستدراجي -

199
00:12:17,838 --> 00:12:20,159
ليس وكأنني أعطيتها
 معلومات بطاقتي

200
00:12:27,395 --> 00:12:30,559
هذه خريطة للمنزل توضح
الأماكن المعرضة للهجوم

201
00:12:30,560 --> 00:12:32,439
إحرص على أن تهتم بها

202
00:12:32,440 --> 00:12:33,560
حسناً

203
00:12:33,640 --> 00:12:37,260
قد يكون أبيها ميّت .. أبقها بأمان
وإسأل عن من غيره يمكنه العناية بها

204
00:12:41,287 --> 00:12:43,159
ما اسم أبيكِ يا "هانا"؟

205
00:12:43,160 --> 00:12:44,719
"إيريك"

206
00:12:44,720 --> 00:12:46,279
سوف تجدونه، صحيح؟

207
00:12:46,960 --> 00:12:48,520
سأفعل ما بوسعي

208
00:12:53,633 --> 00:12:57,080
لا أظنها فكرة جيّدة

209
00:12:58,073 --> 00:12:59,993
لنذهب

210
00:13:04,440 --> 00:13:06,039
بالكاد أرى شيئاً

211
00:13:06,040 --> 00:13:08,830
أشبه ببوابة للمكان والزمن
وثبتت نفسها بتلك المرآة

212
00:13:08,831 --> 00:13:10,516
لكن لا يفترض أن تبدو هكذا

213
00:13:10,517 --> 00:13:12,359
كل أجزاء الضوء الغريبة هذه

214
00:13:12,360 --> 00:13:15,159
وكأن البوابة عالقة بين نصفين

215
00:13:15,160 --> 00:13:17,759
كان يفترض أن ندخل لعالم آخر

216
00:13:17,760 --> 00:13:20,959
هذا عالم آخر -
ليس تبعاً لقراءاتي -

217
00:13:20,960 --> 00:13:24,679
أما زلنا في النرويج أم لا؟ -
أيبدو لك هذا نرويجياً؟ -

218
00:13:24,680 --> 00:13:28,239
ليس تماماً -
لنلقي نظرة، بحذر -

219
00:13:28,240 --> 00:13:31,439
دكتور، يوجد ضوء من تلك الصخرة

220
00:13:31,440 --> 00:13:35,080
"ملاحظة جيّدة يا "غراهام
إبقيا بقربي

221
00:13:36,046 --> 00:13:38,246
لنحرص على أن نجد طريق عودتنا

222
00:13:40,367 --> 00:13:43,040
أهذا خيط؟ يا لها من تقنية متطورة

223
00:13:48,440 --> 00:13:49,813
...أكسرك

224
00:13:55,882 --> 00:13:59,039
أكسرك، وألمس لحمك

225
00:13:59,040 --> 00:14:02,519
...وأقتلعك، وكل قطعة منك

226
00:14:02,520 --> 00:14:04,952
مرحباً، آسفون لإزعاجك

227
00:14:07,000 --> 00:14:09,759
هل رأيت مخلوق مزعج
أتى من هذا الإتجاه؟

228
00:14:09,760 --> 00:14:13,359
أو بشريّ نرويجي، يحتمل
أنه إتجه للإتجاه الآخر؟

229
00:14:13,360 --> 00:14:16,576
بإسم "إيريك"، أعني البشريّ

230
00:14:16,577 --> 00:14:18,035
إبنته تبحث عنه

231
00:14:18,720 --> 00:14:20,200
يالها من مأساة

232
00:14:20,840 --> 00:14:23,360
تشعرني بالجوع

233
00:14:25,271 --> 00:14:26,919
لا

234
00:14:26,920 --> 00:14:29,119
حسناً، إذا لم تستطع مساعدتنا
فهل يمكننا أن نأخذ مصباحك؟

235
00:14:29,120 --> 00:14:31,331
لأنه يبدو بأنك إحتكرت الضوء هنا

236
00:14:31,332 --> 00:14:34,559
لا صدقة، مبادلة فقط

237
00:14:34,560 --> 00:14:36,342
إبتعد

238
00:14:36,343 --> 00:14:38,394
المصباح ليس لك

239
00:14:38,395 --> 00:14:40,108
حسناً، كنت أنظر إليه فحسب

240
00:14:40,109 --> 00:14:41,789
إهدأ

241
00:14:41,790 --> 00:14:43,719
الطير غداء

242
00:14:43,720 --> 00:14:46,159
ربما عجوز للشاي

243
00:14:46,160 --> 00:14:47,799
من تقصد بالعجوز؟

244
00:14:47,800 --> 00:14:49,479
أنت ورائحتك النتنة كالبول

245
00:14:49,480 --> 00:14:51,879
هذا ليس بولي

246
00:14:51,880 --> 00:14:55,579
دعه يذهب، لأنك لا تريد
أن تكون هذه كلماتك الأخيرة

247
00:14:55,580 --> 00:14:59,119
سيّدتي

248
00:14:59,120 --> 00:15:03,239
اسمي "ريبونز" من المعدات السبعة

249
00:15:04,403 --> 00:15:07,399
أريد أنبوبكِ

250
00:15:07,400 --> 00:15:10,416
أنبوب لامع

251
00:15:10,417 --> 00:15:14,187
لأن "ريبونز" رأى الرجل
... الذي تبحثين عنه

252
00:15:14,188 --> 00:15:16,546
المبادلة الآن ممكنة

253
00:15:16,547 --> 00:15:21,959
بهذا الأنبوب، يمكن أن
تشتري معلومات لذيذة

254
00:15:21,960 --> 00:15:23,960
ومصباح

255
00:15:25,280 --> 00:15:27,964
كيف كان يبدو؟ هذا الرجل؟

256
00:15:27,965 --> 00:15:33,077
بلا قرون، وفم واحد، وقبيح جداً

257
00:15:33,078 --> 00:15:38,079
مثلكم، لكن بحذاء أجمل

258
00:15:38,080 --> 00:15:39,840
إنه حيّ إذن

259
00:15:40,800 --> 00:15:43,725
هل كان معه أحد؟ أو شيء؟

260
00:15:43,726 --> 00:15:46,456
ستعرفين حين آخذكِ

261
00:15:46,457 --> 00:15:48,660
لكن بعد الدفع

262
00:15:49,656 --> 00:15:52,560
الأنبوب من فضلكِ، الآن

263
00:15:53,806 --> 00:15:57,082
الدفع عند الإستلام
وأترك السكين هنا

264
00:16:09,800 --> 00:16:12,599
دكتور، لن تعطيه المفك، صحيح؟

265
00:16:12,600 --> 00:16:16,719
أنظري.. لديه حزام مليء
بجرذان ميتة ذات ستة أرجل

266
00:16:16,720 --> 00:16:18,279
غراهام" محق"

267
00:16:18,280 --> 00:16:20,319
"قد يكون من أخذ "إيريك

268
00:16:20,320 --> 00:16:22,999
وتريديننا أن نتبع هذا
المجنون نحو الظلام

269
00:16:23,000 --> 00:16:25,239
لا، بل أريدكم أن تتبعا
هذه المجنونة نحو الظلام

270
00:16:25,240 --> 00:16:27,199
يوجد ثلاثة منا، ولا يوجد سواه

271
00:16:27,200 --> 00:16:28,639
بالإضافة للجرذان

272
00:16:28,640 --> 00:16:31,600
مهم أن تبقوا هادئين يا أصدقاء

273
00:16:32,560 --> 00:16:35,039
تفضلوا، ضوء
لإثبات حسن النية

274
00:16:35,040 --> 00:16:38,360
إتبعوا "ريبونز" للأب المفقود

275
00:16:42,080 --> 00:16:43,559
هل كنتِ طوال عمركِ كفيفة؟

276
00:16:43,560 --> 00:16:44,833
تقريباً

277
00:16:44,834 --> 00:16:47,080
يمكنني أن أرى الضوء
إذا كان قريباً جداً مني

278
00:16:48,080 --> 00:16:49,199
لا بد بأنه صعب

279
00:16:49,200 --> 00:16:51,019
لا أريد شفقتك

280
00:16:51,918 --> 00:16:53,479
لمَ لا تحبينني؟

281
00:16:53,480 --> 00:16:55,231
ظننت بأن أبي سيتركني

282
00:16:55,232 --> 00:16:57,800
حسناً، أنا آسف، كنت مخطئاً

283
00:16:59,440 --> 00:17:01,936
أي جزء من المنزل
يعتبر عرضة للهجوم؟

284
00:17:06,320 --> 00:17:07,720
المستنبت الزجاجي

285
00:17:10,849 --> 00:17:12,869
أعني.. أعني الشرفة

286
00:17:13,642 --> 00:17:15,349
ليست خريطة، صحيح؟

287
00:17:15,350 --> 00:17:16,828
بدا صوتها وكأنها تكتب شيئاً

288
00:17:16,829 --> 00:17:19,615
بل هي خريطة حقاً -
ما الذي تخفيه عني؟ -

289
00:17:19,616 --> 00:17:20,740
أريد أن أذهب معهم

290
00:17:20,741 --> 00:17:23,398
قالت الدكتور بأن نبقى هنا -
أريد أبي -

291
00:17:23,399 --> 00:17:24,960
أتركني

292
00:17:28,520 --> 00:17:30,519
أعطني هذا المفتاح

293
00:17:30,520 --> 00:17:32,959
لا يمكنك أن تمسك بي
وتسحبني حيث شئت

294
00:17:32,960 --> 00:17:34,519
يمكن أن أتصل بالشرطة -
ثم ماذا؟ -

295
00:17:34,520 --> 00:17:35,839
وتخبرينهم بشأن الوحش؟

296
00:17:35,840 --> 00:17:38,010
أو البوابة التي في المرآة؟
كيف سيساعدكِ ذلك؟

297
00:17:38,011 --> 00:17:39,879
لا يعجبني كذبك عليّ

298
00:17:39,880 --> 00:17:41,439
بشأن ما كتبته على الجدار

299
00:17:41,440 --> 00:17:43,399
كان هذا أقرب

300
00:17:43,400 --> 00:17:45,840
ماذا لو نكف عن الجدال
ونتحقق من دفاعاتنا؟

301
00:17:48,720 --> 00:17:50,759
إلى أين ستأخذنا بالضبط يا "ريبونز"؟

302
00:17:50,760 --> 00:17:53,778
"إهدأوا! واستمتعوا مع "ريبونز

303
00:17:53,779 --> 00:17:55,220
نحن كذلك

304
00:17:55,920 --> 00:17:58,287
أخبرنا عن هذه المصابيح
التي تفخر بها

305
00:17:58,874 --> 00:18:00,254
تصميمي

306
00:18:00,760 --> 00:18:02,198
الضوء الوحيد هنا

307
00:18:02,199 --> 00:18:03,359
هنا أين؟

308
00:18:03,360 --> 00:18:07,079
المعلومات باهضة جداً للأسف

309
00:18:07,080 --> 00:18:09,843
لا تملكين الرصيد الكافي

310
00:18:09,844 --> 00:18:11,599
لكنك تعيش هنا، كما أفترض

311
00:18:11,600 --> 00:18:14,079
بما أنه يوجد بوابة قرب
 المكان الذي وجدناك فيه

312
00:18:14,080 --> 00:18:15,640
وإخترت أن لا تستخدمها

313
00:18:18,690 --> 00:18:20,959
تسألين الأسئلة الذكية

314
00:18:20,960 --> 00:18:24,400
أراهن على أن مذاق دماغكِ لذيذ

315
00:18:27,440 --> 00:18:29,680
ما هذا؟ -
عث اللحم -

316
00:18:30,987 --> 00:18:32,580
غلطتكم

317
00:18:32,581 --> 00:18:34,341
لا تتحركوا

318
00:18:43,022 --> 00:18:44,762
هذا عث خطير

319
00:18:45,282 --> 00:18:50,719
لن يؤذي الملابس، لكن
 يفسخ اللحم عن العظام

320
00:18:50,720 --> 00:18:55,360
لحسن الحظ، أي شيء
يمكن تشتيته بالطعام

321
00:18:57,160 --> 00:18:59,943
للأمام يا أصدقاء

322
00:19:01,113 --> 00:19:03,273
سيخلي "ريبونز" المكان ويتبعكم

323
00:19:25,400 --> 00:19:27,320
لا بد بأنك تمزح

324
00:19:39,160 --> 00:19:40,640
لمَ تفعل هذا؟

325
00:19:42,640 --> 00:19:43,960
هانا"؟"

326
00:19:45,240 --> 00:19:46,519
"هانا"

327
00:19:46,520 --> 00:19:48,920
لا داعي للخوف، لا يوجد
 مخلوق في الخارج

328
00:19:59,920 --> 00:20:01,750
لم أعد أعرف أين أنا

329
00:20:01,751 --> 00:20:03,799
هذا المكان أشبه بمتاهة

330
00:20:03,800 --> 00:20:05,199
هل رأيت "إيريك" هنا؟

331
00:20:05,200 --> 00:20:07,164
لا، لا، لا، لا

332
00:20:07,165 --> 00:20:10,399
يضعكم "ريبونز" في
 أضعف حالاتكم للمفاوضة

333
00:20:10,400 --> 00:20:12,081
ما الذي تتحدث عنه؟

334
00:20:12,082 --> 00:20:15,000
مؤسف، ليس لديكِ حبل

335
00:20:21,220 --> 00:20:24,620
لا "إيريك"، لا مفك

336
00:20:27,479 --> 00:20:30,039
سكينتان، بالطبع ستحمل سكينتين

337
00:20:30,040 --> 00:20:33,313
كل ما علينا أن نعيد التفاوض

338
00:20:33,314 --> 00:20:35,079
لا يوجد طريق للعودة

339
00:20:35,080 --> 00:20:40,839
يمكنني أن أريكم
لكن هذا الإرشاد اللذيذ يكلف أكثر

340
00:20:40,840 --> 00:20:44,559
يا إلهي، كيف تكون رائحتك أسوأ من السابق؟

341
00:20:46,403 --> 00:20:48,320
عث اللحم يتبعنا

342
00:20:50,599 --> 00:20:54,118
يجب أن نتخلص منه
وإلا سيأتي الكثير

343
00:20:57,160 --> 00:20:58,680
الجرذ الأخير

344
00:21:01,573 --> 00:21:02,999
لا يريده

345
00:21:03,000 --> 00:21:06,279
ألا يمكننا التخلص من المصباح؟ -
لا! الظلام أسوأ -

346
00:21:06,280 --> 00:21:07,799
ما هذا المكان يا "ريبونز"؟

347
00:21:07,800 --> 00:21:09,159
منطقة مضادة

348
00:21:09,160 --> 00:21:11,079
أوه، لا

349
00:21:11,080 --> 00:21:13,239
أهذا شيء جيّد أم سيء؟

350
00:21:13,240 --> 00:21:15,559
المنطقة المضادة هي شيء
يصنعه الكون

351
00:21:15,560 --> 00:21:19,079
كلما أصبح نسيج المكان
...والزمن مهدداً، مثل

352
00:21:19,080 --> 00:21:21,559
منطقة مصد حماية...
لتبقي التهديد بعيداً

353
00:21:21,560 --> 00:21:23,599
ونحن في الوسط

354
00:21:23,600 --> 00:21:25,439
كيف وصلت إلى هنا يا "ريبونز"؟

355
00:21:25,440 --> 00:21:27,040
لطالما كنت هنا

356
00:21:30,240 --> 00:21:32,239
ما الذي يحدث؟

357
00:21:33,880 --> 00:21:37,479
يستدعي عث اللحم جماعته
الإشارة تقتل مصباحي

358
00:21:37,480 --> 00:21:39,300
سيأتي الكثير منهم الآن

359
00:21:39,880 --> 00:21:41,399
يجب أن تركضوا

360
00:21:41,400 --> 00:21:44,479
أعطيني أنبوبي الآن -
لا، لن تأخذه يا عزيزي -

361
00:21:47,980 --> 00:21:50,079
ما رأيك بهذا بالنسبة لعجوز
يا ذو السكينتين؟

362
00:21:50,080 --> 00:21:51,261
الصمت

363
00:21:51,920 --> 00:21:53,239
إنهم هنا

364
00:21:53,240 --> 00:21:55,330
"ياز" و "غراهام"

365
00:21:56,040 --> 00:21:58,880
لا تحركا عضلة...

366
00:21:59,840 --> 00:22:03,639
يريدنا أن نركض
لذا سنبقى ثابتين تماماً

367
00:22:11,971 --> 00:22:14,118
لا يا "ريبونز"، لا تفعل

368
00:22:14,119 --> 00:22:16,679
لا! ليس أنا

369
00:22:16,680 --> 00:22:20,200
هاجموا الآخرين، ليس أنا

370
00:22:24,683 --> 00:22:26,880
بلطف وهدوء، والآن أركضا

371
00:22:31,080 --> 00:22:33,575
إستمرا! يوجد ضوء أمامنا

372
00:22:33,576 --> 00:22:35,360
ها هي البوابة

373
00:22:44,680 --> 00:22:46,376
ما كان ذلك؟

374
00:22:46,377 --> 00:22:48,355
لا أدري، لكن أظننا آمنون الآن

375
00:22:48,356 --> 00:22:51,119
هل غيروا أماكن الأثاث هنا؟

376
00:22:51,120 --> 00:22:53,360
كل شيء يبدو مختلفاً

377
00:22:54,680 --> 00:22:57,080
لا أظنها نفس البوابة
التي دخلنا عبرها

378
00:22:58,183 --> 00:23:01,800
لكن إذا لم تكن نفس البوابة
فكيف عدنا لغرفة النوم؟

379
00:23:04,093 --> 00:23:07,093
يبدو لي بأننا وصلنا
للجانب الآخر من المرآة

380
00:23:28,760 --> 00:23:30,239
"هانا"

381
00:24:13,760 --> 00:24:15,119
لم نقاطعك، صحيح؟

382
00:24:16,480 --> 00:24:19,061
ما الذي تفعلونه في منزلي؟ -
ما الذي تفعله في منزلك؟ -

383
00:24:19,062 --> 00:24:22,076
وكيف يكون هذا منزلك يا "إيريك"؟
هذا مستحيل، صحيح؟

384
00:24:22,077 --> 00:24:24,039
من أنتِ وكيف تعرفين إسمي؟

385
00:24:24,040 --> 00:24:25,367
أترك هذا من يدك

386
00:24:25,368 --> 00:24:28,399
أتينا عبر المنطقة المضادة
بعد أن أرسلتنا إبنتك التي هجرتها

387
00:24:28,400 --> 00:24:30,239
ولم يكن الأمر ممتعاً

388
00:24:30,240 --> 00:24:32,719
"لم أهجر "هانا -
بلى فعلت يا صاح -

389
00:24:32,720 --> 00:24:35,319
إنها خائفة وجائعة
وتظن بأنك أُختطفت

390
00:24:35,320 --> 00:24:38,519
إنها مراهقة، ويوجد طعام في الثلاجة
وهي بخير دون وجودي

391
00:24:38,520 --> 00:24:41,119
يوجد وحش طليق في
 الغابة خارج منزلك

392
00:24:41,120 --> 00:24:43,719
لا، لا يوجد شيء -
تبدو متأكداً من ذلك -

393
00:24:43,720 --> 00:24:46,726
لأنه مجرد تسجيل
كي لا تذهب إلى التلال

394
00:24:47,426 --> 00:24:51,544
حولت بيتك لحصن
لتخيف إبنتك؟

395
00:24:51,545 --> 00:24:53,763
لأبقيها بأمان، حين أغيب

396
00:24:53,764 --> 00:24:55,719
أسلوب تربية مريع

397
00:24:55,720 --> 00:24:57,279
كنت تعلم بمجيئك إلى هنا

398
00:24:57,280 --> 00:24:59,080
فلمَ صنعت فخاخ الدببة؟

399
00:24:59,081 --> 00:25:00,740
لأنه يوجد دببة

400
00:25:00,741 --> 00:25:03,305
وليس وحشاً، لكن الدب الطبيعي

401
00:25:03,306 --> 00:25:06,999
اسمعوا، شكراً لقدومكم
 سأعود قريباً، لكن إذهبوا الآن

402
00:25:07,000 --> 00:25:08,359
سوف أضربه

403
00:25:08,360 --> 00:25:10,079
لا، لن تفعل، بل أنا سأضربه

404
00:25:10,080 --> 00:25:11,717
لا أحد سيضرب أحد

405
00:25:12,820 --> 00:25:16,163
يوم طويل، وعث لحم ومنطقة مضادة

406
00:25:16,164 --> 00:25:17,719
والآن، من غيرك هنا يا "إيريك"؟

407
00:25:17,720 --> 00:25:19,199
من الذي لا تريدنا أن نراه؟

408
00:25:19,200 --> 00:25:21,119
لا أعرف ما تقصدينه

409
00:25:21,120 --> 00:25:22,364
بلى، تعرف

410
00:25:22,800 --> 00:25:23,960
طبقين

411
00:25:27,640 --> 00:25:28,879
مرحباً

412
00:25:28,880 --> 00:25:30,799
"أنا "ترينا

413
00:25:30,800 --> 00:25:32,199
"زوجة "إيريك

414
00:25:32,961 --> 00:25:34,280
"إيريك"

415
00:25:34,281 --> 00:25:35,940
هل تزوجت بمن بالمرآة؟

416
00:25:35,941 --> 00:25:38,760
"لا، "ترينا" والدة "هانا

417
00:25:40,320 --> 00:25:41,919
والدة "هانا" ميتة

418
00:25:41,920 --> 00:25:44,291
في عالمكم، لكن ليس هنا

419
00:25:44,292 --> 00:25:45,413
ما الذي تفعلينه؟

420
00:25:46,136 --> 00:25:49,239
هل هذا عالم بديل حيث
لا تموت "ترينا"؟

421
00:25:49,240 --> 00:25:52,359
لا أعرف ما يكون -
... ولا أنا، أقصد -

422
00:25:52,360 --> 00:25:55,541
... لقد مت، وأتذكر ذلك

423
00:25:55,976 --> 00:25:57,622
لكن... ها أنا الآن

424
00:25:58,520 --> 00:25:59,761
لا يمكنها المغادرة

425
00:25:59,762 --> 00:26:02,015
حاولنا لكن لا يمكنها
أن تعبر المرآة

426
00:26:02,016 --> 00:26:04,999
"أعلم بأنني تركت "هانا
لوقت طويل لكنني ظللت أفكر

427
00:26:05,000 --> 00:26:07,160
"ماذا لو ذهبت ولم أستطع العودة؟"

428
00:26:09,280 --> 00:26:11,052
لا يمكنني أن أخسر "تينا" ثانية

429
00:26:11,053 --> 00:26:13,155
يجب أن تعيد ترتيب أولويتاتك يا صاح

430
00:26:13,848 --> 00:26:15,639
إبنتك تحتاجك، هيّا

431
00:26:15,640 --> 00:26:17,480
ألا تريدون أن تروا صديقتكم؟

432
00:26:18,440 --> 00:26:19,740
ما الذي تتحدثين عنه؟

433
00:26:20,840 --> 00:26:22,720
وصلت إلى هنا حين أتيتم

434
00:26:39,960 --> 00:26:41,239
هل أنت بخير؟

435
00:26:41,240 --> 00:26:43,400
نعم ... أعرف ذلك الصوت

436
00:26:54,800 --> 00:26:56,640
"غراهام أوبراين"

437
00:26:58,148 --> 00:27:00,286
يستحسن أن تخبرني
الآن بما يحدث هنا

438
00:27:03,360 --> 00:27:04,960
لا تفعلي هذا بي

439
00:27:19,160 --> 00:27:22,056
لا تتحركي، قفي مكانكِ

440
00:27:22,400 --> 00:27:23,960
"إنه أنا، "ريان

441
00:27:26,282 --> 00:27:28,159
حسناً

442
00:27:28,160 --> 00:27:29,661
سوف أصلح شيئاً

443
00:27:30,293 --> 00:27:32,173
ثم سنتحرك معاً

444
00:27:33,760 --> 00:27:35,360
يوجد ضوء مخبأ هنا

445
00:27:46,002 --> 00:27:48,719
حسناً، أمسكي بكمي

446
00:27:48,720 --> 00:27:51,200
أين نحن؟ -
لا فكرة لديّ، إبقي قربي -

447
00:27:52,440 --> 00:27:53,840
حسناً

448
00:27:57,200 --> 00:27:59,040
أخبرني بما تراه

449
00:27:59,973 --> 00:28:03,360
إنه نوع من الكهوف
لكنه كهف جميل

450
00:28:04,040 --> 00:28:07,102
هل زرتِ كهوف البيك دستركت؟
يشبهها قليلاً

451
00:28:07,575 --> 00:28:09,840
ريان" أنت تكذب علي"

452
00:28:10,840 --> 00:28:12,666
أعتذر لإغلاقي الباب عليك

453
00:28:13,340 --> 00:28:15,340
كان عليّ أن آتي إلى هنا لأجد أبي

454
00:28:16,200 --> 00:28:18,382
حسناً، أتريدين الحقيقة؟

455
00:28:18,955 --> 00:28:20,914
كانت الوحوش التي
 في الغابة مجرد تسجيل

456
00:28:20,915 --> 00:28:23,200
أظن والدكِ فعل ذلك
ليبقيكِ داخل المنزل

457
00:28:24,105 --> 00:28:25,493
كان الإنترنت سيكفيه

458
00:28:26,646 --> 00:28:28,246
هل كذب علي؟

459
00:28:30,000 --> 00:28:31,199
نعم

460
00:28:31,200 --> 00:28:34,120
وأنت تكذب الآن عن
مدى سوء المكان هنا

461
00:28:36,120 --> 00:28:37,567
أحاول أن أعتني بكِ

462
00:28:37,568 --> 00:28:39,122
...أعلم بأنها حماقة، لكن

463
00:28:40,022 --> 00:28:41,236
هل أنا حقيقية؟...

464
00:28:41,949 --> 00:28:44,755
قتلني ذلك المخلوق
 الذي على الرافعة

465
00:28:45,754 --> 00:28:48,560
لكن الآن... أنا هنا معك

466
00:28:50,320 --> 00:28:52,280
لا أفهم

467
00:28:53,638 --> 00:28:55,238
لا، ولا أنا

468
00:28:55,938 --> 00:28:57,480
لمَ تتصرف بغرابة معي؟

469
00:28:58,532 --> 00:29:00,039
لأن هذا مستحيل

470
00:29:00,580 --> 00:29:01,719
أعلم

471
00:29:02,260 --> 00:29:03,599
لكنني هنا يا حبيبي

472
00:29:03,600 --> 00:29:04,780
وأنا حقيقية

473
00:29:06,380 --> 00:29:07,820
..."إذا كنتِ "غريس

474
00:29:08,319 --> 00:29:10,439
أخبريني بكل شيء...
عن هذه القلادة

475
00:29:11,560 --> 00:29:13,000
إنها لي

476
00:29:14,040 --> 00:29:16,879
أعطيتني إياها قبل عيدين

477
00:29:17,631 --> 00:29:20,160
وفي نفس السنة، أهداني
ريان" قلادة ضفدع أخرى"

478
00:29:21,440 --> 00:29:23,240
لأنني أحب الضفادع

479
00:29:24,040 --> 00:29:26,800
ولم تتحققا من بعضكما
قبل أن تذهبا للتسوق

480
00:29:28,043 --> 00:29:32,479
وأنت ترتديها... كي تبقيني قربك

481
00:29:32,913 --> 00:29:34,483
هذا ليس عدلاً

482
00:29:37,585 --> 00:29:39,192
لا بد بأنها خدعة

483
00:29:39,193 --> 00:29:42,073
لا يمكن أن تكوني هي

484
00:29:43,078 --> 00:29:44,573
أشعر بأنني أنا

485
00:29:47,440 --> 00:29:49,639
يستحيل أن تكون "غريس"، أهذا ممكن؟

486
00:29:49,640 --> 00:29:50,842
لا

487
00:29:51,469 --> 00:29:53,199
"ولا يمكن أن تكوني زوجة "إيريك

488
00:29:53,200 --> 00:29:54,403
أعلم

489
00:29:55,117 --> 00:29:57,520
لكننا كذلك، صحيح؟

490
00:30:01,160 --> 00:30:02,959
حسناً، لا داعي للهلع

491
00:30:03,525 --> 00:30:06,293
لم أهلع -
أعلم، كنت أحدث نفسي -

492
00:30:06,294 --> 00:30:09,240
لأن كل هذا... خاطئ تماماً

493
00:30:09,740 --> 00:30:11,579
صحيح، ما الذي نعرفه؟

494
00:30:11,580 --> 00:30:16,039
هذه المرآة بوابة بين عالمين

495
00:30:16,040 --> 00:30:20,879
دخلنا إليها من العالم الحقيقي
وخرجنا منها إلى هذا العالم

496
00:30:20,880 --> 00:30:22,860
لكن تلك المنطقة المضادة
موجودة في الوسط

497
00:30:22,861 --> 00:30:24,519
تقسم البوابة لقسمين

498
00:30:24,520 --> 00:30:26,439
منطقة للفصل بين عالمين

499
00:30:26,440 --> 00:30:27,559
بالضبط

500
00:30:27,560 --> 00:30:30,799
لأن المنطقة المضادة لا توجد
إلا حين يتعرض نسيج الكون

501
00:30:30,800 --> 00:30:33,839
لتهديد هائل وعظيم

502
00:30:35,400 --> 00:30:37,359
... وهذا يعني

503
00:30:37,360 --> 00:30:41,073
بأنها موجودة لتمنع هذا العالم...

504
00:30:41,074 --> 00:30:43,650
وعالمكِ، من أن يتلامسا

505
00:30:44,618 --> 00:30:47,439
لحظة، لكن هذا يعني
بأن هذا العالم خطير

506
00:30:47,440 --> 00:30:49,159
لكن كيف يكون خطيراً؟

507
00:30:49,160 --> 00:30:52,559
أيضاً، ما الذي يملك القوة
لأن يصنع نسخة كهذه؟

508
00:30:52,560 --> 00:30:54,085
... إلا لو

509
00:30:54,086 --> 00:30:57,273
هذا مستحيل

510
00:30:57,274 --> 00:30:58,959
ما المستحيل؟

511
00:30:58,960 --> 00:31:00,769
أخبرتكِ عن السوليتراكت، صحيح؟

512
00:31:00,770 --> 00:31:02,359
حرفيّاً لم أسمع بهذه الكلمة من قبل

513
00:31:02,360 --> 00:31:03,559
السوليتراكت؟

514
00:31:03,560 --> 00:31:06,559
السوليتراكت، عبارة عن نظرية
أو أسطورة

515
00:31:06,560 --> 00:31:09,218
قصة قبل النوم، كانت تحكيها لي جدتي

516
00:31:09,219 --> 00:31:10,319
أكانت لديكِ جدة؟

517
00:31:10,320 --> 00:31:12,159
كان لدي سبعة، لكن الجدة الخامسة
 هي المفضلة لدي

518
00:31:12,160 --> 00:31:14,040
كانت تخبرني عن السوليتراكت

519
00:31:16,080 --> 00:31:19,679
لأنه في البداية، قبل الزمن وقبل كل شيء

520
00:31:19,680 --> 00:31:21,799
كانت كل القوانين والمواد

521
00:31:21,800 --> 00:31:24,999
والعناصر الأساسية للكون، موجودة

522
00:31:25,000 --> 00:31:28,799
الضوء والمادة والرياضيات وغيرها

523
00:31:28,800 --> 00:31:31,039
لكن لم تتناسق معاً بالشكل المطلوب

524
00:31:31,040 --> 00:31:32,999
بسبب وجود السوليتراكت

525
00:31:33,685 --> 00:31:35,039
ما هو السوليتراكت إذن؟

526
00:31:35,040 --> 00:31:37,399
وعي، طاقة

527
00:31:37,400 --> 00:31:40,639
لا يمكن لواقعنا أن يعمل
بوجود طاقة السوليتراكت

528
00:31:40,640 --> 00:31:44,640
ستفسَد أبسط الأفكار في الكون

529
00:31:45,680 --> 00:31:49,559
فكري بها كما لو كانت طفلة
مصابة بالحصبة، حصبة نووية

530
00:31:49,560 --> 00:31:53,279
تريد أن تنضم للآخرين
لكنها تصيب البقية بالمرض

531
00:31:53,280 --> 00:31:57,429
لا يمكن لكوننا العمل
بوجود السوليتراكت داخله

532
00:31:57,430 --> 00:31:59,759
حكت لكِ جدتكِ هذا قبل النوم؟

533
00:31:59,760 --> 00:32:01,298
فقط حين يجافيني النوم

534
00:32:01,299 --> 00:32:03,560
ما الذي فعله كوننا إذن؟

535
00:32:04,480 --> 00:32:08,720
إستطاع أن ينفي السوليتراكت

536
00:32:08,721 --> 00:32:11,360
لوجود منفصل لا يمكن وصوله

537
00:32:12,183 --> 00:32:13,959
مستوى السوليتراكت

538
00:32:13,960 --> 00:32:17,719
وفجأة، أصبح كل شيء مفهوم

539
00:32:17,720 --> 00:32:19,999
تمكن الكون من النجاح

540
00:32:20,000 --> 00:32:22,439
لأنه تمت إزالة السوليتراكت

541
00:32:22,440 --> 00:32:26,159
لحظة، أتقولين بأننا الآن
داخل مستوى السوليتراكت؟

542
00:32:26,160 --> 00:32:27,679
أتمنى لو لم يكن كذلك
 لكن هذا ما أظنه

543
00:32:27,680 --> 00:32:30,089
أنا خائفة، فهل أنتِ خائفة؟

544
00:32:30,090 --> 00:32:31,955
أنا مرعوبة بحق

545
00:32:31,956 --> 00:32:35,279
هذا كون منبوذ منفصل
ووعيّ في الوقت ذاته؟

546
00:32:35,280 --> 00:32:36,919
هذا ما كانت تقوله جدتي الخامسة

547
00:32:36,920 --> 00:32:39,159
كون واعي

548
00:32:39,160 --> 00:32:41,919
لكنها قالت أيضاً بأن جدتي الثانية
كانت عميلة سرية للزايغون

549
00:32:41,920 --> 00:32:44,119
لكن بدت متأكدة من هذه المعلومة

550
00:32:44,120 --> 00:32:45,679
لكن لماذا؟

551
00:32:45,680 --> 00:32:48,394
لمَ نسخت السوليتراكت عالمكِ؟

552
00:32:48,395 --> 00:32:50,768
"متضمناً "غريس" و "ترينا

553
00:32:50,769 --> 00:32:52,840
... وبنت بوابة

554
00:32:53,986 --> 00:32:55,506
لعالمنا؟...

555
00:32:56,238 --> 00:33:00,040
حين تقولينه بهذا الشكل
يبدو وكأنه... فخ

556
00:33:03,371 --> 00:33:05,439
ما الذي تفعله في النرويج؟

557
00:33:05,440 --> 00:33:06,622
إنها سفينة الدكتور

558
00:33:06,623 --> 00:33:08,096
"كنتِ ستحبينها يا "غريس

559
00:33:08,097 --> 00:33:10,119
إنها كبينة شرطة قديمة

560
00:33:10,120 --> 00:33:12,599
لكنها من الداخل
مركبة فضاء ضخمة

561
00:33:12,600 --> 00:33:14,531
تذهب إلى أي مكان وزمن

562
00:33:14,532 --> 00:33:16,079
كانت تخبرنا بالحقيقة
تلك الليلة إذن؟

563
00:33:16,080 --> 00:33:18,719
تذكرين كل شيء، صحيح؟ -
بالطبع أذكر كل شيء -

564
00:33:18,720 --> 00:33:19,779
صحيح

565
00:33:20,400 --> 00:33:23,820
ذهبت لكوكب فضائي يا "غريس"، أنا

566
00:33:24,800 --> 00:33:26,879
"وقابلت "روزا باركس

567
00:33:27,317 --> 00:33:28,884
روزا باركس"؟" -
أعلم -

568
00:33:31,112 --> 00:33:33,232
يبدو بأنك بأفضل حال بدوني

569
00:33:34,511 --> 00:33:35,879
"أنا تائه يا "غريس

570
00:33:36,397 --> 00:33:37,680
أفتقدكِ

571
00:33:38,160 --> 00:33:41,039
كنت أبحث عنكِ طوال حياتي
وحين وجدتكِ

572
00:33:41,040 --> 00:33:43,780
كنت... سعيداً جداً

573
00:33:44,400 --> 00:33:46,120
وأنا كذلك

574
00:33:48,726 --> 00:33:50,060
ثم فقدتكِ

575
00:33:50,600 --> 00:33:51,879
أنا هنا

576
00:33:51,880 --> 00:33:53,600
أفتقدكِ كثيراً

577
00:33:54,999 --> 00:33:56,751
"أفتقدكِ كثيراً يا "غريس

578
00:33:56,752 --> 00:33:59,119
غراهام"، سنغادر الآن"

579
00:33:59,120 --> 00:34:01,418
حسناً، نعم
"هيّا يا "غريس

580
00:34:01,419 --> 00:34:03,479
صحيح، آسفة لصراحتي
"مرحباً يا "غريس

581
00:34:03,480 --> 00:34:05,479
"هذه ليست "غريس
"لا أقصد الإساءة يا "غريس

582
00:34:05,480 --> 00:34:06,757
لا عليكِ يا حبيبتي

583
00:34:06,758 --> 00:34:08,719
"لا يمكنها مرافقتنا يا "غراهام
ليست حقيقية

584
00:34:08,720 --> 00:34:10,719
أظنكِ مخطئة -
لست مخطئة -

585
00:34:10,720 --> 00:34:13,118
إنها تذكر كل شيء -
أعلم بأن هذا صعباً -

586
00:34:13,119 --> 00:34:15,359
أعني، بعد كل الأشياء المجنونة
 التي رأيتيها يا دكتور

587
00:34:15,360 --> 00:34:17,384
لا يمكنكِ إخباري بأنكِ
تعرفين بأنها ليست هي

588
00:34:17,385 --> 00:34:20,341
هذا كله مجرد حيلة
ولا أظن "غريس" تعلم ذلك

589
00:34:20,342 --> 00:34:24,109
أظن هذا العالم بأكمله فخ
وهي جزء منه

590
00:34:24,110 --> 00:34:28,631
إسمعني، إما هي أو العالم الحقيقي
لا يمكن أن تحصل على الإثنين

591
00:34:28,632 --> 00:34:31,000
أدخل أرجوك، سنذهب

592
00:34:35,164 --> 00:34:38,460
أحتاج لأن أفتح هذه وأخرج
غراهام" و"إيريك" من هنا"

593
00:34:39,240 --> 00:34:43,879
لن تتزحزح، لا بد بأن
السوليتراكت تتحكم بها

594
00:34:43,880 --> 00:34:45,901
ولا يمكنني إجبارها بالمفك
كما فعلت سابقاً

595
00:34:45,902 --> 00:34:48,239
لأنها ذكيّة وتكيّفت معه

596
00:34:48,240 --> 00:34:50,751
ماذا لو فعلتِ شيئاً
لم تره من قبل

597
00:34:50,752 --> 00:34:53,633
كأن تعكسي القطبية أو ما شابه؟

598
00:34:54,402 --> 00:34:57,119
"ياسمين خان"
أنتِ تتحدثين لغتي

599
00:34:57,120 --> 00:34:59,159
"إستمري بالركض يا "هانا

600
00:34:59,160 --> 00:35:01,399
!إلى هنا! إلى هنا

601
00:35:01,400 --> 00:35:02,920
إنخفضي، إنخفضي

602
00:35:08,816 --> 00:35:11,342
أظننا مستعدون الآن -
عمل جيّد يا دكتور -

603
00:35:11,343 --> 00:35:12,839
شكراً لكِ، أبذل جهدي

604
00:35:12,840 --> 00:35:15,239
غراهام" و "إيريك"، حان الوقت"

605
00:35:15,240 --> 00:35:17,278
هيّا -
"غراهام" -

606
00:35:17,279 --> 00:35:19,031
سمعت ما قالته الدكتور

607
00:35:19,032 --> 00:35:21,079
"هيّا يا "غريس -
لست متأكدة -

608
00:35:21,080 --> 00:35:23,039
لا يمكنني أن أبقيها مفتوحة مدة أطول

609
00:35:23,040 --> 00:35:26,080
غراهام" و"ياز" و"إيريك"، الآن أرجوكم"

610
00:35:28,760 --> 00:35:30,160
أركضي

611
00:35:34,240 --> 00:35:37,040
يوجد بوابة أمامنا مباشرة
سوف أشتت إنتباههم

612
00:35:38,320 --> 00:35:40,640
ما الذي تفعلينه هنا؟ -
هانا"، هذا أنا" -

613
00:35:45,480 --> 00:35:48,799
سمعت أبي -
لا بأس، لا بأس، أنا هنا -

614
00:35:48,800 --> 00:35:51,759
أين نحن؟ وما الذي يحدث؟

615
00:35:51,760 --> 00:35:54,559
تكيّفت البوابة ثانية
لا يمكنني فتحها

616
00:35:55,129 --> 00:35:56,799
لديّ مفاجأة لكِ

617
00:35:56,800 --> 00:35:58,286
"إنها أمكِ يا "هانا

618
00:35:59,046 --> 00:36:01,279
إنها حيّة -
ماذا؟ -

619
00:36:01,280 --> 00:36:02,751
"هانا"

620
00:36:04,200 --> 00:36:06,805
إبنتي الجميلة

621
00:36:08,720 --> 00:36:12,399
لا أعرف من تكونين
لكنكِ لست أمي

622
00:36:12,400 --> 00:36:14,348
ريان"؟"

623
00:36:14,349 --> 00:36:17,166
ريان"؟" -
ريان" ليس هنا" -

624
00:36:17,167 --> 00:36:20,333
لحظة -
هل كان معكِ في المنطقة المضادة؟ -

625
00:36:20,334 --> 00:36:22,399
لا يزال هناك مع تلك الأشياء

626
00:36:22,400 --> 00:36:24,839
أُغلقت البوابة ولا يزال "ريان" هناك

627
00:36:24,840 --> 00:36:26,999
إفتحيها إذن، يجب أن نساعده

628
00:36:27,000 --> 00:36:28,839
لا -
ما الذي تعنينه بـ لا؟ -

629
00:36:30,760 --> 00:36:33,639
هذا العالم يتداعى
لوجودنا داخله حتى الآن

630
00:36:33,640 --> 00:36:36,679
لا نزال نحن وأنتِ غير متوافقين

631
00:36:36,680 --> 00:36:40,070
وجود "إيريك" هنا كان ممكناً
لكن خمسة منا؟

632
00:36:40,071 --> 00:36:42,361
هذه مواد كثيرة غير متوافقة

633
00:36:42,362 --> 00:36:44,079
تتجاوز تحملكِ

634
00:36:44,080 --> 00:36:46,297
يجب أن تدعينا نذهب الآن

635
00:36:46,298 --> 00:36:49,199
هل أنا فقط من ترى أن
 هذه المرأة مجنونة تماماً؟

636
00:36:49,200 --> 00:36:51,397
ليست "غريس" و "ترينا" من تفعلان هذا

637
00:36:51,398 --> 00:36:53,157
بالطبع هما

638
00:36:53,158 --> 00:36:55,559
إنهما مصنوعتان من طاقة السوليتراكت

639
00:36:55,560 --> 00:36:58,119
وتستطيع "هانا" الإحساس بها
فلمَ تعجزان أنتما؟

640
00:36:58,120 --> 00:36:59,839
لماذا؟

641
00:36:59,840 --> 00:37:01,600
لمَ صنعتِ كل هذا؟

642
00:37:07,880 --> 00:37:10,880
يالغبائي، بالطبع

643
00:37:11,866 --> 00:37:16,919
أردتِ ما أردتِه دائماً
أن تكوني معنا

644
00:37:18,000 --> 00:37:20,159
لذا بنيتِ عالماً ظننته سيعجبنا

645
00:37:20,160 --> 00:37:23,663
وأخذتِ أشكالاً لن نصدها

646
00:37:23,664 --> 00:37:25,709
لا تستمع إليها يا حبيبي

647
00:37:25,710 --> 00:37:28,506
لا تستغلي عاطفته
"لستِ "غريس

648
00:37:28,507 --> 00:37:32,039
كانت "غريس" الحقيقية
جميلة ومبتسمة دائماً

649
00:37:32,040 --> 00:37:35,078
وهل تعرفين كيف كانت فوق كل هذا؟
كانت شجاعة

650
00:37:35,079 --> 00:37:37,080
وكانت ستتقدمنا عبر تلك المرآة

651
00:37:38,400 --> 00:37:39,679
"ياز"

652
00:37:43,320 --> 00:37:45,943
"ريان"

653
00:37:48,800 --> 00:37:50,933
هل فعلت أنا هذا؟

654
00:37:50,934 --> 00:37:52,847
أظنكِ تعرفين

655
00:37:53,560 --> 00:37:55,637
أريد العودة للمنزل

656
00:37:55,638 --> 00:37:57,911
هانا"، لا تخافي"

657
00:37:57,912 --> 00:37:59,919
إيريك"، طمئنها"

658
00:37:59,920 --> 00:38:04,328
هانا"، نحن في مكان قريب من المنزل"

659
00:38:04,329 --> 00:38:07,959
يمكننا البقاء هنا
لم أكن لأطلب منكِ البقاء لو لم يكن آمناً

660
00:38:08,672 --> 00:38:10,272
بلى ستفعل يا أبي

661
00:38:10,872 --> 00:38:12,220
لست بخير

662
00:38:12,720 --> 00:38:14,920
لم تكن بخير منذ ماتت أمي

663
00:38:16,120 --> 00:38:18,084
وأنتِ لستِ أمي

664
00:38:18,085 --> 00:38:20,239
أيّاً كنتِ، أنا أكرهكِ

665
00:38:20,240 --> 00:38:21,680
والآن، أخرجيني

666
00:38:25,320 --> 00:38:27,439
"غراهام"

667
00:38:27,440 --> 00:38:30,181
أرتنا "ياز" و "هانا" الطريق

668
00:38:30,182 --> 00:38:34,285
ريان" هناك في خطر"
وسينهار هذا المكان

669
00:38:34,801 --> 00:38:37,039
...دكتور، أعرف ما تطلبينه مني، لكن

670
00:38:37,040 --> 00:38:38,199
لا يمكنني أن أفعلها

671
00:38:40,440 --> 00:38:44,239
ليست زوجتك، إنها أثاث بنبض

672
00:38:44,240 --> 00:38:46,919
لا تعرف ولا يمكنها أن تعرف

673
00:38:46,920 --> 00:38:48,999
غراهام" أرجوك"

674
00:38:49,000 --> 00:38:50,799
أعرف مدى صعوبة هذا بالنسبة لك

675
00:38:50,800 --> 00:38:54,150
لكن دعها وإلا سنموت جميعاً

676
00:38:55,772 --> 00:38:58,881
أعلم بأنك لا تزال تلوم نفسك
"على ما حدث لـ "غريس

677
00:38:58,882 --> 00:39:00,999
لم تكن غلطتك

678
00:39:01,000 --> 00:39:04,378
صدها أرجوك، لأنك تعرف
"بأنها ليست "غريس

679
00:39:05,080 --> 00:39:06,857
لا تتركني يا حبيبي

680
00:39:06,858 --> 00:39:07,919
ليس ثانية

681
00:39:08,728 --> 00:39:10,199
ماذا عن "ريان"؟

682
00:39:10,625 --> 00:39:12,364
إنه في مشكلة يا حبيبتي

683
00:39:12,365 --> 00:39:15,366
سيكون بخير، إنه فتى ذكي

684
00:39:18,000 --> 00:39:20,159
"هذا الواقع ينهار يا "غراهام

685
00:39:20,160 --> 00:39:21,680
إقتربتِ

686
00:39:23,100 --> 00:39:24,540
كنتِ قريبةً جداً

687
00:39:26,480 --> 00:39:27,719
...كما ترين

688
00:39:27,720 --> 00:39:29,919
ما كانت "غريس" لتسمح...
لي بأن أعرّض "ريان" للخطر

689
00:39:34,280 --> 00:39:35,600
أنتِ مزيفة

690
00:39:37,600 --> 00:39:39,000
أتمنى لو كنتِ هي، لكنكِ مزيفة

691
00:39:46,400 --> 00:39:47,594
"غريس"

692
00:39:47,595 --> 00:39:49,159
ما الذي حدث لها؟

693
00:39:49,160 --> 00:39:51,840
زائدة عن الحاجة
هل تصدقني الآن؟

694
00:39:53,001 --> 00:39:54,319
"إيريك"

695
00:39:54,320 --> 00:39:57,719
واضح أن هذه المرأة طاقة
 فضائية ستدمر العالمين

696
00:39:57,720 --> 00:39:59,848
وتنتحل هوية زوجتك المتوفية

697
00:39:59,849 --> 00:40:02,039
حان الوقت لتركها يا صاح -
لكن لا أستطيع -

698
00:40:03,400 --> 00:40:05,906
لا، بالطبع لن تستطيع

699
00:40:06,620 --> 00:40:08,140
حسناً

700
00:40:09,231 --> 00:40:11,350
تهانينا

701
00:40:11,351 --> 00:40:12,912
"يريدكِ "إيريك

702
00:40:14,160 --> 00:40:16,799
لكن أمر أخير
هذا العالم يتداعى

703
00:40:17,311 --> 00:40:18,838
ولا أظنكِ تستطيعي الإبقاء
على أكثر من شخص

704
00:40:18,839 --> 00:40:20,720
فهل متأكدة بأنه خياركِ الأفضل؟

705
00:40:24,000 --> 00:40:25,700
لأن السوليتراكت لا تحتاج زوجاً

706
00:40:26,239 --> 00:40:28,540
بل تريدين كوناً بأكمله

707
00:40:29,309 --> 00:40:32,359
شخص رأى كل شيء
وأنا ذلك الشخص

708
00:40:32,360 --> 00:40:36,679
عشت مدة أطول، ورأيت أكثر
وأحببت أكثر، وفقدت أكثر

709
00:40:37,040 --> 00:40:39,112
يمكنني أن أشارككِ كل هذا

710
00:40:39,113 --> 00:40:41,687
وأي شيء تريدين معرفته
عن أي شيء لم تملكيه

711
00:40:42,960 --> 00:40:46,479
لأنه أحمق لديه إبنة تحتاجه
... لذا دعيه يذهب

712
00:40:46,480 --> 00:40:48,360
وسأعطيكِ كل شيء...

713
00:40:52,760 --> 00:40:54,039
"لستِ "ترينا

714
00:40:54,040 --> 00:40:55,500
"أخيراً يا "إيريك

715
00:40:59,757 --> 00:41:03,228
يمكنكِ أن تكفّي عن تجسيد "ترينا" الآن
لأن هذا الكون في حالة حرجة

716
00:41:03,229 --> 00:41:07,600
وإذا إنفجر فسيأخذ المنطقة
 المضادة وكوني معه أيضاً

717
00:41:41,200 --> 00:41:44,520
لمَ يوجد ضفدع هنا؟

718
00:41:46,400 --> 00:41:48,880
"قلتِ بأن أكف عن تجسيد "ترينا

719
00:41:50,000 --> 00:41:52,080
... السوليتراكت ضفدع

720
00:41:53,000 --> 00:41:55,053
يتحدث بصوت "غريس"؟...

721
00:41:55,054 --> 00:41:57,406
شكلي الحقيقيّ لا نهائي

722
00:41:57,407 --> 00:42:00,247
لكن شكل هذا الضفدع يعجبني

723
00:42:00,248 --> 00:42:02,662
كما أعجب "غريس" سابقاً

724
00:42:02,663 --> 00:42:06,279
وكنت أفكر بأنه لم يبق
مفاجآت في هذا اليوم

725
00:42:06,280 --> 00:42:09,858
والآن، أخبريني أرجوكِ عن كونكِ

726
00:42:09,859 --> 00:42:11,879
أتظنين الكلمات ستوفيه حقه؟

727
00:42:11,880 --> 00:42:13,320
... إنه هائل جداً

728
00:42:15,356 --> 00:42:17,484
وجميل جداً...

729
00:42:18,213 --> 00:42:21,576
ويبدو بأنني لتوي ودعته

730
00:42:22,440 --> 00:42:25,288
لكن الناس ما سوف أفتقده حقاً

731
00:42:25,880 --> 00:42:29,119
أصدقائي -
سأكون هنا، وسنكون هنا معاً -

732
00:42:29,120 --> 00:42:30,881
أصدقاء -
صحيح -

733
00:42:30,882 --> 00:42:34,399
أنا والكون الواعي المتنكر كضفدع
أعز أصدقاء للأبد

734
00:42:34,778 --> 00:42:37,599
هل رأيتِ هذا؟

735
00:42:38,346 --> 00:42:39,839
لأنني لن أكون صديقة حقيقية لكِ

736
00:42:39,840 --> 00:42:41,836
لو لم أنبهكِ إلى عجزكِ
عن السيطرة على هذا

737
00:42:41,837 --> 00:42:45,479
أنتِ مخطئة، هذا مستواي
وأنا أتحكم بكل شيء هنا

738
00:42:45,480 --> 00:42:48,334
يمكنكِ أن تري إذن
بأنه لا زال يتذبذب

739
00:42:48,821 --> 00:42:51,319
وجودي هنا سيقتلنا معاً

740
00:42:51,320 --> 00:42:54,599
قد ترغبين بتواجدنا معاً
لكن لن ينفع هذا

741
00:42:54,600 --> 00:42:56,439
لن ينفع أبداً

742
00:42:56,440 --> 00:42:58,959
أنتِ تكذبين عليّ
لأنكِ تريدين المغادرة

743
00:42:59,503 --> 00:43:01,796
لا، أنا صديقتكِ

744
00:43:02,440 --> 00:43:04,479
لكن الأصدقاء يساعدون بعضهم
ليواجهوا مشاكلهم

745
00:43:04,480 --> 00:43:05,672
لا أن يتجاهلوها

746
00:43:06,466 --> 00:43:08,319
...وهذا

747
00:43:08,320 --> 00:43:11,719
وأنتِ... أشد

748
00:43:12,272 --> 00:43:17,319
الأشياء التي إختبرتها جمالاً

749
00:43:17,320 --> 00:43:20,049
ولم أرَ منكِ شيئاً بعد

750
00:43:21,546 --> 00:43:23,266
أتمنى لو كان بإستطاعتي البقاء

751
00:43:25,033 --> 00:43:27,382
لكن إذا كنا سننجو

752
00:43:27,383 --> 00:43:28,659
فينبغي أن تتركيني أذهب

753
00:43:28,660 --> 00:43:31,586
وتستمري بالعيش وحدكِ، مذهلة كما أنتِ

754
00:43:34,640 --> 00:43:36,440
أفتقدكم

755
00:43:38,200 --> 00:43:41,084
أفتقد كل شيء، كثيراً

756
00:43:41,085 --> 00:43:42,526
أعلم

757
00:43:43,819 --> 00:43:47,328
لكن لو فعلتِ هذا، فأعدكِ

758
00:43:47,329 --> 00:43:51,160
سنبقى صديقتين للأبد

759
00:43:52,226 --> 00:43:53,880
يجب أن تدعيني أذهب

760
00:43:58,120 --> 00:43:59,879
سأحلم بكِ

761
00:43:59,880 --> 00:44:02,200
هناك، دوني

762
00:44:08,600 --> 00:44:09,920
وداعاً

763
00:44:24,760 --> 00:44:29,079
رماني ضفدع، مذهل

764
00:44:35,520 --> 00:44:39,439
صخور مشتعلة، لن أعود إلى هنا ثانية

765
00:44:39,440 --> 00:44:41,659
"غراهام"

766
00:44:41,660 --> 00:44:43,747
أنت بأمان، أمسكت بك

767
00:44:44,240 --> 00:44:45,513
"غراهام"

768
00:44:49,080 --> 00:44:51,320
المكان بأكمله يتفكك

769
00:44:51,321 --> 00:44:53,342
إستمروا بالتقدم، هناك البوابة

770
00:44:53,343 --> 00:44:56,600
ماذا عن الدكتور؟
أين الدكتور؟

771
00:44:57,800 --> 00:44:59,640
قادمة

772
00:45:20,551 --> 00:45:21,919
هل نحن بأمان؟

773
00:45:22,559 --> 00:45:25,216
من السوليتراكت، نعم

774
00:45:26,073 --> 00:45:27,593
...لا أعلم ما إذا نجت

775
00:45:28,760 --> 00:45:30,524
لكنها لن تعود إلى هنا...

776
00:45:31,480 --> 00:45:32,743
مؤسف

777
00:45:33,360 --> 00:45:34,840
كونت صداقة جديدة

778
00:45:35,506 --> 00:45:37,346
كون واعي بأكمله

779
00:45:38,533 --> 00:45:40,137
وكان عليّ توديعه

780
00:46:11,782 --> 00:46:14,999
ما الذي تنويانه؟ -
حان الوقت لنعود -

781
00:46:15,000 --> 00:46:17,320
ليس في صالحنا البقاء هنا

782
00:46:19,289 --> 00:46:20,592
إلى أوسلو؟

783
00:46:21,186 --> 00:46:22,406
أوسلو، نعم

784
00:46:23,024 --> 00:46:26,919
إلى شقتنا والإنترنت والأصدقاء

785
00:46:27,659 --> 00:46:28,659
شكراً لكم

786
00:46:29,450 --> 00:46:30,450
في أي وقت

787
00:46:31,093 --> 00:46:32,093
وداعاً

788
00:46:32,706 --> 00:46:33,706
"وداعاً يا "هانا

789
00:46:42,847 --> 00:46:44,447
"هيّا يا "غراهام

790
00:46:49,213 --> 00:46:51,413
إنه فيورد جميل جداً

791
00:47:00,303 --> 00:47:02,012
أرى أن الخراف قد ذهبت

792
00:47:02,013 --> 00:47:04,244
الأرجح أنها تخطط
هيّا بنا

793
00:47:19,966 --> 00:47:21,366
هل أنت بخير؟

794
00:47:22,753 --> 00:47:24,275
بخير

795
00:47:24,276 --> 00:47:26,260
قالت "ياز" بأنك رأيت جدتي هناك

796
00:47:28,067 --> 00:47:31,187
...صحيح، ظننتها... ربما

797
00:47:33,080 --> 00:47:35,192
لكن لم تكن هي، ليس حقاً

798
00:47:36,119 --> 00:47:37,415
كانت هي

799
00:47:39,713 --> 00:47:40,953
صحيح

800
00:47:43,266 --> 00:47:45,986
أفتقدها أيضاً، طوال الوقت

801
00:47:50,500 --> 00:47:52,540
لكن لدينا بعضنا على الأقل، صحيح؟

802
00:47:53,760 --> 00:47:55,160
يا جدّي

803
00:47:58,280 --> 00:47:59,919
بمَ ناديتني؟

804
00:47:59,920 --> 00:48:02,239
لماذا؟ هل أصابك الصمم بعد أن شبت؟

805
00:48:02,743 --> 00:48:04,160
هيّا، إلى التاردس

806
00:48:59,142 --> 00:49:02,220
تسع إشارات إستغاثة
أتت من نفس الكوكب

807
00:49:02,221 --> 00:49:04,358
كان ينبغي أن أغادر -
ولمَ لم تفعل؟ -

808
00:49:04,359 --> 00:49:05,620
المعركة

809
00:49:05,621 --> 00:49:08,720
أعطيتني قدري
