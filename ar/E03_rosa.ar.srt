1
00:00:22,440 --> 00:00:28,550
Translated by .. MadNess
تـرجمـة .. إبتـهـال

1
00:00:36,440 --> 00:00:40,550
"روزا"

1
00:00:43,840 --> 00:00:47,550
 مونتغمري، ألاباما
عام 1943

2
00:01:16,140 --> 00:01:17,300
أنتِ

3
00:01:18,300 --> 00:01:19,909
لا يُسمح لكِ بالدخول من هنا

4
00:01:20,820 --> 00:01:22,900
ليس هذا مدخل الملونين

5
00:01:24,460 --> 00:01:28,379
إنزلي، وعودي إلى الخلف
وأدخلي من هناك، ذاك هو مدخلكِ

6
00:01:28,380 --> 00:01:30,339
تعلمين ذلك

7
00:01:30,340 --> 00:01:32,459
.. لا أرى داعي

8
00:01:32,460 --> 00:01:34,379
للنزول ثم الصعود ثانية من الخلف

9
00:01:34,380 --> 00:01:37,912
ليس بوجود وقوف على السلم

10
00:01:38,970 --> 00:01:41,090
كيف سأحشر نفسي بينهم؟

11
00:01:42,100 --> 00:01:44,819
..إذا لم تستخدمي الباب الخلفي

12
00:01:44,820 --> 00:01:46,139
فستترجلين من حافلتي

13
00:01:46,140 --> 00:01:48,259
سيّدي، دعني وشأني

14
00:01:48,260 --> 00:01:50,300
لا تفعل هذا من فضلك
!توقف

15
00:02:08,786 --> 00:02:10,463
يستحسن أن لا تضربني

16
00:02:10,466 --> 00:02:12,140
أخرجي من الباب

17
00:02:30,340 --> 00:02:32,099
أنت

18
00:02:32,100 --> 00:02:34,179
!أنت

19
00:02:34,180 --> 00:02:35,939
أنت! توقف

20
00:02:35,940 --> 00:02:37,660
يا إلهي

20
00:02:47,040 --> 00:02:50,660
بعد اثنتي عشرة عاماً
 1955

22
00:03:14,380 --> 00:03:15,620
تقريباً

23
00:03:18,268 --> 00:03:20,867
شفيلد؟ -
تقريباً، قريبون جداً -

24
00:03:20,870 --> 00:03:22,349
ليست شفيلد إذن؟

25
00:03:22,352 --> 00:03:24,271
تفعلين هذا عمداً، أليس كذلك؟

26
00:03:24,274 --> 00:03:25,313
من تخاطبين؟

27
00:03:25,316 --> 00:03:26,636
إذا كنتِ تقصدينني
فلم ألمس شيئاً

28
00:03:26,638 --> 00:03:28,259
أخاطب التاردس

29
00:03:28,260 --> 00:03:30,534
لأن هذه محاولتنا التاسعة

30
00:03:30,537 --> 00:03:31,659
14

31
00:03:31,660 --> 00:03:33,252
لا يمكنكِ التحكم بهذا الشيء، صحيح؟

32
00:03:33,255 --> 00:03:35,179
عذراً! بلى أستطيع

33
00:03:35,180 --> 00:03:36,539
..بالغالب، لكن

34
00:03:36,540 --> 00:03:38,819
يحدث أحياناً، كالآن
أن تتصرف من تلقاء نفسها

35
00:03:38,820 --> 00:03:40,698
أين نحن، صدقاً؟

36
00:03:40,701 --> 00:03:41,979
الأرض

37
00:03:41,980 --> 00:03:43,460
الولايات المتحدة

38
00:03:44,860 --> 00:03:47,292
عام 1955، في مونتغمري، ألاباما

39
00:03:47,295 --> 00:03:48,690
إذا كنت أقرأه بشكل صحيح

40
00:03:48,693 --> 00:03:50,698
شاشات عرض جديدة
لا زلت أتعلمها

41
00:03:50,701 --> 00:03:52,717
1955?!

42
00:03:52,720 --> 00:03:54,199
إلفيس"؟ أيمكننا أن نرى "إلفيس"؟"

43
00:03:54,200 --> 00:03:55,759
أظنه في نيويورك هذا الأسبوع

44
00:03:55,760 --> 00:03:57,079
يمكنني أن أتصل به

45
00:03:57,080 --> 00:03:58,519
"لا تملكين رقم هاتف "إلفيس

46
00:03:58,520 --> 00:04:00,759
لا تخبروا أحداً بأنني
أعرته هاتفاً متنقلاً

48
00:04:05,080 --> 00:04:06,724
ما ذلك؟

49
00:04:06,727 --> 00:04:08,185
آثار من طاقة الأرترون

50
00:04:08,188 --> 00:04:09,959
أيفترض أن نعرف ما هي طاقة الأرترون؟

51
00:04:09,960 --> 00:04:12,199
نفس الطاقة التي تعمل عليها التاردس

52
00:04:12,200 --> 00:04:14,479
لا يفترض أن أجد آثاراً منها هنا

53
00:04:14,480 --> 00:04:15,999
إلا لو كانت لنا، لكنها ليست كذلك

54
00:04:16,000 --> 00:04:17,359
وتريدين التحقق منها

55
00:04:17,360 --> 00:04:18,439
نعم، يجب أن أتحقق

56
00:04:18,440 --> 00:04:19,919
نظرة خاطفة، لكن بهدوء

57
00:04:19,920 --> 00:04:21,279
فالتاريخ حساس جداً

58
00:04:21,280 --> 00:04:22,600
سنبقى معاً

59
00:04:27,280 --> 00:04:29,424
الخمسينات على الطبيعة

60
00:04:29,427 --> 00:04:31,320
السفر عبر الزمن مذهل

61
00:04:32,320 --> 00:04:34,559
المعذرة

62
00:04:34,560 --> 00:04:36,359
المعذرة

63
00:04:36,360 --> 00:04:37,640
أوقعتِ هذه

65
00:04:42,880 --> 00:04:44,559
أبعد يدك السوداء القذرة
عن زوجتي

66
00:04:44,560 --> 00:04:47,399
!توقف -
سيّدي، تراجع من فضلك -

67
00:04:47,400 --> 00:04:48,576
هل أنت بخير يا "ريان"؟

68
00:04:48,579 --> 00:04:50,319
كنت أحاول إعادة
قفازها لها

69
00:04:50,320 --> 00:04:51,581
أهذا فتاكِ؟

70
00:04:51,584 --> 00:04:53,119
بل حفيدي في الواقع

71
00:04:53,120 --> 00:04:55,685
ماذا؟ -
حفيدي -

72
00:04:55,688 --> 00:04:58,239
لستم من هنا -
لا نريد أي مشاكل -

73
00:04:58,240 --> 00:05:00,581
لا أعرف ما القوانين
من حيث أتيتم

74
00:05:00,584 --> 00:05:01,679
لكن فتاكِ هذا

75
00:05:01,680 --> 00:05:04,079
سيتدلى من على شجرة
والحبل حول رقبته

76
00:05:04,080 --> 00:05:05,599
لو لمس امرأة بيضاء
في مونتغمري

77
00:05:05,600 --> 00:05:08,199
ماذا قلـ..؟ -
 ما المشكلة يا سيّد "ستيل"؟ -

78
00:05:08,200 --> 00:05:10,280
تراجعوا الآن
هيّا، تراجعوا

79
00:05:12,670 --> 00:05:14,759
أهؤلاء أصدقاؤكِ؟ -
لا يا سيّدي -

80
00:05:14,760 --> 00:05:16,159
أنا في إستراحة غدائي

81
00:05:16,160 --> 00:05:19,200
وأتساءل ما إذا كنت
أستطيع حل أي سوء فهم

82
00:05:20,120 --> 00:05:22,959
أعتقد بأن بدلتك
ستكون جاهزة غداً

83
00:05:22,960 --> 00:05:26,200
ستجعلها التعديلات أكثر
ملائمة يا سيّدي

84
00:05:31,707 --> 00:05:33,547
"لنذهب يا "ليزي

85
00:05:36,240 --> 00:05:37,839
هل أنت مجنون؟ -
هو من صفعني -

86
00:05:37,840 --> 00:05:39,199
ألا تقرأ الصحف؟

87
00:05:39,200 --> 00:05:41,319
"تعرف ما فعلوه بالشاب "إيمت تيل

88
00:05:41,320 --> 00:05:42,599
نحن من خارج المدينة

89
00:05:42,600 --> 00:05:44,679
"وكذلك كان "إيمت تيل

90
00:05:44,680 --> 00:05:46,439
في إجازة من الشمال

91
00:05:46,440 --> 00:05:47,600
كلمتين قالها

92
00:05:48,600 --> 00:05:50,479
لامرأة بيضاء في مسيسيبي

93
00:05:50,480 --> 00:05:52,399
وبعد ذلك

94
00:05:52,400 --> 00:05:54,639
وجدوا جثته

95
00:05:54,640 --> 00:05:55,920
في النهر

96
00:05:57,040 --> 00:05:58,639
أتريد أن تكون مكانه؟

97
00:05:58,640 --> 00:05:59,839
لا

98
00:05:59,840 --> 00:06:02,159
ألم تعلمك والدتك الأدب؟

99
00:06:02,160 --> 00:06:03,879
"وأسمعني "لا يا سيّدتي

100
00:06:03,880 --> 00:06:05,479
لا يا سيّدتي

101
00:06:05,480 --> 00:06:07,201
هل أنتم معاً؟ -
نعم -

102
00:06:07,204 --> 00:06:08,729
نحن ممتنون لكِ يا آنسة..؟

103
00:06:08,732 --> 00:06:10,239
سيّدة

104
00:06:10,240 --> 00:06:11,919
"باركس"، اسمي "روزا باركس"

105
00:06:11,920 --> 00:06:13,388
مستحيل

106
00:06:13,391 --> 00:06:14,510
تمزحين

107
00:06:14,513 --> 00:06:16,837
مذهل
"روزا باركس"

108
00:06:16,840 --> 00:06:18,999
"يسعدني لقاؤكِ يا "روزا باركس
من أشد المعجبين

109
00:06:19,000 --> 00:06:20,079
عذراً؟

110
00:06:20,080 --> 00:06:22,399
من.. أشد.. المعجبين

111
00:06:22,400 --> 00:06:23,759
بمونتغمري

112
00:06:23,760 --> 00:06:25,920
نحن.. في زيارة للمدينة

113
00:06:27,520 --> 00:06:30,479
ألديكِ توصيات للسياح أمثالنا؟

114
00:06:30,480 --> 00:06:33,839
أوصي بأن تبتعدوا عن ألاباما

115
00:06:33,840 --> 00:06:36,560
قبل أن تجدوا أنفسكم
في ورطة تعجزون عن حلها

116
00:06:40,920 --> 00:06:42,079
يا إلهي

117
00:06:42,080 --> 00:06:44,279
أتصدقون هذا؟
روزا باركس" الحقيقية"

118
00:06:44,280 --> 00:06:45,440
مذهل

119
00:06:46,680 --> 00:06:47,839
ومشكلة أيضاً

120
00:06:47,840 --> 00:06:50,519
تظهر آثار طاقة
أرترون على كل جزء منها

121
00:06:50,520 --> 00:06:52,040
لماذا؟

122
00:07:05,640 --> 00:07:06,720
لا

123
00:07:28,560 --> 00:07:30,320
دروع حماية

124
00:07:35,440 --> 00:07:38,799
"كنا في صف "روزا باركس
في الإبتدائية، أتذكر؟

125
00:07:38,800 --> 00:07:40,519
كل صفوف السنوات 4 و 5  و6

126
00:07:40,520 --> 00:07:42,199
سمّيت بأسماء شخصيات ملهمة

127
00:07:42,200 --> 00:07:43,479
هي امرأة الحافلة، صحيح؟

128
00:07:43,480 --> 00:07:45,079
أتذكر ما فعلته؟ -
نعم -

129
00:07:45,080 --> 00:07:46,759
أول امرأة سوداء تقود حافلة

130
00:07:46,760 --> 00:07:48,399
"لا يا "ريان -
ماذا؟ -

131
00:07:48,400 --> 00:07:50,759
كانت جدتك لتصاب بنوبة الآن

132
00:07:50,760 --> 00:07:53,319
كيف تدرس في صف
سمّي بإسم هذه المرأة

133
00:07:53,320 --> 00:07:54,568
ولا تعرف من تكون؟

134
00:07:54,571 --> 00:07:55,650
إنها أمريكية

135
00:07:55,653 --> 00:07:58,997
رفضت أن تترك مقعدها لراكب أبيض
على حافلة فصل الملونين

136
00:07:59,000 --> 00:08:01,079
وأُعتقلت لذلك

137
00:08:01,080 --> 00:08:03,879
بدأ إعتقالها مقاطعة
لحافلات مونتغمري

138
00:08:03,880 --> 00:08:05,719
أو سيبدأ

139
00:08:05,720 --> 00:08:09,639
اليوم الأربعاء الثلاثون
من شهر نوفمبر لعام 1955

140
00:08:09,640 --> 00:08:12,839
وغداً سترفض "روزا" ترك مقعدها

141
00:08:12,840 --> 00:08:15,839
وهذا تقريباً ما بدأ
حركة الحقوق المدنية في أمريكا

142
00:08:15,840 --> 00:08:17,319
"بقيادة "مارتن لوثر كينج

143
00:08:17,320 --> 00:08:18,999
أترون؟ لست جاهلاً كلياً

144
00:08:19,000 --> 00:08:21,359
إختلط علي أمر الحافلة فقط

145
00:08:21,360 --> 00:08:24,679
يعمل "مارتن لوثر كنج" قساً
هنا في مونتغمري الآن

146
00:08:24,687 --> 00:08:26,367
أيعرفان هو و "روزا" بعضهما؟ -
نعم -

147
00:08:27,400 --> 00:08:30,400
أيخيّل لي، أم أن المكان
أصبح أكثر هدوءاً هنا؟

148
00:08:32,920 --> 00:08:35,760
لا نضيّف الزنوج

149
00:08:40,200 --> 00:08:42,799
جيّد

150
00:08:42,800 --> 00:08:44,280
لأنني لا أتناولهم

151
00:08:45,280 --> 00:08:47,239
ولا المكسيكيون

152
00:08:47,240 --> 00:08:48,559
أتخاطبني أنا؟

153
00:08:48,562 --> 00:08:51,322
يجب أن تأكلوا في مكان آخر

154
00:08:56,760 --> 00:08:58,160
هيّا

155
00:09:05,800 --> 00:09:07,599
حسناً، اسمعوا
يمكنني التعامل مع هذا

156
00:09:07,600 --> 00:09:09,559
ويمكنكم العودة إلى التاردس
لتكونوا بأمان

157
00:09:09,560 --> 00:09:10,559
بينما تفعلين ماذا؟

158
00:09:10,560 --> 00:09:12,719
أحدد مصدر شذوذ الطاقة هذا

159
00:09:12,720 --> 00:09:14,999
نحن على بعد يوم واحد
من نقطة تحول في تاريخ الأرض

160
00:09:15,000 --> 00:09:17,200
ولا أريد لشيء أن يعيقها

161
00:09:17,966 --> 00:09:20,360
لا مشكلة في تواجدي هنا
لكن المكان أكثر خطراً عليكما

162
00:09:21,360 --> 00:09:22,879
يمكنكما أن تتركاه لي

163
00:09:22,880 --> 00:09:24,279
روزا باركس" لم تتركه"

164
00:09:24,280 --> 00:09:25,639
روزا باركس" لن تتركه"

165
00:09:25,640 --> 00:09:27,479
إذا استطاعت أن
تعيش كل حياتها هنا

166
00:09:27,480 --> 00:09:29,341
فلن تقتلني ساعتين

167
00:09:29,344 --> 00:09:31,399
لن تقتلني، صحيح؟ -
لا -

168
00:09:31,400 --> 00:09:33,039
ليس إذا قمنا بحماية بعضنا

169
00:09:33,040 --> 00:09:34,399
لا أمانع ذلك

170
00:09:34,400 --> 00:09:36,639
ما رأيكِ أيتها المكسيكية؟

171
00:09:36,640 --> 00:09:39,759
استمر بذلك وسأجعل منك بينياتا

172
00:09:39,760 --> 00:09:42,630
مركز قراءات الأرترون
على بعد كيلومترين من هنا

173
00:09:42,633 --> 00:09:43,839
هيّا -
إنتظري -

174
00:09:43,840 --> 00:09:45,799
سنتوقف في مكان آخر لنأكل
صحيح؟

175
00:09:45,800 --> 00:09:47,159
"لا وقت لدينا يا "غراهام

176
00:09:47,160 --> 00:09:49,159
ألاحظتم أن هذا يتكرر كثيراً؟

177
00:09:49,160 --> 00:09:52,199
لا أريد سوى تناول الطعام بإنتظام

178
00:09:52,200 --> 00:09:54,599
طُردنا من حانة
وهذا كل ما يُقلقك؟

179
00:09:54,600 --> 00:09:55,719
ليس هذا فحسب

180
00:09:55,720 --> 00:09:58,640
لا أظن معدتك تتوافق
"مع السفر عبر الزمن يا "غراهام

181
00:10:14,161 --> 00:10:16,042
أيمكنني مساعدتك؟

182
00:10:20,474 --> 00:10:22,673
أيوجد مشكلة؟

183
00:10:22,676 --> 00:10:27,410
لا مشكلة يا سيّدتي
لا مشكلة إطلاقاً

184
00:10:34,316 --> 00:10:37,639
هنا تلتقي إشارات الأرترون
في شركة الحافلات

185
00:10:37,642 --> 00:10:39,477
"كل الطرق تؤدي إلى "روزا باركس

186
00:10:39,480 --> 00:10:41,919
نعم، وهذا يدعو للقلق

187
00:10:41,920 --> 00:10:43,316
لنلقِ نظرة حول المكان

188
00:10:43,319 --> 00:10:45,079
لست متأكداً من هذا

189
00:10:49,331 --> 00:10:50,730
لا يوجد شيء هنا

190
00:10:50,733 --> 00:10:53,733
لمَ تغلق غرفة فارغة بالأقفال؟ -
إلا لو لم تكن فارغة  -

191
00:10:57,920 --> 00:10:59,239
لم تكن هذه هنا قبل ثانية

192
00:10:59,240 --> 00:11:00,679
جديّاً

193
00:11:00,680 --> 00:11:04,639
كانت هنا، لكن لم نرها
بسبب مرشح الإدراك

194
00:11:04,640 --> 00:11:07,000
لمَ قد يستخدم أحد هذا على حقيبة؟

195
00:11:09,489 --> 00:11:10,949
أيمكننا فتحها؟

196
00:11:10,952 --> 00:11:12,672
هذا السؤال الصحيح

197
00:11:18,269 --> 00:11:20,479
هل الجميع متحمس؟
لأنني متحمسة جداً

198
00:11:20,480 --> 00:11:21,999
لن تتحمسي إذا كانت قنبلة

199
00:11:22,000 --> 00:11:24,200
"لا تعكر الجو يا "غراهام

200
00:11:26,000 --> 00:11:29,479
ليست من الخمسينات -
كنت أعرف -

201
00:11:29,480 --> 00:11:31,199
والآن لدينا مشكلة

202
00:11:31,202 --> 00:11:33,759
لسنا الدخلاء الوحيدون
في مونتغمري

203
00:11:33,760 --> 00:11:35,320
ألديكِ فكرة عن أي من هذه الأشياء؟

204
00:11:36,384 --> 00:11:40,877
قالب بيانات
وجهاز مراقبة متعدد الإعتراضات

205
00:11:40,880 --> 00:11:42,119
لكنها بالية قليلاً

206
00:11:42,120 --> 00:11:43,679
لمَ تُركت هنا إذن؟

207
00:11:46,160 --> 00:11:50,559
هذا يفسّر إشارات الأرترون
هذه دلالة سيئة

208
00:11:50,560 --> 00:11:53,200
.. شاحن إحتياطي لـ

209
00:11:57,808 --> 00:11:59,368
هنا

210
00:12:16,560 --> 00:12:18,040
ابقوا هنا

211
00:12:23,722 --> 00:12:26,027
يا شبيه "براندو"، أتبحث عنا؟

212
00:12:26,030 --> 00:12:27,400
لست مسلحة

213
00:12:29,212 --> 00:12:31,253
أيفترض أن يمنعني
ذلك من الإطلاق عليكِ؟

214
00:12:31,256 --> 00:12:33,135
المفروض

215
00:12:33,138 --> 00:12:37,097
سلاح  نقل زمني إذن

216
00:12:37,100 --> 00:12:39,519
أشياء فظيعة، لا أطيقها -
شكراً لكِ -

217
00:12:39,520 --> 00:12:40,600
ليست مديحاً

218
00:12:41,891 --> 00:12:44,557
تستهلك طاقة كبيرة
لتنقل شيئاً عبر الزمن

219
00:12:44,560 --> 00:12:48,730
أظن كلانا يعرف بأن
سلاحك إستهلك بطاريته

220
00:12:48,733 --> 00:12:50,399
ومعي البطارية الإحتياطية

221
00:12:50,400 --> 00:12:55,079
نثرت بقايا طاقة الأرترون
في كل مكان من 1955

222
00:12:55,080 --> 00:12:56,886
وماذا تكونين؟
شرطة الأرترون؟

223
00:12:56,889 --> 00:12:58,902
قد تكونين كذلك

224
00:12:58,905 --> 00:13:01,717
كبينة زرقاء في الزقاق
أهي تاردس؟

225
00:13:01,720 --> 00:13:03,919
قد تكون كذلك
بمَ يهمك ذلك؟

226
00:13:03,920 --> 00:13:05,399
قد تساوي الكثير

227
00:13:05,400 --> 00:13:10,639
لا، لا قيمة لهذه
مستعملة، وقطعت مسافات كبيرة والمالك مهمل

228
00:13:10,640 --> 00:13:13,719
لكنها أفضل من جهاز
مناور الدوامة

229
00:13:13,720 --> 00:13:15,319
مثل الذي على رسغك

230
00:13:15,322 --> 00:13:17,089
تنقل زمني رخيص وسيء

231
00:13:19,920 --> 00:13:22,120
ما الذي تريده من "روزا باركس" إذن؟

232
00:13:23,035 --> 00:13:24,199
من؟

233
00:13:24,200 --> 00:13:26,050
أنت تتعمد إزعاجي الآن

234
00:13:26,053 --> 00:13:27,412
الشعور متبادل

235
00:13:27,415 --> 00:13:29,997
منذ متى وأنت هنا؟ -
غادري مونتغمري -

236
00:13:30,000 --> 00:13:31,999
لست أول شخص يأمرنا بذلك

237
00:13:32,002 --> 00:13:35,386
لو رأيت أي منكم ثانية
فسأقتلكم

238
00:13:36,629 --> 00:13:38,509
لا تهددني

239
00:13:44,932 --> 00:13:47,452
هيّا بسرعة، تحركوا الآن

240
00:13:51,880 --> 00:13:53,519
ما الذي تفعلينه؟

241
00:13:53,520 --> 00:13:54,960
هيّا بنا

242
00:13:57,069 --> 00:13:58,410
هل سنغادر حقاً؟

243
00:13:58,413 --> 00:13:59,893
ولا بعد مليون سنة

244
00:14:13,614 --> 00:14:16,277
مللت رؤية هذه اللوحة

245
00:14:16,280 --> 00:14:18,639
كيف سنفعلها إذن؟

246
00:14:18,640 --> 00:14:21,003
أدخل قبل أن يرانا أحد

247
00:14:21,006 --> 00:14:22,525
هذا ممتع

248
00:14:22,528 --> 00:14:24,613
آخر مرة تسللت فيها
لغرفة أحدهم عبر النافذة

249
00:14:24,616 --> 00:14:26,735
كانت لغرفة "داني بيسواس" في السنة العاشرة

250
00:14:26,738 --> 00:14:28,574
أحبطتِ توقعاتي

251
00:14:29,515 --> 00:14:30,554
لماذا؟

252
00:14:30,557 --> 00:14:34,036
داني بيسواس"؟ "
كان يرافق الأفضل

253
00:14:34,039 --> 00:14:36,160
هل إمتدحتني بالخطأ؟

254
00:14:38,160 --> 00:14:39,199
لا يهم

255
00:14:39,200 --> 00:14:41,542
لمَ لا نقضي الليلة في التاردس؟

256
00:14:41,545 --> 00:14:43,517
صديقنا ذو السلاح الزمني

257
00:14:43,520 --> 00:14:44,527
يراقبها

258
00:14:44,530 --> 00:14:46,761
لو ترددنا عليها، فسنقابله ثانية

259
00:14:46,763 --> 00:14:49,245
ولا أريد أن أراه بعد
ليس قبل أن أكتشف ما يحدث

260
00:14:49,248 --> 00:14:52,077
وهذا أفضل؟
نتسلل لنزل رخيص

261
00:14:52,080 --> 00:14:54,039
أحتاج لحظات لأفكر بما يحدث

262
00:14:54,040 --> 00:14:56,159
صحيح، مثلاً ما الذي نعرفه؟

263
00:14:56,160 --> 00:14:59,079
العام 1955، في مونتغمري

264
00:14:59,080 --> 00:15:00,079
على بعد يوم

265
00:15:00,080 --> 00:15:02,253
من رفض "روزا باركس" التخلي
عن مقعدها على الحافلة

266
00:15:02,256 --> 00:15:05,867
وفي الوقت ذاته، لدينا محتال من زمن آخر
يختبئ في مقر الحافلات

267
00:15:05,870 --> 00:15:07,479
يملك سلاح نقل زمنيّ

268
00:15:07,480 --> 00:15:11,449
أفهم كلمة "سلاح" لكن
ماذا عن "النقل الزمني"؟

269
00:15:11,452 --> 00:15:13,058
ينقلك عبر الزمن

270
00:15:13,061 --> 00:15:15,464
يصيبك بشعاعه
ويلقى بك عبر الزمن

271
00:15:15,467 --> 00:15:17,253
إلى أي زمن إختاره المستخدم

272
00:15:17,256 --> 00:15:19,117
إختار زمناً مستقبلياً بعيداً

273
00:15:19,120 --> 00:15:20,714
هذا فظيع -
نعم -

274
00:15:20,717 --> 00:15:22,756
ويستخدم جزيئات الأرترون

275
00:15:22,759 --> 00:15:25,638
ذلك بالإضافة إلى مناور الدوامة

276
00:15:25,641 --> 00:15:28,745
ما يفترض أن التاردس
لاحظته حين أتت بنا إلى هنا

277
00:15:28,748 --> 00:15:30,824
أنظن بأنه يحاول أن يقتل "روزا باركس" إذن؟

278
00:15:30,827 --> 00:15:32,039
أو يستخدم السلاح عليها؟

279
00:15:32,040 --> 00:15:34,745
إنه هنا منذ فترة
وأعد مكانا له في مقر الحافلات

280
00:15:34,748 --> 00:15:37,336
لو أراد التخلص منها
فلمَ لم يفعل؟

281
00:15:37,339 --> 00:15:39,919
بالإضافة إلى أن المفك قرأ
شيئاً آخر يحمله

282
00:15:39,920 --> 00:15:41,503
لكن أريد العودة لأتأكد

283
00:15:41,506 --> 00:15:45,425
صحيح، ما الذي درستموه عن "روزا"؟

284
00:15:45,428 --> 00:15:47,660
انتظري، انتظري، ما الذي تفعلينه؟
هذا تخريب

285
00:15:47,663 --> 00:15:50,230
سندفع ثمنه -
لا تقلق، قلم من نوع خاص -

286
00:15:50,233 --> 00:15:53,039
"لا، أبعديه فلستِ "بانكسي

287
00:15:53,040 --> 00:15:54,799
أم أنني هو؟

288
00:15:54,800 --> 00:15:59,519
تركب "روزا" الحافلة
في الأول من ديسمبر لعام 1955

289
00:15:59,527 --> 00:16:01,785
أي وقت من اليوم؟ -
المساء -

290
00:16:01,788 --> 00:16:03,239
كانت عائدة للمنزل من عملها

291
00:16:03,240 --> 00:16:05,028
أذكر ذلك لأن الناس
قالوا بأنها لم تقف

292
00:16:05,030 --> 00:16:06,950
لأنها كانت مرهقة
بعد العمل، لكن لم يكن صحيحاً

293
00:16:06,952 --> 00:16:07,995
أين كانت تعمل؟

294
00:16:07,998 --> 00:16:10,265
أظنه في متجر
كالمتاجر الشاملة ذات الأقسام

295
00:16:10,268 --> 00:16:11,347
لا، لا ، لحظة

296
00:16:11,350 --> 00:16:13,397
سابقاً قالت لذلك
"السفيه الذي صفع "ريان

297
00:16:13,400 --> 00:16:15,089
"ستكون بدلتك جاهزة غداً"

298
00:16:15,092 --> 00:16:18,019
هذه هي، إنها تعمل بإصلاح الملابس
كانت خيّاطة

299
00:16:18,022 --> 00:16:21,870
أعني بأنها الآن خياطة
لم أعتد العيش بالماضي

300
00:16:24,960 --> 00:16:26,719
للحمام -
جديّاً؟ -

301
00:16:26,720 --> 00:16:27,886
جديّاً جداً

302
00:16:31,280 --> 00:16:33,200
لا يا دكتور، الجدار

303
00:16:36,769 --> 00:16:38,560
لا يملك "بانكسي" واحداً كهذا

304
00:16:39,752 --> 00:16:40,831
أم أملكه؟

305
00:16:42,764 --> 00:16:45,105
أيها الضابط، كيف أخدمك؟

306
00:16:45,108 --> 00:16:46,708
أيمكنني الدخول يا سيّدتي؟

307
00:16:48,183 --> 00:16:50,120
"سيّدتي"
لم أعتده بعد

308
00:16:51,120 --> 00:16:52,636
تفضل يا عزيزي

309
00:16:52,639 --> 00:16:54,262
أراد ضابط الشرطة
أن يدخل

310
00:16:54,264 --> 00:16:55,895
ولم يرَ داعياً
ليُعرّف بإسمه

311
00:16:55,897 --> 00:16:57,877
هل من مشكلة أيها الضابط.. ؟

312
00:16:57,880 --> 00:17:00,839
ميسون"، من شرطة مونتغمري"

313
00:17:01,975 --> 00:17:04,439
كنت لأعرض عليك كوب شاي
لكن ينقص الغرفة خدمات ملائمة

314
00:17:04,441 --> 00:17:07,203
سأترك لهم ملاحظة بذلك -
بريطانية؟ -

315
00:17:07,206 --> 00:17:08,759
كيف عرفت؟

316
00:17:08,760 --> 00:17:10,800
تضايق بعض الأشخاص منكم

317
00:17:10,803 --> 00:17:12,222
وكيف ضايقناهم؟

318
00:17:12,225 --> 00:17:15,008
هل تعرفان إثنان من النغول؟

319
00:17:15,011 --> 00:17:19,039
فتى زنجي وفتاة مكسيكية؟

320
00:17:19,040 --> 00:17:21,439
لا أعرف أحداً بهذا الوصف

322
00:17:23,077 --> 00:17:26,338
كان الزنجي يتجول مفتعلاً شجارات

323
00:17:26,341 --> 00:17:29,105
مع مواطنين محترمين

324
00:17:30,771 --> 00:17:35,570
وتعلمون بأن إيواء الملونين
في غرفة كهذه يعتبر جنحة

325
00:17:35,573 --> 00:17:38,324
لا نأوي أحداً لا يحق له التواجد هنا

327
00:17:42,545 --> 00:17:44,355
ما الذي تفعلونه هنا في مونتغمري؟

328
00:17:44,358 --> 00:17:48,717
أتينا لنبيع إختراعاً
نعم

329
00:17:48,720 --> 00:17:51,760
.. إنه.. هاتف

330
00:17:52,874 --> 00:17:57,219
يشغل الموسيقى، وكاميرا

331
00:17:57,222 --> 00:17:59,050
تلتقط صوراً

332
00:17:59,053 --> 00:18:00,520
وروزنامة كذلك

333
00:18:01,464 --> 00:18:03,517
ويرسل رسائل

334
00:18:03,520 --> 00:18:04,880
يبدو سخيفاً

335
00:18:06,324 --> 00:18:08,403
ما اسمك يا سيّدي؟

336
00:18:08,406 --> 00:18:13,649
"ستيف جوبز"

337
00:18:13,652 --> 00:18:16,605
أتقلل من إحترامي يا سيّد "جوبز"؟

338
00:18:16,608 --> 00:18:20,607
ما كان "ستيف جوبز" ليقلل  من إحترام
ضابط شرطة مونتغمري يا سيّدي

340
00:18:37,929 --> 00:18:43,529
غادرا حالما تتمان عملكما هنا

341
00:18:49,807 --> 00:18:52,127
لم أحبه

342
00:18:54,000 --> 00:18:56,605
كرهت هذا المكان

343
00:18:56,608 --> 00:18:58,727
أعرف

344
00:18:58,730 --> 00:19:01,191
أن تكون شاهداً على التاريخ يحدث

345
00:19:01,194 --> 00:19:04,402
"هذا ليس تاريخاً يا "ياز
نحن مختبئان خلف النفايات

346
00:19:06,211 --> 00:19:09,690
أعمل بجد لأضبط أعصابي
في كل ثانية أقضيها هنا

347
00:19:09,693 --> 00:19:13,052
كان بإمكاني أن أصفع
ذلك الرجل حالما وصلنا

348
00:19:13,055 --> 00:19:15,980
حمداً لله أن جدتي علمتي
كيف أضبط غضبي

349
00:19:17,148 --> 00:19:19,738
لا تمنحهم سبباً -
صحيح -

350
00:19:20,731 --> 00:19:23,770
نفس ما يقوله لي أبي -
نعم، كما ترين -

351
00:19:23,773 --> 00:19:27,878
ليس وكأن "روزا باركس" ستمحو
العنصرية من العالم للأبد

352
00:19:27,881 --> 00:19:30,734
وإلا كيف يتم إيقافي من الشرطة

353
00:19:30,737 --> 00:19:32,331
أكثر من أصحابي البيض؟

354
00:19:32,334 --> 00:19:34,373
بإستثناء هذه الشرطية

355
00:19:34,376 --> 00:19:37,527
قولي بأنكِ لا تتعرضين للمضايقة -
بالطبع أتعرض لها -

356
00:19:37,530 --> 00:19:39,489
خاصة في العمل

357
00:19:39,492 --> 00:19:41,735
ينادونني "الباكستانية" حين
أباشر قضايا أسرية

358
00:19:41,738 --> 00:19:44,488
أو "الإرهابية" في طريقي من المسجد

359
00:19:44,491 --> 00:19:46,600
نعم، بالضبط

360
00:19:46,603 --> 00:19:49,082
لكن لن ينتصر هؤلاء الأشخاص

361
00:19:49,085 --> 00:19:50,519
إستطعت أن أنضم للشرطة

362
00:19:50,520 --> 00:19:54,759
"لأن أشخاصاً مثل "روزا باركس
حاربوا هذه المعارك لأجلي، ولأجلنا

363
00:19:54,760 --> 00:19:57,800
وبعد 53 عاماً، سيتولى
الرئاسة شخص أسود

364
00:19:59,240 --> 00:20:01,730
من يعرف أين سيصلون
بعد 50 عاماً أخرى

365
00:20:02,888 --> 00:20:04,368
هذا تغيير حقيقي

366
00:20:06,360 --> 00:20:09,799
ماذا؟

367
00:20:09,800 --> 00:20:11,792
هل ولدتِ بهذا التفاؤل؟

368
00:20:11,795 --> 00:20:15,199
أظن ذلك
لا بد بأنها جيناتي المكسيكية

369
00:20:18,280 --> 00:20:20,840
"ياز"
"ريان"

370
00:20:25,320 --> 00:20:28,338
أين كنا؟
نحتاج أكبر قدر من المعلومات

371
00:20:28,341 --> 00:20:31,180
إذا كنا سنحمي "روزا" فيجب
أن نعرف حقائق أكثر عن حياتها

372
00:20:31,183 --> 00:20:33,352
عنوان المنزل، والروتين اليومي

373
00:20:33,355 --> 00:20:37,079
أين تعمل، وأي طريق تسلك
وفي أي كنيسة تصلي

374
00:20:37,080 --> 00:20:39,688
وكذلك اسم السائق الذي عارضته

375
00:20:39,691 --> 00:20:41,159
"أعرف هذه، اسمه "جيمس بليك

376
00:20:41,160 --> 00:20:42,199
كيف تعرف هذا؟

377
00:20:42,200 --> 00:20:46,391
من جدتك، حين علمت بأنني
سائق حافلة، قالت لي

378
00:20:46,394 --> 00:20:48,863
"يستحسن أن لا تكون مثل "جيمس بليك

379
00:20:48,866 --> 00:20:50,782
"الأفعى بليك"
هكذا كانت تسميه

380
00:20:50,785 --> 00:20:52,136
وسألتها من يكون

381
00:20:52,139 --> 00:20:54,519
وقالت بأنه أساء لسمعة
جميع سائقي الحافلات

382
00:20:54,522 --> 00:20:56,017
أقالت لك هذا بعد أول لقاء؟

383
00:20:56,019 --> 00:20:58,313
نعم -
إنها متعصبة -

384
00:20:58,316 --> 00:21:00,399
تلك جدتي -
نعم -

385
00:21:00,400 --> 00:21:03,239
كان لديها قميصاً
مكتوب عليه

386
00:21:03,240 --> 00:21:05,239
"روح روزا"

387
00:21:05,240 --> 00:21:06,960
.... و

388
00:21:08,080 --> 00:21:09,880
أتمنى لو كانت هنا

389
00:21:14,800 --> 00:21:17,479
لا أتمنى ذلك
كانت لتسبب شغباً

390
00:21:17,480 --> 00:21:21,160
نعم -
"حسناً، "عملية روزا باركس -

391
00:21:39,157 --> 00:21:41,276
وجدت مقر عملها

392
00:21:41,279 --> 00:21:43,180
متجر مونتغمري الشامل

393
00:21:43,183 --> 00:21:46,563
وإذا كان دليل الهاتف صحيحاً
فهذا عنوان سكنها

394
00:21:46,566 --> 00:21:51,852
حسناً، ومسارات هذه الحافلات
لا تمر بمتجر "روزا" أو بيتها

395
00:21:51,855 --> 00:21:53,599
..لكن هذه

396
00:21:53,602 --> 00:21:54,641
تمر

397
00:21:54,644 --> 00:21:58,157
عظيم، وإذا إستطعنا أن نجد
مسار "روزا" وجدول تنقلها اليوم

398
00:21:58,160 --> 00:22:00,039
فيمكننا مراقبتها غداً

399
00:22:00,040 --> 00:22:01,800
من مستعد لركوب الحافلة؟

400
00:22:05,360 --> 00:22:06,799
المعذرة

401
00:22:06,800 --> 00:22:08,199
عذراً

402
00:22:08,200 --> 00:22:09,600
حسناً يا دكتور

403
00:22:11,240 --> 00:22:14,399
هذا الطريق أحد ثلاثة
"بين بيت "روزا

404
00:22:14,400 --> 00:22:15,559
ومقر عملها

405
00:22:15,560 --> 00:22:17,191
وأظن هذا أقصرها

406
00:22:17,194 --> 00:22:19,639
لذا من الأرجح أن
تأخذ هذا ليلة غد

407
00:22:19,640 --> 00:22:21,559
لكن لا يمكن أن نعرف في أي وقت

408
00:22:21,560 --> 00:22:23,400
إلا لو تبعناها طوال اليوم

409
00:22:26,200 --> 00:22:28,639
مكاني هنا، في مؤخرة الحافلة

410
00:22:28,640 --> 00:22:30,919
يا لخجلي

411
00:22:30,920 --> 00:22:32,519
لا ينبغي أن تُجبر على ذلك

412
00:22:32,520 --> 00:22:34,400
"أوافقك، أنا آسفة يا "ريان

413
00:22:35,600 --> 00:22:37,959
سمح لي السائق بالركوب من الباب الأمامي

414
00:22:37,960 --> 00:22:39,972
ما الذي يعنيه ذلك بالنسبة لمكان جلوسي؟

415
00:22:41,160 --> 00:22:44,120
واضح بأنه لا يوجد الكثير
من الباكستانيين هنا

416
00:22:45,160 --> 00:22:47,960
هل تطلق كلمة "ملون" فقط
على "السود" في 1955؟

417
00:22:49,360 --> 00:22:51,959
أعتقد بأنني سأضع مؤخرتي
الجنوب آسيوية/المكسيكية

418
00:22:51,960 --> 00:22:54,200
في مكان البيض، وسأرى
ما سيحدث بعدها

419
00:22:55,798 --> 00:22:57,877
ركوب الحافلة في مونتغمري

420
00:22:57,880 --> 00:22:59,520
أوقاتاً ممتعة

421
00:23:09,040 --> 00:23:10,919
هذا مقر عملها

422
00:23:10,920 --> 00:23:12,988
لا بد بأن هذه محطتها

423
00:23:12,991 --> 00:23:14,190
ممتاز

424
00:23:14,193 --> 00:23:17,300
يمكننا أن ننتظر هنا، ونركب
الحافلة معها بعد أن تنهي عملها

425
00:23:17,303 --> 00:23:18,663
لنتحدث قليلاً

426
00:23:23,680 --> 00:23:25,479
مرحباً

427
00:23:25,480 --> 00:23:26,879
تسعدني مقابلتكِ ثانية

428
00:23:26,880 --> 00:23:29,120
السيّدة "باركس"، صحيح؟ -
نعم -

429
00:23:29,123 --> 00:23:32,136
ساعدتِنا في وقت سابق اليوم
بسوء الفهم الذي حصل

430
00:23:32,139 --> 00:23:33,479
أتذكر

431
00:23:33,480 --> 00:23:35,417
بريطانيون -
صحيح -

432
00:23:35,420 --> 00:23:37,579
الأمر الطريف
ولن تصدقي هذا

433
00:23:37,582 --> 00:23:40,477
لكننا نجري بحثاً تسويقياً
لشركات الحافلات

434
00:23:40,480 --> 00:23:42,305
ونبحث عن عادات تنقل الأشخاص

435
00:23:42,308 --> 00:23:45,679
أجيبي على الأسئلة
لتدخلي السحب على جائزة

436
00:23:45,680 --> 00:23:48,319
هل تركبين هذه الحافلة كل يوم؟

437
00:23:48,320 --> 00:23:50,759
معظم الأيام، ودائماً في نفس الموعد

438
00:23:50,760 --> 00:23:52,279
وأين تسكنين؟

439
00:23:52,280 --> 00:23:54,400
في كليفلاند كورت، المحطة القادمة

440
00:23:56,680 --> 00:24:01,840
سيّدتي، إذا جلستِ هنا
فسيتحتم علينا أن ننتقل

441
00:24:03,160 --> 00:24:04,399
ما الذي تعنينه؟

442
00:24:04,400 --> 00:24:11,239
إذا إحتاج البيض لمقاعد، ينبغي
أن أعطيهم مقعدي بموجب القانون

443
00:24:11,240 --> 00:24:13,159
هذا القسم الأوسط للملونين

444
00:24:13,160 --> 00:24:15,039
إذا لم يحتاجه البيض

445
00:24:15,040 --> 00:24:16,519
هذا ليس صحيحاً

446
00:24:16,520 --> 00:24:19,959
أخبر شركتك بذلك

447
00:24:19,960 --> 00:24:22,479
إذا فزت بالسحب

448
00:24:22,487 --> 00:24:26,007
فهل سيمنحني ذلك الحق
في أن أجلس حيثما أردت في الحافلة

449
00:24:27,080 --> 00:24:28,280
لا

450
00:24:30,296 --> 00:24:32,117
توقعت

451
00:24:32,120 --> 00:24:33,960
هذه محطتي

452
00:24:37,398 --> 00:24:39,357
سألحق بها

453
00:24:39,360 --> 00:24:41,159
وأرى ما يمكنني إكتشافه

454
00:24:41,160 --> 00:24:43,759
سأقابلكم في النزل

455
00:24:43,760 --> 00:24:45,599
"ريان"

456
00:24:45,600 --> 00:24:47,253
كن حذراً

457
00:24:47,256 --> 00:24:48,487
حسناً

458
00:24:50,238 --> 00:24:52,717
هل سيكون بخير؟ -
آمل ذلك -

459
00:24:52,720 --> 00:24:55,880
غراهام"، أيمكنك أن تجد"
السائق "جيمس بليك"؟

460
00:24:56,730 --> 00:24:59,519
نعم، سأتحدث مع الرجل في المقدمة

461
00:24:59,520 --> 00:25:00,919
وأسأله عن حانتهم

462
00:25:00,920 --> 00:25:02,977
ياز"، أيمكنكِ أن ترتبي زمنياً"

463
00:25:02,980 --> 00:25:05,719
بما سيحدث في هذا الوقت
من مساء الغد؟

464
00:25:05,720 --> 00:25:07,199
حسناً، وما الذي ستفعلينه؟

465
00:25:07,200 --> 00:25:10,920
سأتحدث مع صاحبنا
وأخبره بأن يتنحى عن طريق التاريخ

466
00:25:23,480 --> 00:25:27,080
"ألاحق "روزا باركس
لا أعرف رأيي بهذا

467
00:25:29,714 --> 00:25:31,480
يستحسن أن لا تكون تلاحقني

468
00:25:33,386 --> 00:25:35,280
أريد المساعدة -
بماذا؟ -

469
00:25:37,440 --> 00:25:39,160
المقاومة

470
00:25:40,440 --> 00:25:45,999
وكيف أعرف بأنك لست جاسوساً
للشرطة أو للفيدراليين؟

471
00:25:46,000 --> 00:25:47,959
لأنه لو أرسلوا جاسوساً

472
00:25:47,960 --> 00:25:50,750
فسيرسلون شخصاً يمكنه
تتبعكِ دون أن تلاحظيه

473
00:25:50,753 --> 00:25:52,959
ولا يتحدث بلكنة بريطانية

474
00:25:52,960 --> 00:25:56,279
وأيضاً.. لا أظنهم يعرفون
أحد من السود

475
00:26:01,360 --> 00:26:03,560
أتعرف كيف تقدم القهوة؟

477
00:26:45,920 --> 00:26:49,119
مؤسف، أرسلت كل معداتك
لمكان لا يعلمه إلا الله

478
00:26:49,120 --> 00:26:52,919
القرن التاسع والسبعون
بحسب إعدادات السلاح

479
00:26:52,920 --> 00:26:55,559
والذي، بالمناسبة، يسخن بسرعة

480
00:26:55,560 --> 00:26:57,759
رخيص وسيء

481
00:26:57,760 --> 00:26:59,280
والآن نحن متعادلين

482
00:27:00,680 --> 00:27:02,720
الأهم أولاً

483
00:27:04,320 --> 00:27:06,279
أخبرني عن ستورمكيج

484
00:27:06,280 --> 00:27:07,599
ستورم ماذا؟

485
00:27:07,600 --> 00:27:09,799
كاذب سيء

486
00:27:09,800 --> 00:27:10,879
على رسغك

487
00:27:10,880 --> 00:27:12,839
معرّف من ستورمكيج

488
00:27:12,840 --> 00:27:15,902
أشد السجون حراسة
في هذا الجزء من الكون

489
00:27:15,905 --> 00:27:17,399
وليس في هذا الزمن، بالطبع

490
00:27:17,400 --> 00:27:20,319
لكن هنا يظهر دور
مناور الدوامة كما أظن

491
00:27:20,320 --> 00:27:21,639
مذهل ما يمكن أن تعرفه

492
00:27:21,640 --> 00:27:24,359
إذا كنت مستعداً للعمل
والمقايضة داخل ذلك السجن

493
00:27:24,360 --> 00:27:25,919
هروب أم تسريح؟

494
00:27:25,920 --> 00:27:27,399
قضيت محكوميتي

495
00:27:27,400 --> 00:27:29,999
أُعيد تأهيلي

496
00:27:30,000 --> 00:27:32,159
بأي تهمة أُعتقلت؟

497
00:27:32,160 --> 00:27:35,879
لو أخبرتكِ، فقد يغيّر ذلك نظرتكِ لي

498
00:27:35,880 --> 00:27:38,760
كنت شاباً، ولم يتأذى أحد

499
00:27:39,880 --> 00:27:42,079
لكن قُتل بعض الأشخاص

500
00:27:42,080 --> 00:27:44,720
بضع مئات منهم، أو ألف على الأكثر

501
00:27:46,480 --> 00:27:47,840
2,000

502
00:27:50,560 --> 00:27:52,056
وكان سيئاً كفاية

503
00:27:52,059 --> 00:27:54,576
ليضع السجن قيداً عصبياً في دماغك

504
00:27:54,579 --> 00:27:57,159
قبل أن يعيدك للكون

505
00:27:57,160 --> 00:27:58,920
وكيف تعرفين هذا؟

506
00:28:01,440 --> 00:28:03,919
من أنتِ؟ -
هذا ماسح ممتاز -

507
00:28:03,920 --> 00:28:06,159
ظننت بأنني لاحظته
في أول لقاء لنا

508
00:28:06,160 --> 00:28:08,719
ثم بدأ يتضح الأمر، إذ كنا نتساءل

509
00:28:08,720 --> 00:28:11,799
من الواضح أن لديك مشكلة
مع "روزا" فلمَ لم تقتلها؟

510
00:28:11,800 --> 00:28:14,359
لكن السبب.. لأنك لا تستطيع

511
00:28:14,360 --> 00:28:19,126
القيد العصبي يعني أن لا تستطيع
 أن تقتل أو تؤذي أي كائن حي

512
00:28:19,129 --> 00:28:22,319
فهو يمنعك مهما كانت رغبتك بالمحاولة

513
00:28:22,320 --> 00:28:23,960
.. لذا حتى وإن فعلت هذا

514
00:28:24,939 --> 00:28:27,040
.. وهشمت مناور الدوامة

515
00:28:29,080 --> 00:28:31,719
نعم، هذا هو

516
00:28:31,720 --> 00:28:34,920
بدأ بالعمل، مرتبط بكيمياء دماغك

517
00:28:36,520 --> 00:28:39,479
لا يمكنك إيذائي

518
00:28:39,480 --> 00:28:41,319
بقدر رغبتك بذلك

519
00:28:41,320 --> 00:28:42,376
خير لك أن تتصرف بلطف معي

520
00:28:42,379 --> 00:28:44,939
لأنني أملك الوحيد بالخروج من هذا الزمن

521
00:28:46,000 --> 00:28:49,374
مجرم مُقيّد، يُطلق سراحه

522
00:28:49,377 --> 00:28:51,217
وتأتي إلى هنا

523
00:28:52,600 --> 00:28:54,159
لماذا؟

524
00:28:54,160 --> 00:28:55,959
يحق لي ممارسة هواياتي

525
00:28:55,960 --> 00:28:58,359
و"روزا باركس" أحدها؟

526
00:28:58,360 --> 00:29:00,879
من هنا بدأت تسوء الأمور

527
00:29:00,880 --> 00:29:02,880
وتعتقد أن بإمكانك تصحيحها؟

528
00:29:05,160 --> 00:29:07,719
كان لدي الكثير من الوقت
لأفكر وأنا في ستورمكيج

529
00:29:07,720 --> 00:29:11,560
وأدركت بأن الأفعال البسيطة
هي ما يغير العالم

530
00:29:12,840 --> 00:29:14,519
ما اسمك؟

531
00:29:14,520 --> 00:29:15,999
"كراسكو"

532
00:29:16,000 --> 00:29:17,479
لا يعجبني

533
00:29:17,480 --> 00:29:21,439
اسمع يا "كراسكو"، سأحذرك
لمرة واحدة فقط، إذهب لمكان آخر

534
00:29:21,440 --> 00:29:23,319
إبحث عن شاطئ
إقرأ كتاباً

535
00:29:23,320 --> 00:29:26,920
لأنك مجرم فقد أدواته
وفقد أسلحته

536
00:29:28,173 --> 00:29:29,719
أتظنين ذلك يحدث فرقاً؟

537
00:29:29,720 --> 00:29:34,559
يتغيّر التاريخ حين لا
تحدث الأشياء كما ينبغي

538
00:29:34,560 --> 00:29:36,359
تعني أحداث الغد

539
00:29:36,360 --> 00:29:37,560
لن تفلح

540
00:29:38,485 --> 00:29:39,760
ليس بوجودي

541
00:29:42,920 --> 00:29:44,360
حسناً، سنرى

542
00:29:54,047 --> 00:29:58,247
هذا "ريان سينكلير" من إنجلترا

543
00:29:59,440 --> 00:30:04,280
أفكر بأن يصبح عضواً
في مجلس الشباب

544
00:30:05,495 --> 00:30:08,306
سمحت له بأن ينصت
ويقدم لنا القهوة

545
00:30:09,540 --> 00:30:12,800
"هذا زوجي "باركس

546
00:30:14,410 --> 00:30:16,130
"وهذا السيّد "فريد غراي

547
00:30:17,235 --> 00:30:22,798
وهذا الدكتور "كينج" من
كنيسة دكستر أفنيو المعمدانية

548
00:30:22,801 --> 00:30:27,437
ماذا؟ "مارتن لوثر كينج"؟ -
هذا صحيح -

549
00:30:27,440 --> 00:30:31,306
يا إلهي، أنت هو
جدتي تحبك

550
00:30:31,309 --> 00:30:35,597
جدتك؟ -
نعم، جدتي -

551
00:30:35,600 --> 00:30:38,559
تحب السيّدات الأكبر سناً
"مواعظك يا "مارتن

552
00:30:38,560 --> 00:30:42,371
لن يعوزك زوجة أبيضّ شعرها في ألاباما

553
00:30:42,374 --> 00:30:44,134
هل ترتاد كنيسة ديكستر أفنيو؟

554
00:30:45,200 --> 00:30:47,600
لا، توفيت مؤخراً

555
00:30:48,800 --> 00:30:51,478
آسف لمصابك يا بنيّ

556
00:30:51,481 --> 00:30:54,600
شكراً لك، شكراً لك
"مارتن لوثر كينج"

557
00:30:55,626 --> 00:30:57,759
سيسعدها أن تعرف
بأنك قلت هذا

558
00:30:57,760 --> 00:31:00,189
"ريان" -
"المعذرة يا دكتور "كينج -

559
00:31:00,192 --> 00:31:01,959
"نعم يا "روزا باركس

560
00:31:01,960 --> 00:31:03,599
!مذهل

561
00:31:03,600 --> 00:31:07,240
أتريد أن تقدم القهوة الآن؟ -
نعم -

562
00:31:19,829 --> 00:31:22,519
أتقول بأنك سائق حافلة أيضاً في إنجلترا؟

563
00:31:22,520 --> 00:31:23,839
إنه إمتياز، أليس كذلك؟

564
00:31:23,840 --> 00:31:26,679
أن توصل الناس إلى حيث يريدون
وتكون جزءاً من ذلك المجتمع

565
00:31:26,680 --> 00:31:28,839
أفهم بأنك لا تتعامل مع

566
00:31:28,840 --> 00:31:30,920
الفصل بين الملونين والبيض؟

567
00:31:32,240 --> 00:31:33,840
لا

568
00:31:34,544 --> 00:31:36,693
لا، لا
لا نفعل ذلك

569
00:31:36,696 --> 00:31:38,279
أتؤيد ذلك يا "جيم"؟

570
00:31:38,280 --> 00:31:41,220
هذه هي الحال
مهما علت شكواهم

571
00:31:41,223 --> 00:31:42,640
لا شيء سيتغير

572
00:31:45,202 --> 00:31:47,001
وستعود لذلك غداً كما أفترض

573
00:31:47,004 --> 00:31:49,564
لا، بل سأذهب للصيد
في ميل كريك

574
00:31:51,840 --> 00:31:55,719
لا يمكن ذلك
غداً الأول من ديسمبر

575
00:31:55,720 --> 00:31:57,368
ماذا؟ -
بالطبع -

576
00:31:57,371 --> 00:31:59,837
إنه الأول من ديسمبر، صحيح؟
يعتبر يوم عمل

577
00:31:59,840 --> 00:32:00,919
تغير جدول المناوبة

578
00:32:00,922 --> 00:32:03,362
مر بي زميل من القسم
وزف لي البشرى

579
00:32:10,286 --> 00:32:12,406
هل حصلت على ما تريده هذه الليلة؟

580
00:32:16,248 --> 00:32:17,805
لم أكن أعرف ما أريد

581
00:32:19,548 --> 00:32:21,357
لكن نعم

582
00:32:21,360 --> 00:32:23,251
مقابلتكم يا رفاق

583
00:32:23,254 --> 00:32:25,574
والإنصات لحديثكم
أعجز عن تصديقه

584
00:32:27,408 --> 00:32:29,727
ستتحسن الأمور كما تعلمين

585
00:32:29,730 --> 00:32:31,290
.. لن تكون مثالية، لكن

586
00:32:33,080 --> 00:32:34,200
أفضل

587
00:32:36,665 --> 00:32:38,320
آمل ذلك

588
00:32:39,680 --> 00:32:41,160
القضية تستحق النضال

589
00:32:43,613 --> 00:32:45,213
شكراً لكِ

590
00:32:46,395 --> 00:32:48,235
مني ومن جدتي

591
00:32:49,525 --> 00:32:51,560
لم أفعل شيئاً

592
00:32:57,278 --> 00:32:58,798
طابت ليلتكِ يا سيّدتي

593
00:33:02,017 --> 00:33:04,880
على الأقل إستطعت أن
أجرد "كراسكو" من سلاحه

594
00:33:06,404 --> 00:33:08,723
جيمس بليك" مجاز غداً"

595
00:33:08,726 --> 00:33:10,917
ماذا؟ لكن لا يمكن ذلك

596
00:33:10,920 --> 00:33:12,519
هذا ما قلته

597
00:33:12,520 --> 00:33:14,704
والغريب أنه لم يستمع لي

598
00:33:14,707 --> 00:33:16,746
صاحبكِ يتدخل بالأحداث

599
00:33:16,756 --> 00:33:21,876
"أعاد تعيين جدول "بليك
"لسائق يدعى "إلياس غريفن

600
00:33:21,879 --> 00:33:25,056
أفعال بسيطة
"هذا ما كان يفعله "كراكوس

601
00:33:25,059 --> 00:33:28,142
إنه ذكي كما ترون
سأقرّ له بذلك، وهو يعرف

602
00:33:28,145 --> 00:33:32,345
لا يخطط للقتل أو التدمير
أو الإخلال بالتاريخ

603
00:33:32,348 --> 00:33:36,884
بل ينوي إعطاؤه دفعة
تكفي لإلغاء الحدث

604
00:33:36,887 --> 00:33:39,850
ما يكفي لإعاقة العجلات
وإزاحتها عن السكة

605
00:33:39,853 --> 00:33:41,719
والآن أصبحت أخلط إستعارات المواصلات

606
00:33:41,720 --> 00:33:44,319
لكن لم يضع بحسبانه
أننا سنبقيه في مكانه

607
00:33:44,320 --> 00:33:45,728
وكيف سنفعل ذلك إذن؟

608
00:33:48,560 --> 00:33:51,559
نعرف مهمتنا الآن

609
00:33:51,560 --> 00:33:53,960
نحافظ على سلامة التاريخ

610
00:33:54,948 --> 00:33:56,423
لن نغيره

611
00:33:56,426 --> 00:34:00,181
بل نحميه ممن يود الإخلال به

612
00:34:00,184 --> 00:34:04,165
غداً سنحرص على
أن تركب "روزا" الحافلة

613
00:34:04,168 --> 00:34:06,159
"التي يقودها "جيمس بليك

614
00:34:06,160 --> 00:34:08,600
وأن تكون الحافلة مكتظة
"لتجلس "روزا

615
00:34:08,603 --> 00:34:10,759
حين يُطلب منها أن
تترك مقعدها للركاب البيض

616
00:34:10,760 --> 00:34:12,039
ريان"، لا تعبث بهذا"

617
00:34:12,040 --> 00:34:14,399
كيف يعمل؟ -
الشاحن هنا -

618
00:34:14,400 --> 00:34:16,879
وتدير هذه لضبط
وجهة الإنتقال

619
00:34:16,880 --> 00:34:20,110
بسيط جداً، لكن مميت
والآن، أيمكن أن نركز؟

620
00:34:20,113 --> 00:34:22,039
كيف سنحافظ على سلامة التاريخ

621
00:34:22,040 --> 00:34:24,599
إذا كان سيذهب "جيمس بليك" للصيد؟

622
00:34:24,600 --> 00:34:27,162
وسائق آخر سيستلم مساره؟

623
00:34:27,165 --> 00:34:28,679
لديّ فكرة

624
00:34:28,680 --> 00:34:29,759
نفس الفكرة؟

625
00:34:29,760 --> 00:34:32,360
مقاطعة صيده -
الفوز بالسحب -

626
00:34:35,309 --> 00:34:37,673
إلياس غريفن"؟" -
نعم -

627
00:34:37,676 --> 00:34:43,319
تهانينا، أنت الرابح المحظوظ
بسباق السحب لهذا القرن

628
00:34:43,320 --> 00:34:45,319
لا أذكر المشاركة بأي مسابقات

629
00:34:45,320 --> 00:34:48,359
ربحت رحلة مدفوعة التكاليف
إلى لاس فيغاس

630
00:34:48,360 --> 00:34:50,359
وتذاكر في الصف الأمامي
"لعرض "فرانك سيناترا

631
00:34:50,360 --> 00:34:52,999
وتصاريح النخبة لمقابلة "فرانك" نفسه

632
00:34:53,000 --> 00:34:56,603
"زوجتي تحب "سيناترا -
مذهل! من كان ليتوقع ذلك؟ -

633
00:34:56,606 --> 00:34:59,757
بشرط واحد
يجب أن تغادرا الآن

634
00:34:59,760 --> 00:35:01,134
حالاً

635
00:35:01,137 --> 00:35:04,657
لا أستطيع، ستبدأ
 مناوبتي بعد ساعتين

636
00:35:04,660 --> 00:35:05,719
تكفلنا بالأمر

637
00:35:05,720 --> 00:35:07,679
أعادت شركتك تعيين
شخص آخر ليحل محلك

638
00:35:07,680 --> 00:35:11,559
ستمر سيارة أجرة لتوصلكما
للمطار بعد ثلاثون دقيقة

640
00:35:11,560 --> 00:35:14,735
ثلاثون دقيقة؟ -
إلا لو كنت ترفض الجائزة -

641
00:35:14,738 --> 00:35:17,658
سنكون جاهزين
سنكون جاهزين

642
00:35:20,019 --> 00:35:22,290
جيّد أن "إلفيس" أعار "فرانك" الهاتف

643
00:35:22,293 --> 00:35:24,237
رغم كل تحذيراتي له

644
00:35:24,240 --> 00:35:26,680
"يجب أن نلازم "روزا

645
00:35:34,897 --> 00:35:36,689
"مرحباً أيها الفتى "جيم

646
00:35:36,692 --> 00:35:38,201
كيف حالك أيها الديك؟

647
00:35:38,204 --> 00:35:40,479
كنا نبحث عنك
على إمتداد الجدول

648
00:35:40,480 --> 00:35:42,599
لماذا؟ -
فكرنا بالإنضمام لك -

649
00:35:42,600 --> 00:35:45,673
قلت لي ليلة البارحة
عن جمال وهدوء المكان

650
00:35:45,676 --> 00:35:47,955
"هذا حفيدي "ريان

651
00:35:47,958 --> 00:35:51,560
بحق الجحيم؟ -
جيمي بليك"، كيف حالك يا صاح؟" -

652
00:35:52,706 --> 00:35:54,032
لا يمكنك التواجد هنا

653
00:35:54,035 --> 00:35:56,892
كم اصطدت حتى الآن؟
أيمكنني رؤيتها؟

654
00:35:56,895 --> 00:35:59,118
هل رأيت أحداً يقذف السمك كالكرات؟ -
لا تلمس أشيائي -

655
00:35:59,120 --> 00:36:02,243
لا مكان لك هنا
وليس حفيدك

656
00:36:02,246 --> 00:36:04,212
أظننا سنبقى هنا طوال اليوم

657
00:36:04,215 --> 00:36:05,454
نعم، أظن ذلك

658
00:36:05,457 --> 00:36:07,876
بما أن الجلوس في الحافلات موعده اليوم

659
00:36:07,879 --> 00:36:11,317
سيحدث مشكلة كبيرة -
ما الذي قلته يا فتى؟ -

660
00:36:11,320 --> 00:36:15,295
سمعنا بأن مجموعة
من الركاب السود

661
00:36:15,298 --> 00:36:18,599
يخططون للجلوس إعتراضاً
في كل الحافلات الليلة

662
00:36:18,600 --> 00:36:20,912
ليس في حافلتي

663
00:36:20,915 --> 00:36:22,479
أنت، تنحى عن مقعدي

664
00:36:22,480 --> 00:36:25,520
إنهض عن مقعدي -
حسناً، إهدأ -

665
00:36:28,125 --> 00:36:29,525
سأترك الجدول اللعين لكم

666
00:36:33,320 --> 00:36:36,392
كان هذا سهلاً

667
00:36:36,395 --> 00:36:37,515
لا تفعل هذا

668
00:36:40,346 --> 00:36:43,826
سيّدة "باركس"، حالة طارئة
أيمكنكِ مساعدتي بملابسي؟

669
00:36:43,840 --> 00:36:48,079
شق سيء -
هو كذلك -

670
00:36:48,080 --> 00:36:51,519
ولا نكره نحن البريطانيون شيء
بقدر حالات الملابس الطارئة

671
00:36:51,520 --> 00:36:53,678
سيّدة "باركس"، يجب أن
أرتديه بوجود هذا الشق الليلة

672
00:36:53,681 --> 00:36:55,839
وسأقع في مشكلة
إذا لم أصلحه

673
00:36:55,840 --> 00:36:59,440
أيمكنكِ أن تلقي عليه نظرة الآن؟
وسأعطيك علاوة الكريسمس مضاعفة

674
00:37:03,351 --> 00:37:08,157
ليس لدي أي إستلامات
حتى ظهيرة الغد

675
00:37:08,160 --> 00:37:11,829
أظن بإستطاعتي إضافتكِ

676
00:37:11,832 --> 00:37:14,517
إذا عدتِ قبل أن نغلق

677
00:37:14,520 --> 00:37:17,559
سأنتظركِ بينما تعملين
لأسليكِ بصحبتي

678
00:37:17,560 --> 00:37:19,999
لا أحتاج الصحبة

679
00:37:20,000 --> 00:37:21,704
لا، لكن معطفي يحتاجها

680
00:37:21,707 --> 00:37:25,119
فهو ثمين جداً
ولا أدعه يغيب عن عيني

681
00:37:25,120 --> 00:37:28,525
شكراً لكِ
ستحدثين فرقاً كبيراً

682
00:37:28,528 --> 00:37:31,501
يستحسن أن أشرع بالعمل إذن

683
00:37:31,504 --> 00:37:32,983
لا تغب عن عينكِ

684
00:37:32,986 --> 00:37:34,478
"سأذهب لأقابل "غراهام" و "ريان

685
00:37:34,480 --> 00:37:38,039
تذكري، إجعلي "روزا" تغادر
المكان الساعة 5:40 على الأكثر

686
00:37:38,040 --> 00:37:40,480
لتلحق بتلك الحافلة على الموعد المحدد

687
00:37:47,359 --> 00:37:49,251
عدت من الجدول لأجل هذا؟

688
00:37:49,254 --> 00:37:51,773
أربع عجلات مثقوبة
وزجاج مهشم؟

689
00:37:51,776 --> 00:37:54,939
ما الذي حدث؟ -
الصغار -

690
00:37:54,942 --> 00:37:57,861
لا يمكنني قيادة هذه -
لا، عد لمنزلك -

691
00:37:57,864 --> 00:37:59,520
سنلغي المسار

692
00:38:02,663 --> 00:38:06,103
ومعه خططهم للإحتجاج
لن تذهب الحافلة لأي مكان

693
00:38:10,215 --> 00:38:13,048
أسمعت هذا؟ مع كل ما نفعله
يتقدم "كراسكو" علينا بخطوة

694
00:38:13,051 --> 00:38:15,359
لا شك بأنه خرب الحافلة عمداً

695
00:38:15,360 --> 00:38:16,559
يجب أن نصلحها

696
00:38:16,560 --> 00:38:19,080
"يجب أن يقود "جيمس بليك
حافلة "روزا" لمنزلها الليلة

697
00:38:20,885 --> 00:38:22,803
صحيح، لن يستسلم بسهولة

698
00:38:22,806 --> 00:38:24,126
ولا نحن

699
00:38:24,129 --> 00:38:27,088
ريان"، تحقق من كل محطة للحافلة"
"على مسار "بليك

700
00:38:27,091 --> 00:38:30,397
أخبر الركاب المنتظرون
بأن الحافلة قادمة، وعليهم الإنتظار

701
00:38:30,400 --> 00:38:31,399
حسناً

702
00:38:31,400 --> 00:38:34,479
لا تدع أحداً من الركاب يغادر
يجب أن تمتلىء الحافلة

703
00:38:34,480 --> 00:38:37,599
يجب أن تكون مكتظة كفاية
ليُطلب من "روزا" أن تترك مقعدها

704
00:38:37,600 --> 00:38:40,173
حسناً، فهمت -
حظاً موفقاً -

705
00:38:40,176 --> 00:38:42,839
"والآن يا "غراهام

706
00:38:42,840 --> 00:38:44,728
أتفكر بما أفكر به؟

707
00:38:45,760 --> 00:38:49,087
نسرق حافلة من المحطة

708
00:38:49,090 --> 00:38:51,342
آمل أن لا يسمع
ضابطنا الطيّب عن هذا

709
00:38:51,345 --> 00:38:53,000
بحق الجحيم

710
00:38:55,392 --> 00:38:57,919
هذه حافلتك البديلة لليلة -
"الفتى "جيم -

711
00:38:57,920 --> 00:39:00,514
أنت ثانية؟ -
أعرف، أظهر بكل مكان حرفياً -

712
00:39:00,517 --> 00:39:02,032
هيّا الآن، لتصعد وتؤدّي عملك

713
00:39:02,035 --> 00:39:03,719
تأخرت 80 دقيقة عن الجدول

714
00:39:03,720 --> 00:39:05,423
وكيف عرفتِ هذا؟
ما الذي يحدث؟

715
00:39:05,426 --> 00:39:08,197
ما الذي حدث لذلك الإعتراض اللعين؟
لم يسمع به أحد

716
00:39:08,200 --> 00:39:11,359
أود لو أشرح لك كل هذا
لكن تعرفنا البريطانيون، مستبدون

717
00:39:11,360 --> 00:39:14,079
ولا نحب تبرير تصرفاتنا لأحد
لذا لا وقت لدينا للثرثرة

718
00:39:14,080 --> 00:39:17,120
إستلم القيادة، فالعديد من الناس
يودون ركوب الحافلة هذا المساء

719
00:39:18,619 --> 00:39:21,579
السائق "جيمس بليك" خلف المقود
تم

720
00:39:46,040 --> 00:39:48,876
مسار الحافلة ملغى
"لا، لا، لا .. "كراسكو

721
00:39:49,800 --> 00:39:51,919
هل أردتِ أن تصبحي خيّاطة؟

722
00:39:51,920 --> 00:39:55,142
... حلمت بأن أكون معلمة، لكن

723
00:39:56,000 --> 00:39:58,519
مرضت جدتي، وبعدها والدتي

724
00:39:58,520 --> 00:40:00,642
وتركت المدرسة حينها

725
00:40:00,645 --> 00:40:02,959
آسفة لذلك -
علّمت نفسي -

726
00:40:02,960 --> 00:40:05,079
لكن إستغرقني ذلك
وقت أطول مما توقعت

727
00:40:05,080 --> 00:40:07,039
لكن لم تستسلمي -
أبداً -

728
00:40:07,040 --> 00:40:10,239
يمنحكِ التعليم قوة

729
00:40:10,240 --> 00:40:12,239
كل ما هنا كفاح بالنسبة لكِ

730
00:40:12,240 --> 00:40:13,759
ألا تتعبين؟

731
00:40:13,760 --> 00:40:15,679
ما الذي يدفعكِ للإستمرار؟

732
00:40:15,680 --> 00:40:18,199
الوعد بغد أفضل

733
00:40:18,207 --> 00:40:21,847
إذا لم يكن يومكِ جيّداً
فلديكِ الغد

734
00:40:23,080 --> 00:40:25,359
هل أنتِ متزوجة؟
ألديكِ وظيفة في وطنكِ؟

735
00:40:25,360 --> 00:40:28,439
لم أتزوج، وأعمل شرطية

736
00:40:28,440 --> 00:40:30,639
أنتِ بالشرطة؟ -
نعم -

737
00:40:30,640 --> 00:40:32,959
لتوي بدأت
ولم أصل حيث أريد

738
00:40:32,960 --> 00:40:35,319
أين تريدين الوصول؟

739
00:40:35,320 --> 00:40:38,520
للقيادة -
آمين لذلك -

740
00:40:39,800 --> 00:40:41,519
ألا يفترض أن تنهي العمل الآن؟

741
00:40:41,520 --> 00:40:45,679
إذا كان العمل يستحق إنجازه
فينبغي إنجازه بإتقان

742
00:40:45,680 --> 00:40:47,559
لكن ألن تفوتي الحافلة؟

743
00:40:47,560 --> 00:40:49,400
يمكنني أن أمشي

745
00:41:09,360 --> 00:41:11,199
لا أريد أن أقلقكِ

746
00:41:11,200 --> 00:41:13,520
لكن تبدو الحافلة أقل
إكتظاظاً من البارحة

747
00:41:16,280 --> 00:41:18,100
لا، هذا سيء

748
00:41:18,103 --> 00:41:20,920
يجب أن تمتلئ المقاعد
"هيّا يا "ريان

749
00:41:22,160 --> 00:41:24,279
المعذرة! المعذرة أيها الكبار

750
00:41:24,280 --> 00:41:25,999
لا زالت الحافلات تعمل

751
00:41:26,000 --> 00:41:27,439
سوف نسير

752
00:41:27,440 --> 00:41:30,159
ستأتي الحافلة، أعدكم بذلك
إنتظروا الحافلة أرجوكم

753
00:41:30,160 --> 00:41:32,080
لا يحق لك أن تأمرنا يا فتى

754
00:41:33,920 --> 00:41:35,559
يا لهذا المكان

755
00:41:35,560 --> 00:41:37,439
الركاب أقل
الركاب البيض أقل عدداً

756
00:41:37,440 --> 00:41:38,840
لا يبشر بخير

757
00:41:45,000 --> 00:41:48,159
... أظن هذا سيفي

758
00:41:48,160 --> 00:41:49,239
أعجبني

759
00:41:49,240 --> 00:41:51,479
لنذهب، سأرافقكِ للخارج

760
00:41:51,480 --> 00:41:52,960
وأدفع لكِ بالطريق

761
00:42:00,720 --> 00:42:03,759
كان علي أن أتوقع
أن يغلق الوسيم الشارع

762
00:42:03,762 --> 00:42:05,762
حسناً إذن، هذه لي

763
00:42:07,360 --> 00:42:09,239
يا صاح، حرك سيارتك لتمر الحافلة

764
00:42:09,240 --> 00:42:10,439
هيّا، إبتعد عن الطريق

765
00:42:10,440 --> 00:42:11,519
لا

766
00:42:11,520 --> 00:42:12,839
إبتعد أنت عن الطريق

767
00:42:12,840 --> 00:42:15,999
إستسلم فحسب
وحدّ من خسائرك

768
00:42:16,000 --> 00:42:17,519
لن تنتصر الليلة

769
00:42:17,520 --> 00:42:18,919
سبق وانتصرت

770
00:42:18,920 --> 00:42:20,199
أعرف ما سيحدث

771
00:42:20,200 --> 00:42:21,839
وحتى لو مرت من هنا

772
00:42:21,840 --> 00:42:25,479
فتلك الحافلة ينقصها
ثلاث ركاب على الأقل

773
00:42:25,480 --> 00:42:27,519
لن يُطلب من "باركس" ترك مقعدها

774
00:42:27,520 --> 00:42:31,519
ولن تعترض، ولن يغتر نوعك بنفسه

775
00:42:31,520 --> 00:42:33,119
نوعي؟

776
00:42:33,120 --> 00:42:35,199
نعم، نوعك

777
00:42:35,200 --> 00:42:37,279
لتبقوا في منزلتكم

778
00:42:37,280 --> 00:42:40,639
يا صاح، أنت تعيش في الماضي

779
00:42:40,640 --> 00:42:42,599
في الواقع، ما دمت تحب الماضي بهذا القدر

780
00:42:42,600 --> 00:42:44,199
.. فلمَ لا

781
00:42:44,200 --> 00:42:45,440
تبقى فيه؟

783
00:42:47,745 --> 00:42:49,556
نجحت

784
00:42:49,559 --> 00:42:51,879
"أحسنت يا "ريان
"شكراً يا "ريان

785
00:42:51,880 --> 00:42:53,999
حرك السيارة، وافتح الطريق
وأبحث عن القائدة

786
00:42:54,000 --> 00:42:55,599
وستغير "روزا باركس" العالم

787
00:42:55,600 --> 00:42:57,320
جيّد! هيّا بنا

788
00:43:03,320 --> 00:43:05,559
ياز"! أنتِ هنا"
كيف الحال؟

789
00:43:05,560 --> 00:43:07,079
أصلحت السيّدة "باركس" معطفكِ

790
00:43:07,080 --> 00:43:08,719
"شكراً لكِ سيّدة "باركس

791
00:43:08,720 --> 00:43:11,243
عمل جميل، لكِ تقديري

792
00:43:11,246 --> 00:43:12,840
على الرحب والسعة يا سيّدتي

793
00:43:16,440 --> 00:43:19,119
لا تغلق الباب
لا تنطلق

794
00:43:19,120 --> 00:43:20,760
راكب آخر قادم

795
00:43:24,360 --> 00:43:25,759
وجدتكم

796
00:43:25,760 --> 00:43:27,079
"تخلصت من "كراسكو

797
00:43:27,080 --> 00:43:28,239
كيف؟

798
00:43:28,240 --> 00:43:29,639
إستعرت هذا

799
00:43:29,640 --> 00:43:32,639
أظنني ضبطت إعداداته
لأقدم ما يمكن العودة إليه

800
00:43:32,640 --> 00:43:33,759
لقد رحل

801
00:43:33,760 --> 00:43:35,640
إستخدم باب الملونين

802
00:43:37,920 --> 00:43:39,480
يبقى القانون كما هو

803
00:43:47,880 --> 00:43:49,600
لنعد للخلف

804
00:44:02,600 --> 00:44:05,119
"دكتور، ركبت "روزا
و"بليك" السائق

805
00:44:05,120 --> 00:44:06,240
كل شيء كما ينبغي، صحيح؟

806
00:44:07,150 --> 00:44:09,159
ما الأمر؟ ما الذي تفعلينه؟

807
00:44:09,160 --> 00:44:10,680
أعد المقاعد

808
00:44:12,000 --> 00:44:14,479
هل نجحنا؟ هل يكفي ما فعلناه؟

809
00:44:14,480 --> 00:44:15,680
لا أدري

810
00:44:16,680 --> 00:44:18,520
سننزل في المحطة القادمة، صحيح؟

811
00:44:20,280 --> 00:44:22,400
مسرح إمباير، صحيح

812
00:44:25,200 --> 00:44:27,079
حسناً، هيّا بنا إذن

813
00:44:27,080 --> 00:44:30,120
يمكننا الذهاب، أنجرنا المهمة
والتاريخ بسلام

814
00:44:33,720 --> 00:44:34,999
هيّا إذن

815
00:44:35,000 --> 00:44:37,160
دكتور؟ -
"لا تترجل يا "غراهام -

816
00:44:38,560 --> 00:44:41,959
إذا نزلنا فستتوفر مقاعد للركاب البيض

817
00:44:41,960 --> 00:44:43,519
ولن يُطلب من "روزا" ترك مقعدها

818
00:44:43,520 --> 00:44:44,919
يجب أن نبقى في الحافلة

819
00:44:44,920 --> 00:44:46,799
كنا هنا

820
00:44:46,800 --> 00:44:48,919
نحن جزء من القصة

821
00:44:48,920 --> 00:44:50,159
جزء من التاريخ

822
00:44:50,160 --> 00:44:51,999
لا، لا
لا أريد أن أكون جزءاً من هذا

823
00:44:52,000 --> 00:44:53,559
يتحتم عليك ذلك، أنا آسفة

824
00:44:53,560 --> 00:44:55,080
علينا أن لا نساعدها

825
00:44:59,847 --> 00:45:02,087
أحتاج هذه المقاعد

826
00:45:07,400 --> 00:45:09,519
يستحسن أن تسهلوها على أنفسكم

827
00:45:09,520 --> 00:45:11,173
وأتركوا هذه المقاعد

828
00:45:54,400 --> 00:45:56,520
انهضي الآن

829
00:45:57,520 --> 00:45:59,400
لا أظن هناك داعٍ لذلك

830
00:46:00,400 --> 00:46:02,840
هل ستنهضين؟

831
00:46:06,800 --> 00:46:08,000
لا

832
00:46:09,720 --> 00:46:13,040
إذا لم تنهضي
فسأطلب إعتقالكِ

833
00:46:16,000 --> 00:46:17,840
يمكنك أن تفعل ذلك

834
00:47:39,080 --> 00:47:41,359
يوم الإثنين، ستبدأ المقاطعة

835
00:47:41,360 --> 00:47:44,319
في كل مونتغمري
سيرفض الناس إستخدام الحافلات

836
00:47:44,320 --> 00:47:46,120
"رداً على إعتقال "روزا

837
00:47:46,960 --> 00:47:51,759
وبعد عام من الآن
في ديسمبر 21 من عام 1956

838
00:47:51,760 --> 00:47:55,118
سيتم إنهاء الفصل في حافلات مونتغمري

839
00:47:55,121 --> 00:47:56,696
حلت مشاكلها إذن؟

840
00:47:56,699 --> 00:47:58,928
لا، إستمرت حياة "روزا" صعبة

841
00:47:58,931 --> 00:48:01,679
فقدت وظيفتها، وكذلك زوجها

842
00:48:01,680 --> 00:48:02,999
إنه صراع

843
00:48:03,000 --> 00:48:05,119
إستمروا بالكفاح

844
00:48:05,120 --> 00:48:08,599
وفي يونيو من عام 1999

845
00:48:08,600 --> 00:48:12,559
تسلمت ميدالية الشرف
"من الرئيس "كلينتون

846
00:48:12,560 --> 00:48:14,919
أعلى جائزة تُمنح لمدنيّ

847
00:48:14,920 --> 00:48:19,107
للإعتراف بها كرمز حيّ للحرية

848
00:48:19,110 --> 00:48:20,999
لكنه إستغرق وقتاً طويلاً

849
00:48:21,000 --> 00:48:22,599
عمرها كله

850
00:48:22,600 --> 00:48:24,080
نعم، صحيح

851
00:48:25,680 --> 00:48:27,440
لكنها غيّرت العالم

852
00:48:28,800 --> 00:48:30,639
.. في الواقع

853
00:48:30,640 --> 00:48:32,479
غيّرت الكون

854
00:48:32,480 --> 00:48:34,080
أنظروا لهذا

855
00:48:40,400 --> 00:48:43,799
الكويكب رقم 284996

856
00:48:43,800 --> 00:48:47,000
"والذي يعرف أيضاً بإسم "روزا باركس

857
00:48:52,995 --> 00:48:59,477
Translated by .. MadNess
تـرجمـة .. إبتـهـال

