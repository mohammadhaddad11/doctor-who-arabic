1
00:00:04,000 --> 00:00:09,180
ترجمة
twitter:king07ahmad

2
00:00:27,380 --> 00:00:30,580
اذا هذا الرجل
لديه اّلة زمن

3
00:00:30,860 --> 00:00:34,820
ذهاباً وإياباً في التاريخ
يقع بالمشاكل

4
00:00:36,060 --> 00:00:37,810
وشيء اخر لديه

5
00:00:37,860 --> 00:00:43,490
هو شغف الحب لأعمال
لودفيج فان بيتهوفن

6
00:00:43,540 --> 00:00:46,290
ويوماً ما
فكر وقال : مالهدف من أمتلك اّلة زمن

7
00:00:46,340 --> 00:00:48,730
اذا لم تذهب وتقبل أبطالك

8
00:00:48,780 --> 00:00:53,370
ولهذا ذهب للقرن الثامن عشر , ألمانيا

9
00:00:53,420 --> 00:00:55,170
لكنه لم يجد بيتهوفن في أي مككان

10
00:00:55,220 --> 00:00:58,170
لا أحد قد سمع عنه
حتى عائلته

11
00:00:58,220 --> 00:01:01,220
ليس لديها فكرة
عن الذي يتحدث عنه هذا المسافر بالزمن

12
00:01:02,940 --> 00:01:05,860
بيتهوفن حرفياً
غير موجود

13
00:01:09,540 --> 00:01:15,460
على فكرة هذا لم يحصل
لقد قابلت بيتهوفن , شاب لطيف

14
00:01:16,940 --> 00:01:19,730
قوي جداً , يحب مصارعة الايادي

15
00:01:19,780 --> 00:01:23,380
لا هذا يسمى
المفارقة الزمنية

16
00:01:24,780 --> 00:01:26,570
ابحثوا عنها

17
00:01:26,620 --> 00:01:28,010
مسافر الزمن
خاف

18
00:01:28,060 --> 00:01:32,370
لايستطيع تحمل فكرة عالم بدون
موسيقى بيتهوفن

19
00:01:32,420 --> 00:01:35,730
لحسن الحظ ,لقد جلب
جميع اوراق بيتهوفن

20
00:01:35,780 --> 00:01:38,010
الموسيقية لودفيج ليوقع عليها

21
00:01:38,060 --> 00:01:42,460
لذلك نسخ جميع
القطع الموسيقية والسمفونيات

22
00:01:43,460 --> 00:01:46,000
ونشرها

23
00:01:46,140 --> 00:01:48,210
لقد أصبح بيتهوفن

24
00:01:48,940 --> 00:01:52,460
والتاريخ استمر
ولم ينزعج أحد

25
00:01:57,900 --> 00:02:05,530
لكن سؤالي هو
من وضع هذه الملاحظات والعبارات مع بعض؟

26
00:02:05,580 --> 00:02:08,090
من الذي حقاً
الف سمفونية بيتهوفين الخامسة؟

27
00:02:55,660 --> 00:02:57,810
أين بيننت؟ يجب علينا ان نذهب

28
00:02:57,860 --> 00:02:59,330
اوه , انه مازال يقذف

29
00:02:59,380 --> 00:03:01,450
خطوة صغيرة لرجل ,لكن خطوة كبيرة للأنسانية
وهو يقذف
(اقتبست تعليق اول خطوة على سطح القمر)

30
00:03:01,500 --> 00:03:03,130
التنقل بالزمن يفعلها احياناً

31
00:03:03,180 --> 00:03:05,410
اشك بأن روز أو مارثا أو ايمي

32
00:03:05,460 --> 00:03:08,050
قذفوا فطورهم في أول رحلة

33
00:03:08,100 --> 00:03:10,970
يبدو انكي تعلمين الكثير عني

34
00:03:11,020 --> 00:03:13,050
لقد كنت في الاستخبارات العسكرية

35
00:03:13,100 --> 00:03:16,250
لقد تم تخفيض رتبتي
بسبب أني اوشكت أن ارمي زميلي من النافذة

36
00:03:16,300 --> 00:03:17,290
بسبب غضب؟

37
00:03:17,340 --> 00:03:19,490
هل يوجد سبب اخر لأن ترمي صديقك

38
00:03:19,540 --> 00:03:21,340
من النافذة؟

39
00:03:22,380 --> 00:03:24,380
ما السنة التي نحن فيها الان؟

40
00:03:27,660 --> 00:03:29,010
1980

41
00:03:29,060 --> 00:03:31,690
اذا قبل هاردلود ساكسون
قبل وزير الدفاع

42
00:03:31,740 --> 00:03:34,930
قبل انفجار القمر
وقبل خروج الخفافيش الكبيرة

43
00:03:34,980 --> 00:03:36,610
وزير الحرب؟

44
00:03:36,660 --> 00:03:38,330
نعم

45
00:03:38,380 --> 00:03:41,690
لا تهتمي
أنا اتوقع أن اعرف قريباً

46
00:03:41,740 --> 00:03:43,570
اسف بشأن هذا

47
00:03:43,620 --> 00:03:47,410
لقد أكلت ساندويتش الجامبري
أتوقع أنه خرج كله

48
00:03:47,460 --> 00:03:50,410
لا تهتم , هل نذهب؟

49
00:03:50,460 --> 00:03:53,580
فقط للحظة
لقد علق شيء بجزمتي

50
00:03:57,540 --> 00:04:00,530
أنها اكبر من الداخل
أنا اكبر من الداخل

51
00:04:00,580 --> 00:04:03,620
كيف من الممكن أن تكون اكبر من الداخل
بيننت؟

52
00:04:07,060 --> 00:04:08,860
حسنا , هيا لنذهب

53
00:04:12,500 --> 00:04:14,610
لماذا ذهبنا لروسيا؟

54
00:04:14,660 --> 00:04:16,250
لم نفعل , نحن مازلنا باسكتلندا

55
00:04:16,300 --> 00:04:17,850
هذه هي القرية قبل أن تغمر بالماء

56
00:04:17,900 --> 00:04:20,970
التارديس جلبتنا لأول مكان
هبطت فيه السفينة

57
00:04:21,020 --> 00:04:23,410
ولكن هنا والان
أنها ذروة الحرب الباردة

58
00:04:23,460 --> 00:04:28,060
ويجري تدريب الجيش للهجوم
على الاراضي السوفيتية

59
00:04:45,100 --> 00:04:47,240
اوه هل هذا هو الطيار؟

60
00:04:48,500 --> 00:04:50,900
يا إلهي انظري لحجمه

61
00:04:51,260 --> 00:04:53,850
لا , هذا الجسد

62
00:04:53,900 --> 00:04:55,650
ماذا تقصد بالجسد ؟

63
00:04:55,700 --> 00:04:58,050
هذه ليست كأي سفينة فضائية

64
00:04:58,100 --> 00:05:00,090
أنها كفن

65
00:05:00,140 --> 00:05:02,370
حجرة السبات مازالت هنا

66
00:05:02,420 --> 00:05:04,050
وخلايا الطاقة كذلك

67
00:05:04,100 --> 00:05:07,040
ولا يوجد علامات في الحائط

68
00:05:08,740 --> 00:05:10,450
حتى الان

69
00:05:10,500 --> 00:05:12,690
مرحباً

70
00:05:12,740 --> 00:05:15,480
الشبح الذي من قبل

71
00:05:17,300 --> 00:05:19,140
رائع

72
00:05:20,940 --> 00:05:22,880
وبشر أيضاً

73
00:05:23,340 --> 00:05:26,530
البير برينتز ,منظم جنائز

74
00:05:26,580 --> 00:05:28,290
أنت من تيفولي
أليس كذلك؟

75
00:05:28,340 --> 00:05:30,650
اكثر كوكب مغزو في المجرة

76
00:05:30,700 --> 00:05:33,970
عاصمتنا لديها لافتة تقول
لو أنك احتليتنا

77
00:05:34,020 --> 00:05:36,370
لكنت بمنزلك بحلول الان

78
00:05:36,420 --> 00:05:38,450
نعم
لقد اضطررت لأتعامل مع كثير منكم

79
00:05:38,500 --> 00:05:41,090
لاأستطيع القول بأني معجب
لا ,فنحن نميل للعداوة

80
00:05:41,140 --> 00:05:42,970
ماذا تفعل هنا؟

81
00:05:43,020 --> 00:05:45,090
اه نعم بالطبع

82
00:05:45,140 --> 00:05:46,480
هذا

83
00:05:47,700 --> 00:05:49,450
أنه ملك السمك

84
00:05:49,500 --> 00:05:53,730
هو وجيشه احتلوا تيفولي لمدة
 عشر سنوات رائعه

85
00:05:53,780 --> 00:05:57,210
حتى تحررنا بواسطة
الأركاتييناس

86
00:05:57,260 --> 00:06:00,490
لكن شكرا لله
بعدما اغضبناهم جداً

87
00:06:00,540 --> 00:06:03,140
استعبدونا ايضاً

88
00:06:03,940 --> 00:06:06,570
اول فضائي أراه
غبي جداً

89
00:06:06,620 --> 00:06:09,410
والان وفقاً
للعادات الاركاتيننية

90
00:06:09,460 --> 00:06:14,090
جئت لأدفنه
بأرض قاحلة ووحشية

91
00:06:14,140 --> 00:06:16,290
أنت تقصد البلدة؟

92
00:06:16,340 --> 00:06:17,610
أنه يقصد الكوكب

93
00:06:17,660 --> 00:06:22,050
وعلى الرغم من ذلك و مع خطورة بدأ حرب مزايدات
تستطيع أن تستعبدني انت

94
00:06:22,100 --> 00:06:24,250
في السفينة املك احداثيات لكوكبي

95
00:06:24,300 --> 00:06:26,890
ومعي مجموعة من الادوات
تستطيع أن تضطهدني بها

96
00:06:26,940 --> 00:06:28,610
اسمع , لقد أتينا من الحاضر

97
00:06:28,660 --> 00:06:30,570
لقد كنت ترسل نوعاً من الاشارات

98
00:06:30,620 --> 00:06:33,250
كيف يمكنك فعلها
هل هو نوع من الاقلام؟

99
00:06:33,300 --> 00:06:34,810
مالذي تتكلم عنه؟

100
00:06:34,860 --> 00:06:37,290
التكنولوجيا التي تستخدمها
التي تخرج الروح من الجسد

101
00:06:37,340 --> 00:06:40,730
وتجعله يكرر احداثياتك للأبد

102
00:06:40,780 --> 00:06:43,530
أعطيني ياه الأن
سوف استخرج البطاريات منه الان

103
00:06:43,580 --> 00:06:45,170
لانملك أي شئ كهذا

104
00:06:45,220 --> 00:06:47,690
حتى هذه تنتمي للأكرتييناسس الرائعين

105
00:06:47,740 --> 00:06:49,370
إذا من هو الذي ارسل الرسالة؟

106
00:06:54,100 --> 00:06:57,400
ارجعوا للتارديس
اريد التحدث لكلارا

107
00:07:18,180 --> 00:07:22,370
لقد مررتي بهذا مسبقاً
بمواقف كهذه من قبل

108
00:07:22,420 --> 00:07:27,330
نعم ,ليس بالحقيقة
ولكن مرة أو مرتان

109
00:07:27,380 --> 00:07:29,850
اذا كان يجب أن تتعاملي مع الناس الخائفة

110
00:07:29,900 --> 00:07:31,970
مالذي تقولينه لهم؟

111
00:07:32,020 --> 00:07:34,930
أنا اسألك
مالذي علي أن اقوله لك

112
00:07:34,980 --> 00:07:38,220
اخبرهم أن كل شئ على مايرام
وأن الدكتور سوف ينقذنا

113
00:07:39,420 --> 00:07:42,420
وعندما تقولينها , هل تصدقينها؟

114
00:07:42,860 --> 00:07:45,850
نعم بالتأكيد

115
00:07:45,900 --> 00:07:47,300
والان

116
00:07:50,460 --> 00:07:54,410
كاس تعتقد أن الدكتور يقول شيء مختلف
عن الاخرين

117
00:07:54,460 --> 00:07:59,810
أنه يقول
موران , بريتشارد . ابرينتس

118
00:07:59,860 --> 00:08:04,210
لا , برينتس , اودونيل

119
00:08:04,260 --> 00:08:06,890
كلارا , الدكتور

120
00:08:06,940 --> 00:08:08,940
بيننت , كاس

121
00:08:09,860 --> 00:08:13,090
أنها قائمة بجميع اسمائنا
وعندما ينهيها

122
00:08:13,140 --> 00:08:15,570
يرجع يقولها مرة اخرى
مراراً وتكراراً

123
00:08:15,620 --> 00:08:17,410
من هو برينتس؟

124
00:08:19,660 --> 00:08:21,010
أنه الدكتور

125
00:08:21,060 --> 00:08:22,690
هل هو حي؟

126
00:08:22,740 --> 00:08:24,540
لهذه اللحظة

127
00:08:24,820 --> 00:08:28,090
دكتور؟ دكتور؟ هل أنت بخير؟

128
00:08:28,140 --> 00:08:31,740
نعم بخير , لذا اسمعي
السفينة الفضائية أنها كفن

129
00:08:33,060 --> 00:08:35,330
كلارا , ماخطبك؟

130
00:08:35,380 --> 00:08:36,890
شبخ اخر ظهر

131
00:08:36,940 --> 00:08:39,610
ماذا ؟ من ؟
هل شخصا ما مات؟

132
00:08:39,660 --> 00:08:41,570
دكتور

133
00:08:41,620 --> 00:08:43,090
أنه انت

134
00:08:47,620 --> 00:08:49,370
هل أنت بخير؟

135
00:08:49,420 --> 00:08:52,490
حسنا , حالياً نعم

136
00:08:52,540 --> 00:08:55,010
ماذا يعني هذا؟

137
00:08:55,060 --> 00:08:56,570
هذا يعني أنني قد مت

138
00:08:56,620 --> 00:08:59,450
لا , ليس بالضرورة
نستطيع تغيير مسار الاخداث

139
00:08:59,500 --> 00:09:02,170
هذا ليس حدث قابل للتغيير

140
00:09:02,340 --> 00:09:05,850
هذا هو المستقبل ,الان
لقد حصل بالفعل

141
00:09:05,900 --> 00:09:08,900
والدليل هناك قابع أمامك

142
00:09:16,580 --> 00:09:18,320
يجب علي الموت

143
00:09:19,460 --> 00:09:20,650
لا

144
00:09:20,700 --> 00:09:22,250
تستطيع تغيير الاشياء

145
00:09:22,300 --> 00:09:23,810
لااستطيع

146
00:09:23,860 --> 00:09:27,250
حتى لو كان التغير بسيطاً
من الممكن أن تكون العواقب كارثية

147
00:09:27,300 --> 00:09:28,530
من الممكن أن تتحول إلى مجزرة

148
00:09:28,580 --> 00:09:31,620
وفوضى حول الكون
كسلسلة من ردات الفعل

149
00:09:33,540 --> 00:09:36,090
اه .حسنا
لقد خضت جولات رائعة

150
00:09:36,140 --> 00:09:39,490
التجدد بهذا الجسد قد كان
خطأ مطبعياً على اي حال

151
00:09:39,540 --> 00:09:40,530
يجب علي الذهاب في وقت ما

152
00:09:40,580 --> 00:09:43,570
ليس معي
مت مع من يأتي من بعدي

153
00:09:43,620 --> 00:09:45,620
لن تتركني

154
00:09:46,740 --> 00:09:50,240
كلارا
أنا احتاج التحدث لك بمفردك للحظة

155
00:09:52,980 --> 00:09:54,930
اسمعيني

156
00:09:54,980 --> 00:09:57,490
جميعنا يجب علينا مواجهة الموت في النهاية

157
00:09:57,540 --> 00:10:00,210
ياموتنا أو أحد قريب لنا

158
00:10:00,900 --> 00:10:02,840
أنا لست مستعدة بعد

159
00:10:04,300 --> 00:10:06,010
لا أريد التفكير بهذا
ليس بعد

160
00:10:06,060 --> 00:10:09,890
لا استطيع أن اغير الذي حصل بالفعل
هناك قوانين

161
00:10:09,940 --> 00:10:13,940
اذا اكسرهم
على كل أنت مدين لي

162
00:10:15,060 --> 00:10:19,530
لقد جعلت نفسك شخصاً مهماً بالنسبة لي
 لقد جلعتني اصبح شخص اخر

163
00:10:19,580 --> 00:10:21,690
أنت لاتستطيع أن تفعل هذا

164
00:10:21,740 --> 00:10:23,130
ثم تموت , هذ ليس عدلاً

165
00:10:23,180 --> 00:10:24,610
كلارا
لا

166
00:10:24,660 --> 00:10:27,770
دكتور , أنا لاأهتم بقوانينك اللعينة
او شعورك بالذنب

167
00:10:27,820 --> 00:10:32,180
إذا كنت تحبني بأي طريقة كانت
فسوف تعود

168
00:10:39,420 --> 00:10:41,460
دكتور , هل انت ..... ؟

169
00:10:42,700 --> 00:10:44,890
لا أستطيع انقاذ موران أو بريتشارد

170
00:10:44,940 --> 00:10:48,770
لا, لكن كم قلت
أذا اكتشفت لماذا هذا يحدث؟

171
00:10:48,820 --> 00:10:52,260
فربما يمكنك أن توقفهم من أن يقتلوا أي شخص اخر
أنت تستطيع أنقاذنا

172
00:10:54,220 --> 00:10:57,090
و تستطيع أن تنقذ نفسك

173
00:10:57,140 --> 00:11:00,090
سأفعل ما بوسعي
لكن الحاضر قد حصل بالفعل

174
00:11:00,140 --> 00:11:03,940
لقد قابلنا منظم الجنائز
ولايزال على قيد الحياة

175
00:11:32,060 --> 00:11:36,210
حسناً ,صفوني
تمتلكون منظر افضل مني

176
00:11:36,260 --> 00:11:39,850
كيف ابدو؟ هل هناك ايه رضوض؟
ايه ندوب؟

177
00:11:39,900 --> 00:11:41,530
اي دليل على كيفية موتي؟

178
00:11:41,580 --> 00:11:42,770
لا , لاشيء

179
00:11:42,820 --> 00:11:45,330
تشبه جميع الاشباح السابقين مع
نفس العيون الغريبة

180
00:11:50,140 --> 00:11:53,700
لا لا , أنتظر , معطفك

181
00:11:55,060 --> 00:11:57,610
أنه ممزق من جهة الكتف الايمن

182
00:11:57,660 --> 00:12:00,330
أنا افترض أنني أقول نفس الشيء
كالاخرين

183
00:12:00,380 --> 00:12:05,130
لا , أنت تقول قائمة من الاسماء
أسمائنا بالتحديد

184
00:12:05,180 --> 00:12:08,170
موران , بريتشارد , برينتز
اودونيل , كلارا , دكتور

185
00:12:08,220 --> 00:12:09,490
بيننت , كاسس

186
00:12:09,540 --> 00:12:12,660
من يكون برينتس؟
الشاب ذو وجه الخلد

187
00:12:14,900 --> 00:12:17,900
ما الامر؟
كلارا , مالذي حدث؟

188
00:12:18,940 --> 00:12:21,170
لقد أتيت للداخل
أنت بالداخل الان

189
00:12:21,220 --> 00:12:23,530
ما الذي افعله؟

