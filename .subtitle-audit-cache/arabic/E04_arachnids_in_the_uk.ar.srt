1
00:00:12,116 --> 00:00:20,121
Translated by .. MadNess
تـرجمـة .. إبتهـال

1
00:00:36,116 --> 00:00:40,321
‪"‬عنكبوتيات في المملكة المتحدة‪"‬

2
00:01:06,020 --> 00:01:07,599
أتمازحينني؟

3
00:01:07,600 --> 00:01:10,799
سيّدي، يجب أن نتحرك
الطائرة في الإنتظار

4
00:01:10,800 --> 00:01:13,599
"أنا أحدد متى تقلع الطائرة يا "كيفن
ما الذي تحتاجينه، المال؟

5
00:01:13,600 --> 00:01:17,119
المال ليس المشكلة يا سيّدي
بل الخدمات اللوجستية

6
00:01:17,120 --> 00:01:18,439
بالإضافة للمقياس

7
00:01:18,440 --> 00:01:20,759
إنه كبير ومعقد جداً

8
00:01:20,760 --> 00:01:22,359
بالإضافة للسرية، بالطبع

9
00:01:22,360 --> 00:01:24,919
الأرجح أنه مكشوف تماماً

10
00:01:24,920 --> 00:01:28,660
لأي منا، وخاصة لك

11
00:01:29,500 --> 00:01:30,840
"فرانكي"

12
00:01:32,340 --> 00:01:33,560
نحن بمثابة عائلة، صحيح؟

13
00:01:34,820 --> 00:01:36,580
... أعني بأنكِ

14
00:01:39,260 --> 00:01:41,284
ذكريني من تكونين؟ -
أنا زوجة ابنة أخيك يا سيّدي -

15
00:01:41,285 --> 00:01:43,759
بالضبط، لكنك تنجزين هذه الأعمال

16
00:01:43,760 --> 00:01:46,239
قد يدمر هذا سمعتي لعام 2020

17
00:01:46,240 --> 00:01:49,900
لذا إعملي على إخفائه

18
00:01:51,287 --> 00:01:52,647
لا أظنني أستطيع

19
00:01:56,000 --> 00:01:57,239
ماذا؟

20
00:01:57,240 --> 00:02:01,260
مرحباً! ظننتني وحدي هنا

21
00:02:01,980 --> 00:02:05,239
أتيت لأتحقق من سلامة
 كل شيء قبل الإفتتاح

22
00:02:05,240 --> 00:02:07,280
من تكون هذه؟

23
00:02:07,828 --> 00:02:09,400
"أنا "ناجية

24
00:02:09,820 --> 00:02:14,279
لم أعلم بأنك هنا.. أو في المدينة من الأساس

25
00:02:14,280 --> 00:02:16,439
ظننتني أخبرتك بأن تقف
"على الباب يا "كيفن

26
00:02:16,440 --> 00:02:18,839
دخلت من الباب لأخبرك
بأن علينا المغادرة يا سيّدي

27
00:02:18,840 --> 00:02:22,559
..غير معقول، ماذا تكونين
هل تعملين لدي أو ما شابه؟

28
00:02:22,560 --> 00:02:24,760
نعم، سأكون المديرة العامة

29
00:02:25,060 --> 00:02:28,386
فكرت بأن آتي وأتعرف على المكان
بينما نضع اللمسات الأخيرة

30
00:02:28,387 --> 00:02:30,159
لأكون مستعدة وقت الإفتتاح

31
00:02:30,160 --> 00:02:31,260
أنتِ مطرودة

32
00:02:31,980 --> 00:02:33,320
عذراً؟

33
00:02:33,740 --> 00:02:37,039
أنتِ مطرودة، أخرجي -
أنا آسفة جداً -

34
00:02:37,040 --> 00:02:42,800
لديكِ ساعة واحدة لتخبرينني
كيف ستخفين كل هذا، حسناً؟

36
00:02:44,080 --> 00:02:46,240
كيفن"، أنا من يحدد موعد مغادرتنا"

37
00:03:05,960 --> 00:03:07,640
كدنا نصل

38
00:03:09,920 --> 00:03:12,379
أمتأكدة بأنها تحت سيطرتكِ؟

39
00:03:12,380 --> 00:03:16,900
تماماً! نظام جديد
يحتاج للتحمية

40
00:03:37,760 --> 00:03:39,519
لقد عدنا

41
00:03:39,520 --> 00:03:41,220
عدنا حقاً

42
00:03:42,460 --> 00:03:46,039
نعم، إليكم النتيجة
أرأيتم؟ قلت بأنني سأفعلها

43
00:03:46,040 --> 00:03:49,039
نحن في بارك هيل -
هذه شقتي هناك -

44
00:03:49,040 --> 00:03:51,879
لحظة، أتسكنين في بارك هيل؟
نحن أعلى الشارع هناك

45
00:03:51,880 --> 00:03:53,860
وعادت الإشارة لهاتفي

46
00:03:55,100 --> 00:03:56,399
ولا يوجد رسائل

47
00:03:56,400 --> 00:03:59,439
لم يمضِ سوى نصف
 ساعة منذ مغادرتنا

48
00:03:59,440 --> 00:04:02,319
ماذا؟ نصف ساعة مذ كنا
معكِ في ذلك المستودع؟

49
00:04:02,320 --> 00:04:03,460
نعم

50
00:04:06,000 --> 00:04:07,280
‫..‬ إذن

51
00:04:09,860 --> 00:04:11,520
أعتقد بأن الوقت قد حان

52
00:04:14,220 --> 00:04:16,159
نعم، أظن ذلك

53
00:04:16,160 --> 00:04:18,340
أعدتكم، وأظننا إنتهينا

54
00:04:18,960 --> 00:04:20,700
سعدت برفقتكم

55
00:04:21,120 --> 00:04:24,340
شكراً يا دكتور
كانت تجربة مذهلة، صدقاً

56
00:04:25,260 --> 00:04:26,420
يسرني ذلك

57
00:04:28,140 --> 00:04:29,999
ما الذي ستفعلينه الآن؟

58
00:04:30,000 --> 00:04:31,720
كما تعلمون

59
00:04:32,020 --> 00:04:35,119
سأعود للكبينة، ويوجد الكثير لأراه

60
00:04:35,120 --> 00:04:36,740
لوحدكِ؟

61
00:04:38,740 --> 00:04:40,060
نعم، أظن ذلك

62
00:04:43,480 --> 00:04:45,999
أتريدين أن تشربي الشاي في منزلي؟ -
بلا شك -

63
00:04:46,000 --> 00:04:48,599
نعم، أود ذلك! شكراً
أحب الشاي

64
00:04:48,600 --> 00:04:50,380
الشاي عند "ياز"! مذهل

65
00:04:51,420 --> 00:04:53,759
هل ستأتيان؟
هل سنتناول جميعنا الشاي عند "ياز"؟

66
00:04:53,760 --> 00:04:55,479
لم تدعُنا

67
00:04:55,480 --> 00:04:58,439
كفى حماقة
بالطبع أنتما مدعوين

68
00:04:58,440 --> 00:05:00,060
حسناً إذن

69
00:05:01,760 --> 00:05:02,920
غراهام"؟"

70
00:05:04,480 --> 00:05:06,827
"أظنني سأمر المنزل أولاً يا "ياز

71
00:05:06,828 --> 00:05:09,060
وقد أنضم إليكم لاحقاً
إذا لم يكن لديكم مانع؟

72
00:05:13,206 --> 00:05:14,526
أتريدني أن أرافقك؟

73
00:05:16,227 --> 00:05:17,427
أفضل دخوله وحدي

74
00:05:21,326 --> 00:05:23,540
لا تغادري قبل توديعي

75
00:05:26,280 --> 00:05:29,980
"الشاي عند "ياز
لم أتناول الشاي عند "ياز" من قبل

76
00:05:33,060 --> 00:05:35,780
لا أصدق بأنكِ تعيشين هنا -
"آنا" -

77
00:05:36,520 --> 00:05:38,500
يمكنني أن أرى هذا المجمع من نافذتي

78
00:05:39,520 --> 00:05:42,399
طوال هذا الوقت ونحن جيران

79
00:05:42,400 --> 00:05:45,980
أعلم! مذهل -
نعم -

80
00:05:47,660 --> 00:05:48,959
هل كل شيء على ما يرام؟

81
00:05:48,960 --> 00:05:50,460
نعم، شكراً

82
00:05:51,000 --> 00:05:53,473
"آنا"، أنا "جيد  مكينتاير"

83
00:05:53,474 --> 00:05:55,759
أنا خارج بابكِ
هل أنتِ بالداخل؟

84
00:05:55,760 --> 00:05:58,320
!لقد عدت
ومعي صديقين

85
00:05:59,960 --> 00:06:01,319
‫..‬ الأرجح أنهم في الخارج

86
00:06:01,320 --> 00:06:05,759
أحضرتِ معكِ أصدقاء
سونيا"، أحضرت "ياز" معها أصدقاء"

87
00:06:05,760 --> 00:06:07,999
سأعد الطعام

88
00:06:08,000 --> 00:06:12,020
ماذا، ألديكِ أصدقاء حقاً؟
هل دفعت لكم؟

89
00:06:14,800 --> 00:06:17,799
يا لإطلالاتكم
لم أمتلك شقة قط

90
00:06:17,800 --> 00:06:20,919
ينبغي أن أمتلك واحدة
سأكون مذهلة كمالكة شقة، وسأشتري أريكة

91
00:06:20,920 --> 00:06:23,559
تخيلوني أمتلك أريكة
أريكتي الخاصة

92
00:06:23,560 --> 00:06:26,300
يمكنني أن أشتري أريكة بنفسجية، وأجلس عليها

93
00:06:26,920 --> 00:06:29,199
هل أتصرف بغرابة؟ -
قليلاً، نعم -

94
00:06:29,200 --> 00:06:31,879
أحاول أن أدردش
ظننتني أتقنتها

95
00:06:31,880 --> 00:06:33,479
تحتاج تحسين

96
00:06:33,480 --> 00:06:34,839
قد أكون متوترة

97
00:06:34,840 --> 00:06:38,040
أو خجولة إجتماعياً
لا زلت أكتشف نفسي

98
00:06:40,120 --> 00:06:41,919
أنت تحب الخردة حقاً

99
00:06:41,920 --> 00:06:44,119
هل تجمعها، كالطوابع مثلاً؟

100
00:06:44,120 --> 00:06:47,471
دعيني أخبركِ عن هذه الفوضى -
لا تدعيه يبدأ -

101
00:06:47,472 --> 00:06:49,479
أبي، لا ننفك نخبرك
أن تكف عن جمعها

102
00:06:49,480 --> 00:06:52,159
ستجن أمي حين ترى
ما أحضرته ثانية

103
00:06:52,160 --> 00:06:54,987
رائحته كريهة -
لا يمكنني أن أتركه حيث هو -

104
00:06:55,012 --> 00:06:56,199
ولمَ علينا أن نجمعه؟

105
00:06:56,200 --> 00:06:58,574
ظننت بما أن شقيقتكِ شرطية

106
00:06:58,575 --> 00:06:59,660
ضابطة شرطة

107
00:06:59,685 --> 00:07:01,759
وقالت بأنها ستتصرف بشأنه

108
00:07:01,760 --> 00:07:04,439
فعلت، وقالوا بأنهم سينظرون بأمره -
ليس بالسرعة الكافية -

109
00:07:04,440 --> 00:07:05,599
وضع مخجل

110
00:07:05,600 --> 00:07:07,759
لا تتركه في المطبخ
ضعه في المكب

111
00:07:07,760 --> 00:07:10,999
إنه دليل! وهل تعرفين
على ماذا يدل؟

112
00:07:11,000 --> 00:07:13,303
مؤامرة -
بالضبط -

113
00:07:13,304 --> 00:07:15,919
مؤامرة كاملة، وتزداد سوءاً

114
00:07:15,920 --> 00:07:18,080
أحب المؤامرة

115
00:07:19,720 --> 00:07:22,599
هل أنت و "ياز" إذن...؟ -
أصحاب -

116
00:07:22,600 --> 00:07:24,919
درسنا الإبتدائية معاً

117
00:07:24,920 --> 00:07:28,551
مجرد أصحاب إذن؟     - صحيح-
هذا جيّد -

118
00:07:32,240 --> 00:07:34,919
مرحباً أمي -
مرحباً، أيمكن أن تقليني من العمل؟ -

119
00:07:34,920 --> 00:07:36,845
ماذا، الآن؟

120
00:07:36,846 --> 00:07:38,879
...لكنني بين -
نعم، الآن -

121
00:07:38,880 --> 00:07:42,319
الأمر ضروري، سأرسل لكِ العنوان

122
00:07:42,320 --> 00:07:44,359
ولا تخبري والدكِ

123
00:07:44,360 --> 00:07:45,836
سأخبركِ بكل شيء حين أراكِ

124
00:07:45,861 --> 00:07:46,902
حسناً

125
00:07:47,495 --> 00:07:48,793
شكراً يا حبيبتي

126
00:07:54,120 --> 00:07:57,919
هل هي بخير؟ -
نعم، نسيَت شيء -

127
00:07:57,920 --> 00:08:00,120
وتريدني أن أمر به عليها

128
00:08:01,820 --> 00:08:04,339
لديها عمل جديد
إفتتاح فندق فاخر

129
00:08:04,340 --> 00:08:06,209
أتمانعان لو خرجت؟

130
00:08:06,210 --> 00:08:09,066
أتحتاجين رفقة؟ -
لا، سأكون بخير -

131
00:08:09,067 --> 00:08:12,159
سنعتني بصديقيكِ
سأعد الباكورا

132
00:08:12,160 --> 00:08:13,820
لا يا أبي

133
00:08:14,700 --> 00:08:16,159
سيء في إعداد الباكورا

134
00:08:16,160 --> 00:08:18,719
لا نقابل أحداً من أصدقاؤكِ أبداً
لا تحضر معها أحد أبداً

135
00:08:18,720 --> 00:08:21,971
متزوجة عملها -
على الأقل لدي عمل لأتزوجه -

136
00:08:21,972 --> 00:08:24,171
وداعاً -
آمل أن لا تصطدمين -

137
00:08:24,172 --> 00:08:26,439
‫..‬ كفى يا فتيات -
الأخوات -

138
00:08:26,440 --> 00:08:30,439
كان لدي أخوات
وكنت أخت في مستشفى مائي

139
00:08:30,440 --> 00:08:33,055
والذي إكتشفت لاحقاً
بأنه معسكر تدريب

140
00:08:33,056 --> 00:08:34,439
لقتلة كالسيوم كويستون المحترفين

141
00:08:34,440 --> 00:08:36,959
بدأتِ الثرثرة ثانية -
لديك طرد لتستلمه -

142
00:08:36,960 --> 00:08:38,399
استلمه أحد جيرانك

143
00:08:38,400 --> 00:08:40,439
نعم، وكنت أحاول
إسترجاعه منذ أيام

144
00:08:40,440 --> 00:08:42,426
على بعد بابين
لكن لا أحد يرد

145
00:08:42,427 --> 00:08:45,280
أتريدني أن أذهب لأحضره
بينما تعد باكورتك المريعة؟

146
00:09:14,880 --> 00:09:18,300
يجب أن تتعلم كيف
تغير أكياس المكنسة الآن

147
00:09:19,260 --> 00:09:21,180
وتكتشف أين أضع الإحتياطية

148
00:09:23,080 --> 00:09:25,300
وجمع النفايات كل جمعة

149
00:09:25,980 --> 00:09:28,319
وإعادة التدوير كل أسبوعين

150
00:09:28,320 --> 00:09:29,759
أعرف

151
00:09:32,480 --> 00:09:34,340
أعرف

152
00:09:35,340 --> 00:09:37,120
لدي الكثير لأخبركِ به

153
00:09:47,280 --> 00:09:49,919
هل سمعت من "غراهام"؟ -
أكان يفترض أن أرافقه؟ -

154
00:09:49,920 --> 00:09:52,560
تعرفه أفضل مني -
لا أعرفه جيّداً -

155
00:09:52,757 --> 00:09:56,036
ألم ترد بعد؟ لدينا طرد
لنستلمه من الشقة 34

156
00:09:56,037 --> 00:09:57,876
أظنها استلمته
هل أنتِ صديقتها؟

157
00:09:57,877 --> 00:09:59,996
نعمل معاً في الجامعة

158
00:09:59,997 --> 00:10:02,756
وتغيبت عن العمل لبضعة أيام
ولم تتصل لتطلب إجازة

159
00:10:02,757 --> 00:10:06,026
ولا ترد على رسائلها
ففكرت أن أمر بها

160
00:10:06,027 --> 00:10:07,676
لأطمئن عليها

161
00:10:07,677 --> 00:10:10,196
"أنا "جيد -
"وأنا "ريان -

162
00:10:10,197 --> 00:10:12,836
وهذه الدكتور -
"مرحباَ "آنا -

163
00:10:12,837 --> 00:10:15,677
أنا من الشقة المجاورة
هل إستلمتِ طرداَ لنا؟

164
00:10:18,277 --> 00:10:19,820
‫...‬ أعني

165
00:10:20,317 --> 00:10:21,996
يمكنني أن أفتح الباب

166
00:10:21,997 --> 00:10:23,716
ماذا، أتعنين إقتحامه؟

167
00:10:23,717 --> 00:10:26,196
لا، لكن.. أفتح القفل

168
00:10:26,197 --> 00:10:28,036
إذا ظننته ملائماً

169
00:10:28,037 --> 00:10:29,396
‫...‬ وإذا كنتِ قلقة

170
00:10:29,397 --> 00:10:31,780
بشأنها -
نعم -

171
00:10:35,117 --> 00:10:37,397
آنا"؟"

172
00:10:40,037 --> 00:10:42,316
قلتِ كم مضى منذ آخر مرة رأيتها؟

173
00:10:44,437 --> 00:10:46,877
الكهرباء مقطوعة -
بضعة أيام -

174
00:10:48,717 --> 00:10:50,916
شباك العنكبوت كثيرة
بالنسبة لبضعة أيام

175
00:10:50,917 --> 00:10:52,597
نعم، هذا ما كنت أفكر به

177
00:10:55,557 --> 00:10:58,997
هذا غريب بحق -
نعم -

178
00:11:07,957 --> 00:11:13,380
غراهام أوبراين"، لماذا تشم المعاطف؟"

179
00:11:15,437 --> 00:11:17,276
كيف سيساعدك هذا، هه؟

180
00:11:23,317 --> 00:11:25,957
هل إشتكت "آنا" من العناكب من قبل؟

181
00:11:38,397 --> 00:11:40,757
لنلقي نظرة بالأسفل

182
00:11:44,117 --> 00:11:45,477
ما هذا؟

183
00:11:47,797 --> 00:11:50,320
آنا"؟" -
هل هي هنا؟ -

184
00:11:54,237 --> 00:11:55,717
هل أنتِ بخير؟

185
00:12:00,197 --> 00:12:01,677
آنا"؟"

186
00:12:04,117 --> 00:12:07,756
يا أيامي -
"... يا إلهي، "آنا -

187
00:12:07,757 --> 00:12:09,196
أنا آسفة

188
00:12:09,197 --> 00:12:11,500
لا تفعل العناكب هذا

189
00:12:12,357 --> 00:12:14,996
صحيح؟ -
"السؤال الخطأ يا "ريان -

190
00:12:14,997 --> 00:12:17,596
ينبغي أن تسأل
أين العنكبوت الذي فعل هذا؟

191
00:12:17,597 --> 00:12:19,420
أتظنينه ما زال هنا؟

192
00:12:20,237 --> 00:12:22,237
ربما

193
00:12:30,477 --> 00:12:33,117
‫...‬ ثلاثة، إثنان

194
00:12:50,277 --> 00:12:51,997
أنظروا لحجمه

195
00:12:53,073 --> 00:12:54,770
بلا حركات مفاجئة

196
00:12:56,397 --> 00:12:59,516
عنكبوت منزلي، لكنه أكبر من اللازم
ليس مؤذياً

197
00:12:59,517 --> 00:13:02,916
خنق زميلتكِ -
لنضع الباب بيننا -

198
00:13:02,917 --> 00:13:04,780
عند إشارتي، تحركوا بأقصى سرعتكم

199
00:13:06,397 --> 00:13:09,636
هيّا، هيّا، هيّا... هيّا

200
00:13:09,637 --> 00:13:12,396
ريان"، إحبسه مكانه، سأعود حالاً"

201
00:13:12,397 --> 00:13:14,876
نحن في الخارج، وتم إحتواؤه
ليس سوى عنكبوت

202
00:13:14,877 --> 00:13:18,540
عنكبوت ضخم، لكنه عنكبوت
لا أحب العناكب كثيراً

203
00:13:19,197 --> 00:13:20,877
ماذا؟

204
00:13:23,797 --> 00:13:26,596
دكتور! يحاول المرور

205
00:13:26,597 --> 00:13:28,477
لا يمكن أن أبقيه في غرفة النوم

206
00:13:30,557 --> 00:13:31,836
مكب النفايات

207
00:13:31,837 --> 00:13:34,396
قد يكون ذلك مدخله
أيمكننا أن نخرجه منه؟

208
00:13:34,397 --> 00:13:35,836
ونطلقه على باقي المدينة؟

209
00:13:35,837 --> 00:13:38,020
لا، يجب أن نبقيه معزولاً هنا

210
00:13:39,357 --> 00:13:42,076
ريان"! تعال إلى هنا"

211
00:13:42,077 --> 00:13:44,796
غطيتني بالخل

212
00:13:44,797 --> 00:13:48,076
أقدام العناكب بمثابة أنوف لها
وهي تكره رائحة الثوم

213
00:13:48,077 --> 00:13:51,397
وحمض الخليك في الخل
يعني بأنها لن تتخطاه

214
00:13:59,197 --> 00:14:00,756
أين هو؟

215
00:14:15,677 --> 00:14:18,196
مرحباً
لا نود أذيتك

216
00:14:18,197 --> 00:14:19,676
لا يفترض أن تكون بهذا الحجم

217
00:14:19,677 --> 00:14:22,396
ولا يفترض أن تهاجم البشر

218
00:14:22,397 --> 00:14:26,036
إبق مكانك
إلى أن أكتشف الأمر

219
00:14:26,037 --> 00:14:27,597
إتفقنا؟

220
00:14:34,757 --> 00:14:36,077
لنذهب

221
00:14:38,157 --> 00:14:39,757
لم يعجبني ذلك

222
00:14:41,557 --> 00:14:42,996
"جيد مكينتاير"

223
00:14:42,997 --> 00:14:44,476
من تكونين بالضبط؟

224
00:14:44,477 --> 00:14:47,756
رأيتكِ تتحققين من شباك
العنكبوت، ولم تبدي متفاجئة

225
00:14:47,757 --> 00:14:51,796
لن تتوقعوا ما وجدته في العلية

226
00:14:51,797 --> 00:14:53,236
يستحسن أن لا يكون عنكبوت ضخم

227
00:14:53,237 --> 00:14:55,756
بلى! وكأن عنكبوت ضخم
قد رمى قشرته

228
00:14:55,757 --> 00:14:59,060
ماتت امرأة هنا، وأظنكِ
تعرفين أكثر مما قلتيه لنا

229
00:15:00,037 --> 00:15:03,516
لم تكن هذه أول حادثة

230
00:15:03,517 --> 00:15:06,516
يحدث شيء ما للعناكب في المدينة

231
00:15:06,517 --> 00:15:07,877
إنها خارجة عن السيطرة

232
00:15:13,637 --> 00:15:16,076
إستغرقوا وقتاً طويلاً لإستعادة طرد

233
00:15:16,077 --> 00:15:18,797
دائما ما تصاحب غريبي الأطوار

234
00:15:25,117 --> 00:15:28,156
المكان حيث عملت "آنا" معي قريب

235
00:15:28,157 --> 00:15:29,836
أنا باحثة زميلة في علم الحيوان

236
00:15:29,837 --> 00:15:32,036
متخصصة في المفصليات والعنكبوتيات

237
00:15:32,037 --> 00:15:34,716
لكن العناكب هي محط إهتمامنا

238
00:15:34,717 --> 00:15:38,157
ونلاحظ وجود مشكلة في تصرفاتها حالياً

239
00:15:40,397 --> 00:15:43,436
كيف المنزل؟ -
بخير، نعم -

240
00:15:43,437 --> 00:15:45,196
جيّد أننا عدنا، صحيح؟

241
00:15:45,197 --> 00:15:46,596
نعم

242
00:15:46,597 --> 00:15:49,140
أنظر، وجدت هذه على الأرض

243
00:15:50,317 --> 00:15:52,436
إنه خط أبيك، صحيح؟

244
00:15:52,437 --> 00:15:54,540
يبدو كذلك، نعم

245
00:15:55,037 --> 00:15:57,197
ألن تفتحه إذن؟ -
لا -

246
00:16:15,477 --> 00:16:17,596
هذه بوليصة تأميني

247
00:16:17,597 --> 00:16:20,276
كل ما فعلته كان تحت تعليمات صارمة

248
00:16:20,277 --> 00:16:22,756
وإتفاقيات بعدم الكشف

249
00:16:22,757 --> 00:16:24,796
وخلافاً لما تمليه علي نفسي

250
00:16:24,797 --> 00:16:27,717
وأتمنى أن أستطيع أن أسامح
نفسي يوماً على دوري فيه

251
00:16:31,877 --> 00:16:33,286
ما هذا؟

252
00:16:34,997 --> 00:16:36,356
يا إلهي

253
00:16:47,397 --> 00:16:49,237
يا للهول يا أمي

254
00:16:54,197 --> 00:16:56,516
بسرعة، أدخلي قبل أن يراكِ أحد

255
00:16:56,517 --> 00:16:57,756
مرحباً

256
00:16:57,757 --> 00:17:02,676
لمَ تحضنيني بقوة؟
رأيتكِ هذا الصباح

257
00:17:02,677 --> 00:17:04,636
نعم، لكن

258
00:17:04,637 --> 00:17:06,676
أشعر بأن المدة أطول

259
00:17:06,677 --> 00:17:08,237
المكان فخم جداً

260
00:17:09,477 --> 00:17:11,676
لا تتعلقي به، يجب أن نذهب

261
00:17:11,677 --> 00:17:13,716
ألا يمكنني أن ألقي نظرة خاطفة على المكان؟

262
00:17:13,717 --> 00:17:15,117
"لا يا "ياز

263
00:17:16,277 --> 00:17:18,476
