1
00:00:00,000 --> 00:00:05,180
ترجمة
twitter:king07ahmad

2
00:00:23,380 --> 00:00:26,580
اذا هذا الرجل
لديه اّلة زمن

3
00:00:26,860 --> 00:00:30,820
ذهاباً وإياباً في التاريخ
يقع بالمشاكل

4
00:00:32,060 --> 00:00:33,810
وشيء اخر لديه

5
00:00:33,860 --> 00:00:39,490
هو شغف الحب لأعمال
لودفيج فان بيتهوفن

6
00:00:39,540 --> 00:00:42,290
ويوماً ما
فكر وقال : مالهدف من أمتلك اّلة زمن

7
00:00:42,340 --> 00:00:44,730
اذا لم تذهب وتقبل أبطالك

8
00:00:44,780 --> 00:00:49,370
ولهذا ذهب للقرن الثامن عشر , ألمانيا

9
00:00:49,420 --> 00:00:51,170
لكنه لم يجد بيتهوفن في أي مككان

10
00:00:51,220 --> 00:00:54,170
لا أحد قد سمع عنه
حتى عائلته

11
00:00:54,220 --> 00:00:57,220
ليس لديها فكرة
عن الذي يتحدث عنه هذا المسافر بالزمن

12
00:00:58,940 --> 00:01:01,860
بيتهوفن حرفياً
غير موجود

13
00:01:05,540 --> 00:01:11,460
على فكرة هذا لم يحصل
لقد قابلت بيتهوفن , شاب لطيف

14
00:01:12,940 --> 00:01:15,730
قوي جداً , يحب مصارعة الايادي

15
00:01:15,780 --> 00:01:19,380
لا هذا يسمى
المفارقة الزمنية

16
00:01:20,780 --> 00:01:22,570
ابحثوا عنها

17
00:01:22,620 --> 00:01:24,010
مسافر الزمن
خاف

18
00:01:24,060 --> 00:01:28,370
لايستطيع تحمل فكرة عالم بدون
موسيقى بيتهوفن

19
00:01:28,420 --> 00:01:31,730
لحسن الحظ ,لقد جلب
جميع اوراق بيتهوفن

20
00:01:31,780 --> 00:01:34,010
الموسيقية لودفيج ليوقع عليها

21
00:01:34,060 --> 00:01:38,460
لذلك نسخ جميع
القطع الموسيقية والسمفونيات

22
00:01:39,460 --> 00:01:42,000
ونشرها

23
00:01:42,140 --> 00:01:44,210
لقد أصبح بيتهوفن

24
00:01:44,940 --> 00:01:48,460
والتاريخ استمر
ولم ينزعج أحد

25
00:01:53,900 --> 00:02:01,530
لكن سؤالي هو
من وضع هذه الملاحظات والعبارات مع بعض؟

26
00:02:01,580 --> 00:02:04,090
من الذي حقاً
الف سمفونية بيتهوفين الخامسة؟

27
00:02:51,660 --> 00:02:53,810
أين بيننت؟ يجب علينا ان نذهب

28
00:02:53,860 --> 00:02:55,330
اوه , انه مازال يقذف

29
00:02:55,380 --> 00:02:57,450
خطوة صغيرة لرجل ,لكن خطوة كبيرة للأنسانية
وهو يقذف
(اقتبست تعليق اول خطوة على سطح القمر)

30
00:02:57,500 --> 00:02:59,130
التنقل بالزمن يفعلها احياناً

31
00:02:59,180 --> 00:03:01,410
اشك بأن روز أو مارثا أو ايمي

32
00:03:01,460 --> 00:03:04,050
قذفوا فطورهم في أول رحلة

33
00:03:04,100 --> 00:03:06,970
يبدو انكي تعلمين الكثير عني

34
00:03:07,020 --> 00:03:09,050
 لقد كنت في الاستخبارات العسكرية

35
00:03:09,100 --> 00:03:12,250
لقد تم تخفيض رتبتي
بسبب أني اوشكت أن ارمي زميلي من النافذة

36
00:03:12,300 --> 00:03:13,290
بسبب غضب؟

37
00:03:13,340 --> 00:03:15,490
هل يوجد سبب اخر لأن ترمي صديقك

38
00:03:15,540 --> 00:03:17,340
من النافذة؟

39
00:03:18,380 --> 00:03:20,380
ما السنة التي نحن فيها الان؟

40
00:03:23,660 --> 00:03:25,010
1980

41
00:03:25,060 --> 00:03:27,690
اذا قبل هاردلود ساكسون
قبل وزير الدفاع

42
00:03:27,740 --> 00:03:30,930
قبل انفجار القمر
وقبل خروج الخفافيش الكبيرة

43
00:03:30,980 --> 00:03:32,610
وزير الحرب؟

44
00:03:32,660 --> 00:03:34,330
نعم

45
00:03:34,380 --> 00:03:37,690
لا تهتمي
أنا اتوقع أن اعرف قريباً

46
00:03:37,740 --> 00:03:39,570
اسف بشأن هذا

47
00:03:39,620 --> 00:03:43,410
لقد أكلت ساندويتش الجامبري
أتوقع أنه خرج كله

48
00:03:43,460 --> 00:03:46,410
لا تهتم , هل نذهب؟

49
00:03:46,460 --> 00:03:49,580
فقط للحظة
لقد علق شيء بجزمتي

50
00:03:53,540 --> 00:03:56,530
أنها اكبر من الداخل
أنا اكبر من الداخل

51
00:03:56,580 --> 00:03:59,620
كيف من الممكن أن تكون اكبر من الداخل
بيننت؟

52
00:04:03,060 --> 00:04:04,860
حسنا , هيا لنذهب

53
00:04:08,500 --> 00:04:10,610
لماذا ذهبنا لروسيا؟

54
00:04:10,660 --> 00:04:12,250
لم نفعل , نحن مازلنا باسكتلندا

55
00:04:12,300 --> 00:04:13,850
هذه هي القرية قبل أن تغمر بالماء

56
00:04:13,900 --> 00:04:16,970
التارديس جلبتنا لأول مكان
هبطت فيه السفينة

57
00:04:17,020 --> 00:04:19,410
ولكن هنا والان
أنها ذروة الحرب الباردة

58
00:04:19,460 --> 00:04:24,060
ويجري تدريب الجيش للهجوم
على الاراضي السوفيتية

59
00:04:41,100 --> 00:04:43,240
اوه هل هذا هو الطيار؟

60
00:04:44,500 --> 00:04:46,900
يا إلهي انظري لحجمه

61
00:04:47,260 --> 00:04:49,850
لا , هذا الجسد

62
00:04:49,900 --> 00:04:51,650
ماذا تقصد بالجسد ؟

63
00:04:51,700 --> 00:04:54,050
هذه ليست كأي سفينة فضائية

64
00:04:54,100 --> 00:04:56,090
أنها كفن

65
00:04:56,140 --> 00:04:58,370
حجرة السبات مازالت هنا

66
00:04:58,420 --> 00:05:00,050
وخلايا الطاقة كذلك

67
00:05:00,100 --> 00:05:03,040
ولا يوجد علامات في الحائط

68
00:05:04,740 --> 00:05:06,450
حتى الان

69
00:05:06,500 --> 00:05:08,690
مرحباً

70
00:05:08,740 --> 00:05:11,480
الشبح الذي من قبل

71
00:05:13,300 --> 00:05:15,140
رائع

72
00:05:16,940 --> 00:05:18,880
وبشر أيضاً

73
00:05:19,340 --> 00:05:22,530
البير برينتز ,منظم جنائز

74
00:05:22,580 --> 00:05:24,290
أنت من تيفولي
أليس كذلك؟

75
00:05:24,340 --> 00:05:26,650
اكثر كوكب مغزو في المجرة

76
00:05:26,700 --> 00:05:29,970
عاصمتنا لديها لافتة تقول
لو أنك احتليتنا

77
00:05:30,020 --> 00:05:32,370
لكنت بمنزلك بحلول الان

78
00:05:32,420 --> 00:05:34,450
نعم
لقد اضطررت لأتعامل مع كثير منكم

79
00:05:34,500 --> 00:05:37,090
لاأستطيع القول بأني معجب
لا ,فنحن نميل للعداوة

80
00:05:37,140 --> 00:05:38,970
ماذا تفعل هنا؟

81
00:05:39,020 --> 00:05:41,090
اه نعم بالطبع

82
00:05:41,140 --> 00:05:42,480
هذا

83
00:05:43,700 --> 00:05:45,450
أنه ملك السمك

84
00:05:45,500 --> 00:05:49,730
 هو وجيشه احتلوا تيفولي لمدة
 عشر سنوات رائعه

85
00:05:49,780 --> 00:05:53,210
حتى تحررنا بواسطة
الأركاتييناس

86
00:05:53,260 --> 00:05:56,490
لكن شكرا لله
بعدما اغضبناهم جداً

87
00:05:56,540 --> 00:05:59,140
استعبدونا ايضاً

88
00:05:59,940 --> 00:06:02,570
اول فضائي أراه
غبي جداً

89
00:06:02,620 --> 00:06:05,410
والان وفقاً
للعادات الاركاتيننية

90
00:06:05,460 --> 00:06:10,090
جئت لأدفنه
بأرض قاحلة ووحشية

91
00:06:10,140 --> 00:06:12,290
أنت تقصد البلدة؟

92
00:06:12,340 --> 00:06:13,610
أنه يقصد الكوكب

93
00:06:13,660 --> 00:06:18,050
وعلى الرغم من ذلك و مع خطورة بدأ حرب مزايدات
تستطيع أن تستعبدني انت

94
00:06:18,100 --> 00:06:20,250
في السفينة املك احداثيات لكوكبي

95
00:06:20,300 --> 00:06:22,890
ومعي مجموعة من الادوات
تستطيع أن تضطهدني بها

96
00:06:22,940 --> 00:06:24,610
اسمع , لقد أتينا من الحاضر

97
00:06:24,660 --> 00:06:26,570
لقد كنت ترسل نوعاً من الاشارات

98
00:06:26,620 --> 00:06:29,250
كيف يمكنك فعلها
هل هو نوع من الاقلام؟

99
00:06:29,300 --> 00:06:30,810
مالذي تتكلم عنه؟

100
00:06:30,860 --> 00:06:33,290
التكنولوجيا التي تستخدمها
التي تخرج الروح من الجسد

101
00:06:33,340 --> 00:06:36,730
وتجعله يكرر احداثياتك للأبد

102
00:06:36,780 --> 00:06:39,530
أعطيني ياه الأن
سوف استخرج البطاريات منه الان

103
00:06:39,580 --> 00:06:41,170
لانملك أي شئ كهذا

104
00:06:41,220 --> 00:06:43,690
حتى هذه تنتمي للأكرتييناسس الرائعين

105
00:06:43,740 --> 00:06:45,370
إذا من هو الذي ارسل الرسالة؟

106
00:06:50,100 --> 00:06:53,400
ارجعوا للتارديس
اريد التحدث لكلارا

107
00:07:14,180 --> 00:07:18,370
لقد مررتي بهذا مسبقاً
بمواقف كهذه من قبل

108
00:07:18,420 --> 00:07:23,330
نعم ,ليس بالحقيقة
ولكن مرة أو مرتان

109
00:07:23,380 --> 00:07:25,850
اذا كان يجب أن تتعاملي مع الناس الخائفة

110
00:07:25,900 --> 00:07:27,970
مالذي تقولينه لهم؟

111
00:07:28,020 --> 00:07:30,930
أنا اسألك
مالذي علي أن اقوله لك

112
00:07:30,980 --> 00:07:34,220
اخبرهم أن كل شئ على مايرام
وأن الدكتور سوف ينقذنا

113
00:07:35,420 --> 00:07:38,420
وعندما تقولينها , هل تصدقينها؟

114
00:07:38,860 --> 00:07:41,850
نعم بالتأكيد

115
00:07:41,900 --> 00:07:43,300
والان

116
00:07:46,460 --> 00:07:50,410
كاس تعتقد أن الدكتور يقول شيء مختلف
عن الاخرين

117
00:07:50,460 --> 00:07:55,810
أنه يقول
موران , بريتشارد . ابرينتس

118
00:07:55,860 --> 00:08:00,210
لا , برينتس , اودونيل

119
00:08:00,260 --> 00:08:02,890
كلارا , الدكتور

120
00:08:02,940 --> 00:08:04,940
بيننت , كاس

121
00:08:05,860 --> 00:08:09,090
أنها قائمة بجميع اسمائنا
وعندما ينهيها

122
00:08:09,140 --> 00:08:11,570
يرجع يقولها مرة اخرى
مراراً وتكراراً

123
00:08:11,620 --> 00:08:13,410
من هو برينتس؟

124
00:08:15,660 --> 00:08:17,010
أنه الدكتور

125
00:08:17,060 --> 00:08:18,690
هل هو حي؟

126
00:08:18,740 --> 00:08:20,540
لهذه اللحظة

127
00:08:20,820 --> 00:08:24,090
دكتور؟ دكتور؟ هل أنت بخير؟

128
00:08:24,140 --> 00:08:27,740
نعم بخير , لذا اسمعي
السفينة الفضائية أنها كفن

129
00:08:29,060 --> 00:08:31,330
كلارا , ماخطبك؟

130
00:08:31,380 --> 00:08:32,890
شبخ اخر ظهر

131
00:08:32,940 --> 00:08:35,610
ماذا ؟ من ؟
هل شخصا ما مات؟

132
00:08:35,660 --> 00:08:37,570
دكتور

133
00:08:37,620 --> 00:08:39,090
أنه انت

134
00:08:43,620 --> 00:08:45,370
هل أنت بخير؟

135
00:08:45,420 --> 00:08:48,490
حسنا , حالياً نعم

136
00:08:48,540 --> 00:08:51,010
ماذا يعني هذا؟

137
00:08:51,060 --> 00:08:52,570
هذا يعني أنني قد مت

138
00:08:52,620 --> 00:08:55,450
لا , ليس بالضرورة
نستطيع تغيير مسار الاخداث

139
00:08:55,500 --> 00:08:58,170
هذا ليس حدث قابل للتغيير

140
00:08:58,340 --> 00:09:01,850
هذا هو المستقبل ,الان
لقد حصل بالفعل

141
00:09:01,900 --> 00:09:04,900
والدليل هناك قابع أمامك

142
00:09:12,580 --> 00:09:14,320
يجب علي الموت

143
00:09:15,460 --> 00:09:16,650
لا

144
00:09:16,700 --> 00:09:18,250
تستطيع تغيير الاشياء

145
00:09:18,300 --> 00:09:19,810
لااستطيع

146
00:09:19,860 --> 00:09:23,250
حتى لو كان التغير بسيطاً
من الممكن أن تكون العواقب كارثية

147
00:09:23,300 --> 00:09:24,530
من الممكن أن تتحول إلى مجزرة

148
00:09:24,580 --> 00:09:27,620
وفوضى حول الكون
كسلسلة من ردات الفعل

149
00:09:29,540 --> 00:09:32,090
اه .حسنا
لقد خضت جولات رائعة

150
00:09:32,140 --> 00:09:35,490
التجدد بهذا الجسد قد كان
خطأ مطبعياً على اي حال

151
00:09:35,540 --> 00:09:36,530
يجب علي الذهاب في وقت ما

152
00:09:36,580 --> 00:09:39,570
ليس معي
مت مع من يأتي من بعدي

153
00:09:39,620 --> 00:09:41,620
لن تتركني

154
00:09:42,740 --> 00:09:46,240
كلارا
أنا احتاج التحدث لك بمفردك للحظة

155
00:09:48,980 --> 00:09:50,930
اسمعيني

156
00:09:50,980 --> 00:09:53,490
جميعنا يجب علينا مواجهة الموت في النهاية

157
00:09:53,540 --> 00:09:56,210
ياموتنا أو أحد قريب لنا

158
00:09:56,900 --> 00:09:58,840
أنا لست مستعدة بعد

159
00:10:00,300 --> 00:10:02,010
لا أريد التفكير بهذا
ليس بعد

160
00:10:02,060 --> 00:10:05,890
لا استطيع أن اغير الذي حصل بالفعل
هناك قوانين

161
00:10:05,940 --> 00:10:09,940
اذا اكسرهم
على كل أنت مدين لي

162
00:10:11,060 --> 00:10:15,530
لقد جعلت نفسك شخصاً مهماً بالنسبة لي
 لقد جلعتني اصبح شخص اخر

163
00:10:15,580 --> 00:10:17,690
 أنت لاتستطيع أن تفعل هذا

164
00:10:17,740 --> 00:10:19,130
ثم تموت , هذ ليس عدلاً

165
00:10:19,180 --> 00:10:20,610
كلارا
لا

166
00:10:20,660 --> 00:10:23,770
دكتور , أنا لاأهتم بقوانينك اللعينة
او شعورك بالذنب

167
00:10:23,820 --> 00:10:28,180
إذا كنت تحبني بأي طريقة كانت
فسوف تعود

168
00:10:35,420 --> 00:10:37,460
دكتور , هل انت ..... ؟

169
00:10:38,700 --> 00:10:40,890
لا أستطيع انقاذ موران أو بريتشارد

170
00:10:40,940 --> 00:10:44,770
لا, لكن كم قلت
أذا اكتشفت لماذا هذا يحدث؟

171
00:10:44,820 --> 00:10:48,260
فربما يمكنك أن توقفهم من أن يقتلوا أي شخص اخر
أنت تستطيع أنقاذنا

172
00:10:50,220 --> 00:10:53,090
و تستطيع أن تنقذ نفسك

173
00:10:53,140 --> 00:10:56,090
سأفعل ما بوسعي
لكن الحاضر قد حصل بالفعل

174
00:10:56,140 --> 00:10:59,940
لقد قابلنا منظم الجنائز
ولايزال على قيد الحياة

175
00:11:28,060 --> 00:11:32,210
حسناً ,صفوني
تمتلكون منظر افضل مني

176
00:11:32,260 --> 00:11:35,850
كيف ابدو؟ هل هناك ايه رضوض؟
ايه ندوب؟

177
00:11:35,900 --> 00:11:37,530
اي دليل على كيفية موتي؟

178
00:11:37,580 --> 00:11:38,770
لا , لاشيء

179
00:11:38,820 --> 00:11:41,330
تشبه جميع الاشباح السابقين مع
نفس العيون الغريبة

180
00:11:46,140 --> 00:11:49,700
لا لا , أنتظر , معطفك

181
00:11:51,060 --> 00:11:53,610
أنه ممزق من جهة الكتف الايمن

182
00:11:53,660 --> 00:11:56,330
أنا افترض أنني أقول نفس الشيء
كالاخرين

183
00:11:56,380 --> 00:12:01,130
لا , أنت تقول قائمة من الاسماء
أسمائنا بالتحديد

184
00:12:01,180 --> 00:12:04,170
موران , بريتشارد , برينتز
اودونيل , كلارا , دكتور

185
00:12:04,220 --> 00:12:05,490
بيننت , كاسس

186
00:12:05,540 --> 00:12:08,660
من يكون برينتس؟
الشاب ذو وجه الخلد

187
00:12:10,900 --> 00:12:13,900
ما الامر؟
كلارا , مالذي حدث؟

188
00:12:14,940 --> 00:12:17,170
لقد أتيت للداخل
أنت بالداخل الان

189
00:12:17,220 --> 00:12:19,530
ما الذي افعله؟

190
